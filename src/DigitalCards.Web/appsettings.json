{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "DigitalCards": {
    "UseFakeIntegrations": true,
    "PersistenceProvider": "InMemory",
    "GoogleWallet": {
      "Provider": "Fake"
    },
    "AppleWallet": {
      "Provider": "Fake"
    },
    "Email": {
      "Provider": "Fake"
    },
    "WalletLinks": {
      "AllowLegacyCardIdTokens": false
    },
    "Branding": {
      "LogoUploads": {
        "RequestPath": "/uploads/business-logos",
        "MaxBytes": 2097152
      }
    },
    "Diagnostics": {
      "EnableDevOutbox": false
    }
  },
  "AllowedHosts": "*"
}
