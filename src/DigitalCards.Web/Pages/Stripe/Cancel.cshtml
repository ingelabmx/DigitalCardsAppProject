@page
@model DigitalCards.Web.Pages.Stripe.CancelModel
@{
    ViewData["Title"] = "Pago cancelado";
    Layout = "_LandingLayout";
}

<div class="p-page-header" style="text-align:center; padding: 3rem 1rem;" data-testid="stripe-cancel-panel">
    <div style="font-size: 3rem; margin-bottom: 1rem;">
        <i class="bi bi-x-circle" style="color:#dc2626;"></i>
    </div>
    <h1 class="p-page-heading">Pago cancelado</h1>
    <p class="p-page-sub">Tu negocio fue creado pero el pago no se completo. Puedes intentar de nuevo cuando quieras.</p>

    @if (Model.BusinessId.HasValue)
    {
        <form method="post" class="mt-4">
            <input type="hidden" name="businessId" value="@Model.BusinessId.Value" />
            <button class="btn btn-primary btn-lg" type="submit" data-testid="stripe-cancel-retry">
                Completar pago
            </button>
        </form>
    }

    <div class="mt-3">
        <a asp-page="/Index" class="btn btn-outline-secondary">Volver al inicio</a>
    </div>
</div>
