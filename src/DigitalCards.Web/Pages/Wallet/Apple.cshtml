@page "{token}"
@model DigitalCards.Web.Pages.Wallet.AppleModel
@{
    ViewData["Title"] = "Apple Wallet";
}

@if (Model.Result is null)
{
    <section class="result-panel" data-testid="apple-wallet-not-found">
        <h1>Link no valido</h1>
        <p>El link de enrolamiento no existe o ya no esta disponible.</p>
    </section>
}
else
{
    if (Model.Result.Status == DigitalCards.Application.Models.AppleWalletIssueStatus.Ready)
    {
        <section class="result-panel" data-testid="apple-wallet-ready">
            <h1>Apple Wallet lista</h1>
            <p data-testid="apple-wallet-message">@Model.Result.Message</p>
            <a class="btn btn-dark" href="@Model.Result.DownloadUrl" data-testid="apple-wallet-download-link">Descargar Apple Wallet</a>
        </section>
    }
    else
    {
        <section class="result-panel" data-testid="apple-wallet-pending">
            <h1>Apple Wallet pendiente</h1>
            <p data-testid="apple-wallet-message">@Model.Result.Message</p>
            <a asp-page="/Wallet/Select" asp-route-token="@Model.Token">Volver</a>
        </section>
    }
}
