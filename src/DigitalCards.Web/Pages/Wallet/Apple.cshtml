@page "{token}"
@model DigitalCards.Web.Pages.Wallet.AppleModel
@{
    ViewData["Title"] = "Apple Wallet";
}

@if (Model.Result is null)
{
    <section class="result-panel" data-testid="apple-wallet-not-found">
        <h1>Link no valido</h1>
        <p>El link de enrolamiento no existe o ya no esta disponible.</p>
    </section>
}
else
{
    var primaryColor = Model.Landing?.PrimaryColor ?? "#111827";
    var secondaryColor = Model.Landing?.SecondaryColor ?? "#5d87ff";

    if (Model.Result.Status == DigitalCards.Application.Models.AppleWalletIssueStatus.Ready)
    {
        <section class="result-panel wallet-public-panel" style="--wallet-primary:@primaryColor;--wallet-secondary:@secondaryColor;" data-testid="apple-wallet-ready">
            <p class="eyebrow">Apple Wallet</p>
            <h1>@(Model.Landing?.BusinessName ?? "Apple Wallet") lista</h1>
            <p data-testid="apple-wallet-message">@Model.Result.Message</p>
            <div class="wallet-install-help" data-testid="apple-wallet-install-help">
                <strong>Para instalar en iPhone</strong>
                <ul>
                    <li>Abre el link desde Safari en el iPhone.</li>
                    <li>Si Wallet muestra error, elimina una version anterior del pase y vuelve a descargar.</li>
                    <li>Manten este dominio abierto durante la instalacion para que las actualizaciones funcionen.</li>
                </ul>
            </div>
            <a class="btn btn-dark" href="@Model.Result.DownloadUrl" data-testid="apple-wallet-download-link">Descargar Apple Wallet</a>
        </section>
    }
    else
    {
        <section class="result-panel wallet-public-panel" style="--wallet-primary:@primaryColor;--wallet-secondary:@secondaryColor;" data-testid="apple-wallet-pending">
            <p class="eyebrow">Apple Wallet</p>
            <h1>Apple Wallet pendiente</h1>
            <p data-testid="apple-wallet-message">@Model.Result.Message</p>
            <div class="wallet-install-help" data-testid="apple-wallet-install-help">
                <strong>Apple Wallet no esta disponible todavia</strong>
                <p>Cuando el pase este activo, el boton descargara un archivo `.pkpass` instalable desde Safari.</p>
            </div>
            <a class="btn btn-outline-secondary" asp-page="/Wallet/Select" asp-route-token="@Model.Token">Volver</a>
        </section>
    }
}
