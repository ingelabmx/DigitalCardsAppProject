@page "{token}"
@model DigitalCards.Web.Pages.Wallet.SelectModel
@{
    ViewData["Title"] = "Seleccionar Wallet";
}

@if (Model.Landing is null)
{
    <section class="result-panel" data-testid="wallet-not-found">
        <h1>Link no valido</h1>
        <p>El link de enrolamiento no existe o ya no esta disponible.</p>
    </section>
}
else
{
    var primaryColor = Model.Landing.PrimaryColor ?? "#111827";
    var secondaryColor = Model.Landing.SecondaryColor ?? "#5d87ff";
    var customFieldColor = Model.Landing.CustomFieldColor ?? "#ffffff";
    var fallbackInitials = Model.Landing.BusinessName[..Math.Min(Model.Landing.BusinessName.Length, 2)].ToUpperInvariant();

    <section class="wallet-panel wallet-public-panel"
             style="--wallet-primary:@primaryColor;--wallet-secondary:@secondaryColor;--wallet-custom:@customFieldColor;"
             data-testid="wallet-select">
        <div class="wallet-public-brand">
            @if (!string.IsNullOrWhiteSpace(Model.Landing.LogoPath))
            {
                <img src="@Model.Landing.LogoPath" alt="@Model.Landing.BusinessName logo" data-testid="wallet-business-logo" />
            }
            else
            {
                <span>@fallbackInitials</span>
            }
            <div>
                <p class="eyebrow">Tarjeta digital</p>
                <h1>@Model.Landing.BusinessName</h1>
            </div>
        </div>

        <div class="wallet-visual-card" data-testid="wallet-visual-card">
            <div>
                <span>Cliente</span>
                <strong>@Model.Landing.ClientName</strong>
            </div>
            <div>
                <span>Programa</span>
                <strong>@Model.Landing.BusinessName</strong>
            </div>
            <p>Guarda esta tarjeta digital para recibir sellos y actualizaciones del negocio.</p>
        </div>

        <p class="lead">Elige donde guardar tu tarjeta. Se actualizara automaticamente cuando el negocio agregue nuevos sellos.</p>

        <div class="wallet-actions">
            <a class="btn btn-dark wallet-button d-flex align-items-center justify-content-center"
               asp-page="/Wallet/Apple"
               asp-route-token="@Model.Landing.Token"
               data-wallet-button="apple"
               data-testid="apple-wallet-button">
                <span>Apple Wallet</span>
                <small>iPhone</small>
                <small data-wallet-recommendation hidden>Recomendado para este celular</small>
            </a>
            <a class="btn btn-primary wallet-button d-flex align-items-center justify-content-center"
               asp-page="/Wallet/Google"
               asp-route-token="@Model.Landing.Token"
               data-wallet-button="google"
               data-testid="google-wallet-button">
                <span>Google Wallet</span>
                <small>Android</small>
                <small data-wallet-recommendation hidden>Recomendado para este celular</small>
            </a>
        </div>
    </section>

    @section Scripts {
        <script>
            (() => {
                const root = document.querySelector("[data-testid='wallet-select']");
                if (!root) {
                    return;
                }

                const userAgent = navigator.userAgent || "";
                const recommendedWallet = /iPhone|iPad|iPod/i.test(userAgent)
                    ? "apple"
                    : /Android/i.test(userAgent)
                        ? "google"
                        : "";

                if (!recommendedWallet) {
                    return;
                }

                root.dataset.recommendedWallet = recommendedWallet;
                const button = root.querySelector(`[data-wallet-button="${recommendedWallet}"]`);
                button?.classList.add("is-recommended");
                button?.querySelector("[data-wallet-recommendation]")?.removeAttribute("hidden");
            })();
        </script>
    }
}
