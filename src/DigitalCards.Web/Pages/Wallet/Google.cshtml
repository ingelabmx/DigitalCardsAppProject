@page "{token}"
@model DigitalCards.Web.Pages.Wallet.GoogleModel
@{
    ViewData["Title"] = "Google Wallet";
}

@if (Model.Result is null)
{
    <section class="result-panel" data-testid="google-wallet-not-found">
        <h1>Link no valido</h1>
        <p>No se pudo emitir Google Wallet para este token.</p>
    </section>
}
else
{
    var primaryColor = Model.Landing?.PrimaryColor ?? "#111827";
    var secondaryColor = Model.Landing?.SecondaryColor ?? "#5d87ff";

    <section class="result-panel wallet-public-panel" style="--wallet-primary:@primaryColor;--wallet-secondary:@secondaryColor;" data-testid="google-wallet-result">
        <p class="eyebrow">Google Wallet</p>
        <h1>@(Model.Landing?.BusinessName ?? "Google Wallet") emitida</h1>
        <p>Object ID: <strong data-testid="google-object-id">@Model.Result.ObjectId</strong></p>
        <div class="wallet-install-help" data-testid="google-wallet-install-help">
            <strong>Para guardar en Android</strong>
            <ul>
                <li>Abre el boton con Chrome o el navegador asociado a tu cuenta Google.</li>
                <li>Confirma que la cuenta correcta este iniciada antes de guardar.</li>
                <li>Si ya existe la tarjeta, vuelve a abrir Google Wallet para ver el ultimo sello.</li>
            </ul>
        </div>
        <div class="form-actions">
            <a class="wallet-store-badge-link wallet-store-badge-link-single" href="@Model.Result.SaveUrl" data-testid="google-save-url">
                <img src="/img/add_to_google_wallet.svg" alt="Add to Google Wallet" />
            </a>
            @if (Model.Landing is not null)
            {
                <a class="btn btn-outline-secondary" asp-page="/Wallet/Select" asp-route-token="@Model.Landing.Token">Volver</a>
            }
        </div>
    </section>
}
