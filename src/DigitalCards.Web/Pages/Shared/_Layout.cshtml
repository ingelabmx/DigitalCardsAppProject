<!DOCTYPE html>
<html lang="es">
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment WebHostEnvironment
@inject DigitalCards.Application.Services.DigitalCardsAppService AppService
@{
    var requestPath = Context.Request.Path;
    var isAdmin = User.HasClaim(claim => claim.Type == AdminAuth.AdminUserIdClaim);
    var isBusiness = User.HasClaim(claim => claim.Type == BusinessAuth.BusinessIdClaim);
    var isClient = User.HasClaim(claim => claim.Type == ClientAuth.ClientIdClaim);
    var isAuthenticatedArea =
        requestPath.StartsWithSegments("/Admin") ||
        requestPath.StartsWithSegments("/Business") ||
        requestPath.StartsWithSegments("/Client");
    var isAuthPage =
        requestPath.Value?.EndsWith("/Login", StringComparison.OrdinalIgnoreCase) == true ||
        requestPath.Value?.EndsWith("/ForgotPassword", StringComparison.OrdinalIgnoreCase) == true ||
        requestPath.Value?.EndsWith("/ResetPassword", StringComparison.OrdinalIgnoreCase) == true;
    var navClientCta = requestPath.Value?.EndsWith("/Client/Login", StringComparison.OrdinalIgnoreCase) == true;
    var navBusinessCta = requestPath.Value?.EndsWith("/Business/Login", StringComparison.OrdinalIgnoreCase) == true;
    var useLegacyShell = isAuthenticatedArea && !isAuthPage && (isAdmin || isBusiness || isClient);
    var shellRole = isAdmin ? "Administradores" : isBusiness ? "Negocio" : "Cliente";
    var shellName = isAdmin
        ? User.FindFirst(AdminAuth.AdminNameClaim)?.Value ?? "Admin"
        : isBusiness
            ? User.FindFirst(BusinessAuth.BusinessNameClaim)?.Value ?? "Negocio"
            : User.FindFirst(ClientAuth.ClientNameClaim)?.Value ?? "Cliente";
    string shellPrimaryColor = "#0A0A0A";
    string shellSecondaryColor = "#1D6AF5";
    if (isBusiness)
    {
        var shellBusiness = await AppService.GetBusinessShellAsync(
            BusinessAuth.GetBusinessId(User),
            Context.RequestAborted);
        shellName = ViewData["BusinessShellName"] as string
            ?? shellBusiness?.Name
            ?? shellName;
    }

    var puntelioBrandingLogoPath = ResolvePuntelioBrandingLogoPath();
    var puntelioIconPath = ResolvePuntelioIconPath();
    string SidebarClass(string path) => requestPath.StartsWithSegments(path)
        ? "legacy-sidebar-link active"
        : "legacy-sidebar-link";
    string? ResolvePuntelioBrandingLogoPath()
    {
        foreach (var path in new[] { "/img/puntelio-branding.svg", "/img/puntelio-branding.png" })
        {
            if (WebHostEnvironment.WebRootFileProvider.GetFileInfo(path.TrimStart('/')).Exists)
            {
                return path;
            }
        }

        return null;
    }

    string? ResolvePuntelioIconPath()
    {
        foreach (var path in new[] { "/img/puntelio-logo.svg", "/img/puntelio-logo.png" })
        {
            if (WebHostEnvironment.WebRootFileProvider.GetFileInfo(path.TrimStart('/')).Exists)
            {
                return path;
            }
        }

        return null;
    }
}
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <!-- SEO -->
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — Puntelio" : "Puntelio — Panel de negocios y clientes")</title>
    <meta name="description" content="Accede a tu panel de Puntelio para gestionar tarjetas de lealtad, sellos y clientes." />
    <meta name="robots" content="noindex, nofollow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Puntelio" />
    <meta property="og:title" content="Puntelio — Panel de negocios" />
    <meta property="og:description" content="Gestiona tu programa de lealtad digital desde un solo panel." />
    <meta property="og:image" content="https://puntelio.com/img/og-image.png" />
    <meta property="og:url" content="https://app.puntelio.com" />
    @if (puntelioIconPath is not null)
    {
        <link rel="icon" type="image/svg+xml" href="@puntelioIconPath" asp-append-version="true" />
    }
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DigitalCards.Web.styles.css" asp-append-version="true" />
</head>
@functions {
    private static Microsoft.AspNetCore.Html.IHtmlContent SidebarIcon(string name)
    {
        var body = name switch
        {
            "dashboard" => "<path d=\"M4 4h7v7H4z\"/><path d=\"M13 4h7v5h-7z\"/><path d=\"M13 11h7v9h-7z\"/><path d=\"M4 13h7v7H4z\"/>",
            "business" => "<path d=\"M4 20V7l8-3 8 3v13\"/><path d=\"M9 20v-7h6v7\"/><path d=\"M8 9h.01\"/><path d=\"M12 8h.01\"/><path d=\"M16 9h.01\"/>",
            "admin" => "<path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"/><path d=\"M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8\"/><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/>",
            "reports" => "<path d=\"M4 19V5\"/><path d=\"M4 19h16\"/><path d=\"M8 16v-5\"/><path d=\"M12 16V8\"/><path d=\"M16 16v-3\"/>",
            "support" => "<circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M8.5 8.5l7 7\"/><path d=\"M15.5 8.5l-7 7\"/><path d=\"M9 3.7l1.8 4.1\"/><path d=\"M15 20.3l-1.8-4.1\"/>",
            "cards" => "<rect x=\"3\" y=\"5\" width=\"18\" height=\"14\" rx=\"2\"/><path d=\"M3 10h18\"/><path d=\"M7 15h5\"/>",
            "enroll" => "<path d=\"M15 19a6 6 0 0 0-12 0\"/><path d=\"M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8\"/><path d=\"M19 8v6\"/><path d=\"M22 11h-6\"/>",
            "stamp" => "<path d=\"M6 21h12\"/><path d=\"M8 21v-5h8v5\"/><path d=\"M7 16h10l-1-5H8z\"/><path d=\"M9 11V5a3 3 0 0 1 6 0v6\"/>",
            "branding" => "<path d=\"M12 22a9 9 0 1 1 8.9-10.3 2.4 2.4 0 0 1-2.4 2.8h-1.4a2.1 2.1 0 0 0-1.5 3.6 2.1 2.1 0 0 1-1.4 3.6z\"/><path d=\"M7.5 10.5h.01\"/><path d=\"M10.5 7.5h.01\"/><path d=\"M14.5 7.5h.01\"/>",
            "profile" => "<path d=\"M20 21a8 8 0 0 0-16 0\"/><circle cx=\"12\" cy=\"7\" r=\"4\"/>",
            "logout" => "<path d=\"M10 17l5-5-5-5\"/><path d=\"M15 12H3\"/><path d=\"M21 3v18\"/>",
            _ => "<circle cx=\"12\" cy=\"12\" r=\"8\"/>"
        };

        return new Microsoft.AspNetCore.Html.HtmlString(
            $"<span class=\"legacy-sidebar-icon\" aria-hidden=\"true\"><svg viewBox=\"0 0 24 24\" role=\"img\" focusable=\"false\">{body}</svg></span>");
    }
}
<body class="@(useLegacyShell ? "legacy-shell" : "public-shell")">
    @if (useLegacyShell)
    {
        <div class="legacy-page-wrapper" style="--shell-primary:@shellPrimaryColor;--shell-secondary:@shellSecondaryColor;" data-testid="legacy-shell">
            <aside class="legacy-left-sidebar" id="legacy-sidebar" data-testid="legacy-sidebar">
                <div class="legacy-brand">
                    <a asp-page="@(isAdmin ? "/Admin/Dashboard" : isBusiness ? "/Business/Dashboard" : "/Client/Dashboard")" class="legacy-brand-link legacy-brand-link-wordmark">
                        @if (puntelioBrandingLogoPath is not null)
                        {
                            <span class="brand-wordmark-shell" data-testid="puntelio-brand-mark">
                                <img src="@puntelioBrandingLogoPath" asp-append-version="true" alt="Puntelio" />
                            </span>
                        }
                        else
                        {
                            <span class="legacy-brand-fallback">
                                <span class="legacy-brand-mark brand-mark brand-logo-mark" data-testid="puntelio-brand-mark">
                                    @if (puntelioIconPath is not null)
                                    {
                                        <img src="@puntelioIconPath" asp-append-version="true" alt="Puntelio" />
                                    }
                                    <span class="brand-logo-letter">P</span>
                                </span>
                                <strong>Puntelio</strong>
                            </span>
                        }
                    </a>
                </div>

                <nav class="legacy-sidebar-nav" aria-label="Navegacion principal">
                    <p class="legacy-nav-caption">@shellRole</p>
                    <ul>
                        @if (isAdmin)
                        {
                            <li><a class="@SidebarClass("/Admin/Dashboard")" asp-page="/Admin/Dashboard">@SidebarIcon("dashboard")Dashboard</a></li>
                            <li><a class="@SidebarClass("/Admin/Businesses")" asp-page="/Admin/Businesses">@SidebarIcon("business")Negocios</a></li>
                            <li><a class="@SidebarClass("/Admin/Clients")" asp-page="/Admin/Clients">@SidebarIcon("profile")Clientes</a></li>
                            <li><a class="@SidebarClass("/Admin/AdminUsers")" asp-page="/Admin/AdminUsers">@SidebarIcon("admin")Administradores</a></li>
                            <li><a class="@SidebarClass("/Admin/Reports")" asp-page="/Admin/Reports">@SidebarIcon("reports")Reportes</a></li>
                            <li><a class="@SidebarClass("/Admin/Support")" asp-page="/Admin/Support">@SidebarIcon("support")Soporte</a></li>
                        }
                        else if (isBusiness)
                        {
                            <li><a class="@SidebarClass("/Business/Dashboard")" asp-page="/Business/Dashboard">@SidebarIcon("dashboard")Dashboard</a></li>
                            <li><a class="@SidebarClass("/Business/Cards")" asp-page="/Business/Cards" data-testid="cards-link">@SidebarIcon("cards")Tarjetas</a></li>
                            <li><a class="@SidebarClass("/Business/Enroll")" asp-page="/Business/Enroll" data-testid="enroll-link">@SidebarIcon("enroll")Asociar cliente</a></li>
                            <li><a class="@SidebarClass("/Business/Stamp")" asp-page="/Business/Stamp" data-testid="stamp-link">@SidebarIcon("stamp")Sellos</a></li>
                            <li><a class="@SidebarClass("/Business/Reports")" asp-page="/Business/Reports">@SidebarIcon("reports")Reportes</a></li>
                            <li><a class="@SidebarClass("/Business/Branding")" asp-page="/Business/Branding">@SidebarIcon("branding")Branding</a></li>
                            <li><a class="@SidebarClass("/Business/Account")" asp-page="/Business/Account">@SidebarIcon("profile")Mi cuenta</a></li>
                        }
                        else if (isClient)
                        {
                            <li><a class="@SidebarClass("/Client/Dashboard")" asp-page="/Client/Dashboard" data-testid="client-sidebar-dashboard-link">@SidebarIcon("dashboard")Dashboard</a></li>
                            <li><a class="@SidebarClass("/Client/Cards")" asp-page="/Client/Cards" data-testid="client-sidebar-cards-link">@SidebarIcon("cards")Mis tarjetas</a></li>
                            <li><a class="@SidebarClass("/Client/Profile")" asp-page="/Client/Profile" data-testid="client-sidebar-profile-link">@SidebarIcon("profile")Perfil</a></li>
                        }
                    </ul>

                    <p class="legacy-nav-caption">Autenticacion</p>
                    <ul>
                        @if (isAdmin)
                        {
                            <li><a class="legacy-sidebar-link" asp-page="/Admin/Logout" data-testid="admin-layout-logout-link">@SidebarIcon("logout")Cerrar sesion</a></li>
                        }
                        else if (isBusiness)
                        {
                            <li><a class="legacy-sidebar-link" asp-page="/Business/Logout" data-testid="business-logout-link">@SidebarIcon("logout")Cerrar sesion</a></li>
                        }
                        else if (isClient)
                        {
                            <li><a class="legacy-sidebar-link" asp-page="/Client/Logout" data-testid="client-layout-logout-link">@SidebarIcon("logout")Cerrar sesion</a></li>
                        }
                    </ul>
                </nav>
            </aside>

            <div class="legacy-body-wrapper">
                <div class="legacy-sidebar-backdrop" data-legacy-sidebar-backdrop></div>
                <header class="legacy-app-header" data-testid="legacy-header">
                    <div>
                        <button class="legacy-menu-button"
                                type="button"
                                aria-label="Abrir navegacion"
                                aria-controls="legacy-sidebar"
                                aria-expanded="false"
                                data-legacy-menu-button>
                            <span></span>
                            <span></span>
                            <span></span>
                        </button>
                    </div>
                    <div class="p-user-pill">
                        <span class="p-user-role">@shellRole</span>
                        <span class="p-user-name">@shellName</span>
                    </div>
                </header>

                <main role="main" class="legacy-container-fluid">
                    @RenderBody()
                </main>

                <footer class="legacy-footer">
                    Propiedad de Ingelab
                </footer>
            </div>
        </div>
    }
    else
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container">
                    <a class="navbar-brand fw-semibold brand-lockup brand-lockup-wordmark" asp-area="" asp-page="/Index" data-testid="public-brand-lockup">
                        @if (puntelioBrandingLogoPath is not null)
                        {
                            <img class="brand-wordmark-public" src="@puntelioBrandingLogoPath" asp-append-version="true" alt="Puntelio" data-testid="puntelio-public-brand-mark" />
                        }
                        else
                        {
                            <span class="brand-mark brand-mark-sm brand-logo-mark" data-testid="puntelio-public-brand-mark">
                                @if (puntelioIconPath is not null)
                                {
                                    <img src="@puntelioIconPath" asp-append-version="true" alt="Puntelio" />
                                }
                                <span class="brand-logo-letter">P</span>
                            </span>
                            <span class="brand-lockup-text">Puntelio</span>
                        }
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item">
                                <a class="nav-link @(navClientCta ? "nav-link-cta" : "")" asp-page="/Client/Login">Clientes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(navBusinessCta ? "nav-link-cta" : "")" asp-page="/Business/Login">Negocios</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2026 - Puntelio. Propiedad de Ingelab.
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
    (function () {
        function formatLocalTime(utcString, format) {
            var d = new Date(utcString);
            if (isNaN(d.getTime())) return null;
            var opts = { hour12: true };
            if (format === 'datetime' || !format) {
                opts.year = 'numeric'; opts.month = 'numeric'; opts.day = 'numeric';
                opts.hour = 'numeric'; opts.minute = '2-digit';
            } else if (format === 'date') {
                opts.year = 'numeric'; opts.month = 'numeric'; opts.day = 'numeric';
            } else if (format === 'time') {
                opts.hour = 'numeric'; opts.minute = '2-digit';
            } else if (format === 'relative') {
                var diff = Math.floor((Date.now() - d.getTime()) / 1000);
                if (diff < 60) return 'hace un momento';
                if (diff < 3600) return 'hace ' + Math.floor(diff / 60) + ' min';
                if (diff < 86400) return 'hace ' + Math.floor(diff / 3600) + ' h';
                opts.year = 'numeric'; opts.month = 'numeric'; opts.day = 'numeric';
                opts.hour = 'numeric'; opts.minute = '2-digit';
            }
            return d.toLocaleString(navigator.language || 'es-MX', opts);
        }
        document.querySelectorAll('time.local-time[data-utc]').forEach(function (el) {
            var formatted = formatLocalTime(el.getAttribute('data-utc'), el.getAttribute('data-format'));
            if (formatted) el.textContent = formatted;
        });
    })();
    </script>
</body>
</html>
