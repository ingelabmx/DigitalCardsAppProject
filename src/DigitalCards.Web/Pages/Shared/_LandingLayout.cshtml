@using DigitalCards.Web.Landing
@inject Microsoft.Extensions.Options.IOptions<LandingOptions> LandingOptionsAccessor
@{
    var landing = LandingOptionsAccessor.Value;
    var title = ViewData["Title"] != null
        ? ViewData["Title"] + " — Puntelio"
        : "Puntelio — Tarjetas de lealtad digitales";
    var description = ViewData["Description"]?.ToString()
        ?? "Digitaliza tus tarjetas de sellos, premia a tus clientes y administra recompensas con QR desde una plataforma simple para negocios.";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <!-- SEO -->
    <title>@title</title>
    <meta name="description" content="Puntelio ayuda a negocios locales a reemplazar tarjetas físicas por tarjetas digitales con sellos, QR, recompensas y estadísticas. Un sistema para el mostrador y otro para el cliente." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="@landing.SiteUrl" />

    <!-- Open Graph (WhatsApp, Facebook, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Puntelio" />
    <meta property="og:title" content="Puntelio — Tarjetas de lealtad digitales" />
    <meta property="og:description" content="Fideliza a tus clientes con tarjetas digitales, sellos, QR y Wallet. Sin app, sin tarjetas físicas." />
    <meta property="og:image" content="@($"{landing.SiteUrl.TrimEnd('/')}/img/og-image.png")" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content="@landing.SiteUrl" />
    <meta property="og:locale" content="es_MX" />

    <!-- Twitter/X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Puntelio — Tarjetas de lealtad digitales" />
    <meta name="twitter:description" content="Fideliza a tus clientes con tarjetas digitales, sellos, QR y Wallet." />
    <meta name="twitter:image" content="@($"{landing.SiteUrl.TrimEnd('/')}/img/og-image.png")" />
    <!-- FIX 1: Preconnect para dominios criticos -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <!-- FIX 3: Preload hero background para mejorar LCP -->
    <link rel="preload" as="image" href="/img/background.webp" fetchpriority="high" />
    <link rel="icon" type="image/svg+xml" href="~/img/puntelio-logo.svg" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="landing-shell">
    <header class="landing-header">
        <a class="landing-brand" asp-page="/Index" aria-label="Puntelio">
            <img src="~/img/puntelio-branding.svg" asp-append-version="true" alt="Puntelio" />
        </a>
        <nav aria-label="Navegacion principal">
            <a class="p-btn p-btn-outline" href="@landing.AppUrl">Entrar</a>
        </nav>
    </header>

    <main class="landing-main">
        @RenderBody()
    </main>

    <footer class="landing-footer">
        <div>
            <img src="~/img/puntelio-branding.svg" asp-append-version="true" alt="Puntelio" />
            <p>Sistema de fidelizacion para negocios locales mediante tarjetas digitales de sellos.</p>
        </div>
        <div>
            <h2>Contacto</h2>
            <p><a href="mailto:@landing.ContactEmail">@landing.ContactEmail</a></p>
            <p>@landing.PhoneDisplay</p>
            <p>Tijuana, BC</p>
        </div>
        <div>
            <h2>Redes</h2>
            <p><a href="@landing.InstagramUrl">Instagram @@puntelio</a></p>
            <p><a href="@landing.TikTokUrl">TikTok @@puntelio</a></p>
        </div>
        <div>
            <h2>Legal</h2>
            <p><a asp-page="/Terminos">Terminos y condiciones</a></p>
            <p><a asp-page="/Privacidad">Politica de privacidad</a></p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js" defer></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="~/js/landing.js" asp-append-version="true" defer></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
