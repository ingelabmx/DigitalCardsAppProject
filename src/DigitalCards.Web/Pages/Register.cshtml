@page
@model DigitalCards.Web.Pages.RegisterModel
@{
    ViewData["Title"] = "Registro cliente";
}

<section class="form-panel">
    <h1>Registro cliente</h1>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status" data-testid="register-success">@Model.StatusMessage</div>
    }

    <form method="post" data-testid="register-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Input.UserName" class="form-label"></label>
            <input asp-for="Input.UserName" class="form-control" data-testid="register-username" />
            <span asp-validation-for="Input.UserName" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Input.FirstName" class="form-label"></label>
                <input asp-for="Input.FirstName" class="form-control" data-testid="register-first-name" />
                <span asp-validation-for="Input.FirstName" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Input.LastName" class="form-label"></label>
                <input asp-for="Input.LastName" class="form-control" data-testid="register-last-name" />
                <span asp-validation-for="Input.LastName" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Email" class="form-label"></label>
            <input asp-for="Input.Email" class="form-control" data-testid="register-email" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <button class="btn btn-primary" type="submit" data-testid="register-submit">Registrar</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

