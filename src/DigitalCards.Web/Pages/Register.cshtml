@page
@model DigitalCards.Web.Pages.RegisterModel
@{
    ViewData["Title"] = "Registro cliente";
}

<section class="auth-gateway">
    <div class="auth-copy-panel">
        <h1>Empieza a usar tus tarjetas digitales.</h1>
        <p>Crea tu cuenta para consultar sellos, abrir tus links Wallet y mantener tus tarjetas de lealtad en un solo lugar.</p>
        <a class="auth-home-link" asp-page="/Index">Volver al inicio</a>
    </div>

    <div class="auth-form-card">
        <div class="auth-form-heading">
            <div>
                <h2>Crear cuenta</h2>
                <p>Usa un correo al que puedas acceder para recibir links de Wallet y recuperacion.</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="alert alert-success" role="status" data-testid="register-success">@Model.StatusMessage</div>
        }

        <form method="post" data-testid="register-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Input.UserName" class="form-label"></label>
                <input asp-for="Input.UserName"
                       class="form-control form-control-lg"
                       pattern="[A-Za-z0-9]+"
                       autocomplete="username"
                       autocapitalize="none"
                       spellcheck="false"
                       data-testid="register-username" />
                <span asp-validation-for="Input.UserName" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.FirstName" class="form-label"></label>
                    <input asp-for="Input.FirstName" class="form-control form-control-lg" data-testid="register-first-name" />
                    <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.LastName" class="form-label"></label>
                    <input asp-for="Input.LastName" class="form-control form-control-lg" data-testid="register-last-name" />
                    <span asp-validation-for="Input.LastName" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control form-control-lg" data-testid="register-email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" class="form-control form-control-lg" data-testid="register-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="Input.AcceptTerms" class="form-check-input" data-testid="register-accept-terms" />
                <label asp-for="Input.AcceptTerms" class="form-check-label">
                    Acepto los <a asp-page="/Privacy" target="_blank" rel="noopener">terminos y privacidad</a>.
                </label>
                <span asp-validation-for="Input.AcceptTerms" class="text-danger"></span>
            </div>

            <button class="btn btn-primary btn-lg w-100" type="submit" data-testid="register-submit">Crear cuenta</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
