@section Scripts {
    @if (Model.IsLanding)
    {
        <partial name="_ValidationScriptsPartial" />
        <script src="~/js/landing.js" asp-append-version="true"></script>
        <script>
            (function () {
                var carousel = document.querySelector('[data-landing-carousel]');
                if (!carousel) return;
                var slides = Array.from(carousel.querySelectorAll('[data-carousel-slide]'));
                if (slides.length === 0) return;
                var prevBtn = carousel.querySelector('[data-carousel-prev]');
                var nextBtn = carousel.querySelector('[data-carousel-next]');
                var current = 0;
                var timer;

                function update() {
                    var total = slides.length;
                    slides.forEach(function (slide, i) {
                        slide.classList.remove('peek-active', 'peek-prev', 'peek-next', 'peek-hidden');
                        var diff = (i - current + total) % total;
                        if (diff === 0) slide.classList.add('peek-active');
                        else if (diff === 1) slide.classList.add('peek-next');
                        else if (diff === total - 1) slide.classList.add('peek-prev');
                        else slide.classList.add('peek-hidden');
                    });
                }

                function goNext() { current = (current + 1) % slides.length; update(); }
                function goPrev() { current = (current - 1 + slides.length) % slides.length; update(); }
                function startTimer() { timer = setInterval(goNext, 3500); }
                function resetTimer() { clearInterval(timer); startTimer(); }

                if (prevBtn) prevBtn.addEventListener('click', function () { goPrev(); resetTimer(); });
                if (nextBtn) nextBtn.addEventListener('click', function () { goNext(); resetTimer(); });

                update();
                startTimer();
            })();
        </script>
    }
}
