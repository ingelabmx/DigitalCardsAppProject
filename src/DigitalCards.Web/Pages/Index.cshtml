@page
@using DigitalCards.Web.Diagnostics
@inject IWebHostEnvironment HostEnvironment
@inject IConfiguration Configuration
@model IndexModel
@{
    ViewData["Title"] = "Migracion ASP.NET Core";
    var showDevOutboxLink = DevToolAccess.ShouldRenderDevOutboxLink(
        HostEnvironment,
        Configuration,
        User);
}

<section class="app-surface">
    <div>
        <p class="eyebrow">ASP.NET Core paralelo</p>
        <h1>DigitalCards migration shell</h1>
        <p class="lead">
            Esqueleto modular con dominio, casos de uso, providers controlados y Razor Pages para cubrir los primeros flujos criticos sin reemplazar Web Forms.
        </p>
    </div>

    <div class="action-grid" aria-label="Flujos disponibles">
        <a class="action-card" asp-page="/Register" data-testid="home-register-link">
            <span>Registro cliente</span>
            <small>Alta de cliente con el provider configurado.</small>
        </a>
        <a class="action-card" asp-page="/Business/Login" data-testid="home-business-login-link">
            <span>Login negocio</span>
            <small>Usa demo local o negocio legacy segun configuracion.</small>
        </a>
        @if (showDevOutboxLink)
        {
            <a class="action-card" asp-page="/Dev/Outbox" data-testid="home-outbox-link">
                <span>Outbox fake</span>
                <small>Simula correo de enrolamiento Wallet.</small>
            </a>
        }
    </div>
</section>

<section class="info-band">
    <h2>Estado de esta fase</h2>
    <p>
        Los fakes siguen siendo el default para desarrollo, CI y Playwright. MySQL HostGator, Google Wallet y SMTP real se activan solo desde configuracion local fuera del repo.
    </p>
</section>
