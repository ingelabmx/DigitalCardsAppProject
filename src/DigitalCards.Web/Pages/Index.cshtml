            @if (!string.IsNullOrWhiteSpace(Model.LandingSuccessMessage))
            {
                <div class="alert alert-success">@Model.LandingSuccessMessage</div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.LandingErrorMessage))
            {
                <div class="alert alert-danger">@Model.LandingErrorMessage</div>
            }
            <label asp-for="ScheduleCall.Name"></label>
            <input asp-for="ScheduleCall.Name" autocomplete="name" />
            <span asp-validation-for="ScheduleCall.Name" class="text-danger"></span>

            <label asp-for="ScheduleCall.BusinessName"></label>
            <input asp-for="ScheduleCall.BusinessName" autocomplete="organization" />
            <span asp-validation-for="ScheduleCall.BusinessName" class="text-danger"></span>

            <label asp-for="ScheduleCall.Email"></label>
            <input asp-for="ScheduleCall.Email" autocomplete="email" />
            <span asp-validation-for="ScheduleCall.Email" class="text-danger"></span>

            <label asp-for="ScheduleCall.Phone"></label>
            <input asp-for="ScheduleCall.Phone" autocomplete="tel" />
            <span asp-validation-for="ScheduleCall.Phone" class="text-danger"></span>

            <p class="landing-form-note">Al enviar este formulario aceptas que usemos tus datos para contactarte sobre Puntelio. No compartimos tu informacion con terceros para fines comerciales.</p>
