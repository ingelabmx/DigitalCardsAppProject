@page
@model DigitalCards.Web.Pages.Client.CardsModel
@{
    ViewData["Title"] = "Tarjetas cliente";
}

<section class="form-panel">
    <h1>Tarjetas del cliente</h1>
    <p class="text-muted">Estas tarjetas pertenecen a tu sesion de cliente.</p>
</section>

@if (Model.Cards.Count > 0)
{
    <section class="result-panel mt-3" data-testid="client-card-results">
        <h2>Resultados</h2>
        @foreach (var card in Model.Cards)
        {
            <article class="border-top py-3" data-testid="client-card">
                <h3>@card.BusinessName</h3>
                <p class="text-muted">@card.ClientUserName</p>
                <p>Sellos actuales: <strong>@card.CurrentStamps</strong></p>
                <p>Sellos historicos: <strong>@card.LifetimeStamps</strong></p>
                <p>Google Wallet: <strong>@(card.GoogleIssued ? "Google emitida" : "Pendiente")</strong></p>
                <p>
                    <a class="btn btn-outline-primary btn-sm" asp-page="/Wallet/Select" asp-route-token="@card.WalletSelectToken" data-testid="client-card-wallet-link">Abrir Wallet</a>
                </p>
            </article>
        }
    </section>
}
else
{
    <section class="result-panel mt-3" data-testid="client-card-results">
        <p class="text-muted">Todavia no tienes tarjetas asociadas.</p>
    </section>
}
