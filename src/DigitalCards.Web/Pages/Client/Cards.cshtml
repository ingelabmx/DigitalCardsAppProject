@page
@model DigitalCards.Web.Pages.Client.CardsModel
@{
    ViewData["Title"] = "Tarjetas cliente";
}

<section class="result-panel client-cards-heading">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Cliente</p>
            <h1>Mis tarjetas</h1>
            <p class="lead">Estas tarjetas pertenecen a tu sesion de cliente. Los links Wallet usan tokens opacos.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-page="/Client/Dashboard" data-testid="client-cards-dashboard-link">Dashboard</a>
    </div>
    <div class="client-identity-panel client-cards-qr-panel" data-testid="client-cards-qr-panel">
        <div class="client-qr-card" data-testid="client-cards-qr-card" aria-label="QR real del usuario @Model.ClientUserName">
            @Html.Raw(Model.ClientQrSvg)
        </div>
        <div>
            <p class="eyebrow">QR cliente</p>
            <strong data-testid="client-cards-qr-username">@Model.ClientUserName</strong>
            <p class="text-muted mb-0">El negocio puede escanear este codigo para encontrarte por usuario.</p>
        </div>
    </div>
</section>

@if (Model.Cards.Count > 0)
{
    <section class="result-panel mt-3" data-testid="client-card-results">
        <div class="page-heading">
            <div>
                <p class="eyebrow">Tarjetas</p>
                <h2>Programas asociados</h2>
            </div>
            <span class="badge text-bg-light">@Model.Cards.Count tarjeta(s)</span>
        </div>

        <div class="client-card-list">
            @foreach (var card in Model.Cards)
            {
                <article class="client-card-row" data-testid="client-card">
                    <div class="client-card-main">
                        <div class="client-card-face">
                            <span class="client-card-kicker">Puntelio</span>
                            <h3>@card.BusinessName</h3>
                            <p>@card.ClientUserName</p>
                            <div class="client-stamp-track" aria-label="Sellos actuales">
                                @for (var stamp = 1; stamp <= 10; stamp++)
                                {
                                    <span class="@(stamp <= Math.Min(card.CurrentStamps, 10) ? "filled" : string.Empty)"></span>
                                }
                            </div>
                        </div>

                        <div class="client-card-state">
                            <span class="badge text-bg-light">Ultimo sello @card.LastStampedAt.ToLocalTime().ToString("g")</span>
                            <div class="metric-row metric-row-wide">
                                <div class="metric">
                                    <span>Sellos actuales</span>
                                    <strong data-testid="client-card-current-stamps">@card.CurrentStamps</strong>
                                </div>
                                <div class="metric">
                                    <span>Sellos historicos</span>
                                    <strong data-testid="client-card-lifetime-stamps">@card.LifetimeStamps</strong>
                                </div>
                                <div class="metric">
                                    <span>Google Wallet</span>
                                    <strong data-testid="client-card-google-status">@(card.GoogleIssued ? "Google emitida" : "Pendiente")</strong>
                                </div>
                                <div class="metric">
                                    <span>Apple Wallet</span>
                                    <strong data-testid="client-card-apple-status">@(card.AppleTracked ? "Apple activa" : "Pendiente")</strong>
                                </div>
                                <div class="metric">
                                    <span>Dispositivos Apple</span>
                                    <strong data-testid="client-card-apple-devices">@card.AppleRegisteredDeviceCount</strong>
                                </div>
                                <div class="metric">
                                    <span>Ultimo update Apple</span>
                                    <strong data-testid="client-card-apple-updated">@(card.AppleUpdatedAt?.ToLocalTime().ToString("g") ?? "Pendiente")</strong>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <a class="btn btn-primary btn-sm" asp-page="/Wallet/Select" asp-route-token="@card.WalletSelectToken" data-testid="client-card-wallet-link">Abrir Wallet</a>
                        @if (card.GoogleIssued && !string.IsNullOrWhiteSpace(card.GoogleSaveUrl))
                        {
                            <a class="btn btn-outline-secondary btn-sm" href="@card.GoogleSaveUrl" data-testid="client-card-google-save-link">Abrir Google Wallet</a>
                        }
                    </div>
                </article>
            }
        </div>
    </section>
}
else
{
    <section class="result-panel mt-3" data-testid="client-card-results">
        <p class="text-muted">Todavia no tienes tarjetas asociadas.</p>
    </section>
}
