@page
@model DigitalCards.Web.Pages.Client.CardsModel
@{
    ViewData["Title"] = "Tarjetas cliente";
}

<div class="p-page-header">
    <span class="p-eyebrow">Cliente</span>
    <h1 class="p-page-heading">Mis tarjetas</h1>
    <p class="p-page-sub">Estas tarjetas pertenecen a tu sesion de cliente. Los links Wallet usan tokens opacos.</p>
</div>

<div class="p-card mb-4" data-testid="client-cards-qr-panel">
    <div class="p-qr-wrap">
        <div class="client-qr-card" data-testid="client-cards-qr-card" aria-label="QR real del usuario @Model.ClientUserName">
            @Html.Raw(Model.ClientQrSvg)
        </div>
        <div>
            <span class="p-eyebrow p-eyebrow-sm">QR cliente</span>
            <p class="p-page-heading" data-testid="client-cards-qr-username">@Model.ClientUserName</p>
            <p class="p-page-sub">El negocio puede escanear este codigo para encontrarte por usuario.</p>
        </div>
    </div>
</div>

@if (Model.Cards.Count > 0)
{
    var totalCurrentStamps = Model.Cards.Sum(card => card.CurrentStamps);
    var walletReady = Model.Cards.Count(card => card.GoogleIssued || card.AppleTracked);

    <div class="p-stats-grid mb-4" data-testid="client-cards-summary">
        <div class="p-stat">
            <div class="p-stat-label">Tarjetas</div>
            <div class="p-stat-value">@Model.Cards.Count</div>
        </div>
        <div class="p-stat">
            <div class="p-stat-label">Sellos actuales</div>
            <div class="p-stat-value">@totalCurrentStamps</div>
        </div>
        <div class="p-stat">
            <div class="p-stat-label">Tarjetas listas</div>
            <div class="p-stat-value">@walletReady</div>
        </div>
    </div>

    <div data-testid="client-card-results">
        @foreach (var card in Model.Cards)
        {
            var stampGoal = Math.Max(1, card.StampGoal);
            var visibleStamps = Math.Min(card.CurrentStamps, stampGoal);
            var stampsToGoal = Math.Max(0, stampGoal - visibleStamps);
            var stampProgress = visibleStamps * 100 / stampGoal;

            <article class="p-client-card" data-testid="client-card">
                <div class="p-client-card-face">
                    <p class="kicker">Puntelio</p>
                    <h3>@card.BusinessName</h3>
                    <p class="user">@card.ClientUserName</p>
                    <div class="p-stamps" aria-label="Sellos actuales">
                        @for (var stamp = 1; stamp <= stampGoal; stamp++)
                        {
                            <span class="p-stamp @(stamp <= visibleStamps ? "on" : string.Empty)"></span>
                        }
                    </div>
                </div>

                <div class="p-client-card-body">
                    <div class="d-flex gap-2 flex-wrap mb-3" data-testid="client-wallet-badges">
                        <span class="p-badge p-badge-gray">Ultimo sello @card.LastStampedAt.ToLocalTime().ToString("g")</span>
                        <span class="p-badge @(card.GoogleIssued || card.AppleTracked ? "p-badge-green" : "p-badge-gray")">
                            @(card.GoogleIssued || card.AppleTracked ? "Tarjeta lista" : "Tarjeta pendiente")
                        </span>
                    </div>

                    <div class="mb-3" data-testid="client-card-progress-panel">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="p-stat-label">Progreso</span>
                            <span class="p-list-name">
                                @(stampsToGoal == 0
                                    ? "Tarjeta completa"
                                    : $"Faltan {stampsToGoal} sello(s)")
                            </span>
                        </div>
                        <div class="p-progress-bar-wrap" aria-label="Progreso de sellos">
                            <div class="p-progress-bar-fill" style="width:@stampProgress%"></div>
                        </div>
                    </div>

                    <div class="p-stats-grid mb-3">
                        <div class="p-stat">
                            <div class="p-stat-label">Sellos actuales</div>
                            <div class="p-stat-value" data-testid="client-card-current-stamps">@visibleStamps</div>
                            <div class="p-stat-sub">de @stampGoal</div>
                        </div>
                        <div class="p-stat">
                            <div class="p-stat-label">Tarjeta</div>
                            <div class="p-stat-value-sm" data-testid="client-card-wallet-status">@(card.GoogleIssued || card.AppleTracked ? "Lista" : "Pendiente")</div>
                        </div>
                    </div>

                    @if (card.RecentRewardRedemptions.Count > 0)
                    {
                        <div class="p-info-box mb-3" data-testid="client-card-redemptions">
                            <strong>Ultimo canje:</strong> @card.RecentRewardRedemptions[0].RedeemedAt.ToLocalTime().ToString("g") — @card.RecentRewardRedemptions[0].RewardText
                        </div>
                    }

                    <a class="btn btn-primary btn-sm" asp-page="/Wallet/Select" asp-route-token="@card.WalletSelectToken" data-testid="client-card-wallet-link">Abrir Wallet</a>
                </div>
            </article>
        }
    </div>
}
else
{
    <div class="p-empty" data-testid="client-card-results">
        <div class="p-empty-icon"><i class="bi bi-credit-card-2-front"></i></div>
        <p class="p-empty-title" data-testid="client-cards-empty-state">Visita un negocio participante</p>
        <p class="p-empty-desc">Escanea el QR del negocio o pide que te asocien desde el mostrador para recibir tu link Wallet.</p>
        <div class="p-empty-actions">
            <a class="btn btn-primary" asp-page="/Client/Dashboard">Ver mi QR</a>
            <a class="btn btn-outline-primary" asp-page="/Client/Profile">Revisar perfil</a>
        </div>
    </div>
}
