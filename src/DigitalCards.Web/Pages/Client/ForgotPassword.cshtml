@page
@model DigitalCards.Web.Pages.Client.ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperar contrasena cliente";
}

<section class="form-panel client-auth-panel">
    <p class="eyebrow">Cliente</p>
    <h1>Recuperar contrasena cliente</h1>
    <p class="lead">Solicita un link seguro para restablecer tu acceso.</p>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status" data-testid="client-forgot-password-status">
            @Model.StatusMessage
        </div>
    }

    <form method="post" data-testid="client-forgot-password-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Input.UserNameOrEmail" class="form-label"></label>
            <input asp-for="Input.UserNameOrEmail"
                   class="form-control"
                   autocomplete="username"
                   autocapitalize="none"
                   spellcheck="false"
                   data-testid="client-forgot-username" />
            <span asp-validation-for="Input.UserNameOrEmail" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button class="btn btn-primary" type="submit" data-testid="client-forgot-submit">Enviar link</button>
            <a class="btn btn-link" asp-page="/Client/Login">Volver al login</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
