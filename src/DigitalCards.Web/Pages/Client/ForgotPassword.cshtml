@page
@model DigitalCards.Web.Pages.Client.ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperar contrasena cliente";
}

<div class="p-auth-simple">
    <span class="p-eyebrow">Cliente</span>
    <h1 class="p-page-heading mb-2">Recuperar contrasena</h1>
    <p class="p-page-sub mb-4">Solicita un link seguro para restablecer tu acceso.</p>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status" data-testid="client-forgot-password-status">
            @Model.StatusMessage
        </div>
    }

    <div class="p-card">
        <form method="post" data-testid="client-forgot-password-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Input.UserNameOrEmail" class="form-label"></label>
                <input asp-for="Input.UserNameOrEmail"
                       class="form-control"
                       autocomplete="username"
                       autocapitalize="none"
                       spellcheck="false"
                       data-testid="client-forgot-username" />
                <span asp-validation-for="Input.UserNameOrEmail" class="text-danger"></span>
            </div>

            <div class="p-action-buttons">
                <button class="btn btn-primary" type="submit" data-testid="client-forgot-submit">Enviar link</button>
                <a class="btn btn-outline-secondary" asp-page="/Client/Login">Volver al login</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
