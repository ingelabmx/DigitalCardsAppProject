@page
@model DigitalCards.Web.Pages.Client.ProfileModel
@{
    ViewData["Title"] = "Perfil cliente";
}

<section class="form-panel client-auth-panel" data-testid="client-profile">
    <p class="eyebrow">Cliente</p>
    <h1>Perfil</h1>
    <p class="lead">Actualiza tus datos basicos. El usuario se mantiene fijo para no romper tarjetas ni links Wallet.</p>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status" data-testid="client-profile-status">
            @Model.StatusMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.PasswordStatusMessage))
    {
        <div class="alert alert-success" role="status" data-testid="client-change-password-status">
            @Model.PasswordStatusMessage
        </div>
    }

    @if (Model.Client is not null)
    {
        <div class="client-profile-helper" data-testid="client-profile-helper">
            <span>Usuario fijo</span>
            <p>Tu username se usa para QR y busqueda de mostrador. No se cambia para proteger tarjetas y Wallets existentes.</p>
        </div>

        <dl class="client-profile-list" data-testid="client-profile-readonly">
            <div>
                <dt>Usuario</dt>
                <dd data-testid="client-profile-username">@Model.Client.UserName</dd>
            </div>
        </dl>
    }

    <form method="post" data-testid="client-profile-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Input.FirstName" class="form-label"></label>
            <input asp-for="Input.FirstName" class="form-control" data-testid="client-profile-first-name" />
            <span asp-validation-for="Input.FirstName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.LastName" class="form-label"></label>
            <input asp-for="Input.LastName" class="form-control" data-testid="client-profile-last-name" />
            <span asp-validation-for="Input.LastName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Email" class="form-label"></label>
            <input asp-for="Input.Email" class="form-control" data-testid="client-profile-email" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button class="btn btn-primary" type="submit" data-testid="client-profile-submit">Actualizar perfil</button>
            <a class="btn btn-outline-secondary" asp-page="/Client/Dashboard">Volver</a>
        </div>
    </form>

    <hr class="section-divider" id="password" />

    <section class="client-password-panel" data-testid="client-profile-password-panel">
        <p class="eyebrow">Seguridad</p>
        <h2>Modificar contrasena</h2>
        <p class="text-muted">Cambia tu contrasena desde tu perfil. No se muestra ni se guarda texto plano.</p>

        <form method="post" asp-page-handler="ChangePassword" data-testid="client-change-password-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="PasswordInput.CurrentPassword" class="form-label"></label>
                <input asp-for="PasswordInput.CurrentPassword" class="form-control" data-testid="client-current-password" />
                <span asp-validation-for="PasswordInput.CurrentPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PasswordInput.NewPassword" class="form-label"></label>
                <input asp-for="PasswordInput.NewPassword" class="form-control" data-testid="client-new-password" />
                <span asp-validation-for="PasswordInput.NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PasswordInput.ConfirmPassword" class="form-label"></label>
                <input asp-for="PasswordInput.ConfirmPassword" class="form-control" data-testid="client-confirm-password" />
                <span asp-validation-for="PasswordInput.ConfirmPassword" class="text-danger"></span>
            </div>

            <button class="btn btn-primary" type="submit" data-testid="client-change-password-submit">Actualizar contrasena</button>
        </form>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
