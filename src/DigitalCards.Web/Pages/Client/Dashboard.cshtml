@page
@model DigitalCards.Web.Pages.Client.DashboardModel
@{
    ViewData["Title"] = "Dashboard cliente";
}

<section class="app-surface client-legacy-hero">
    <div>
        <p class="eyebrow">Cliente</p>
        <h1 data-testid="client-dashboard-title">Mis tarjetas de @Model.ClientName</h1>
        <p class="lead">@Model.ClientName, consulta tus tarjetas de lealtad, revisa tus sellos y vuelve a abrir tus links Wallet.</p>
    </div>

    <div class="action-grid client-action-grid">
        <a class="action-card" asp-page="/Client/Cards" data-testid="client-dashboard-cards-link">
            <span>Mis tarjetas</span>
            <small>Sellos actuales, historicos y estado Wallet.</small>
        </a>
        <a class="action-card" asp-page="/Client/ChangePassword" data-testid="client-dashboard-change-password-link">
            <span>Contrasena</span>
            <small>Actualiza tu acceso al dashboard cliente.</small>
        </a>
        <a class="action-card" asp-page="/Client/Profile" data-testid="client-dashboard-profile-link">
            <span>Perfil</span>
            <small>Edita nombre, apellido y correo.</small>
        </a>
        <a class="action-card" asp-page="/Client/Logout" data-testid="client-logout-link">
            <span>Salir cliente</span>
            <small>Cierra la sesion de cliente.</small>
        </a>
    </div>
</section>

@if (Model.Dashboard is not null)
{
    <section class="result-panel client-dashboard-summary" data-testid="client-dashboard-summary">
        <div class="page-heading">
            <div>
                <p class="eyebrow">Resumen</p>
                <h2>@Model.ClientName</h2>
            </div>
            <span class="badge text-bg-light" data-testid="client-dashboard-card-count">@Model.Dashboard.Cards.Count tarjeta(s)</span>
        </div>

        <div class="client-dashboard-grid">
            <div class="client-identity-panel" data-testid="client-identity-panel">
                <div class="client-qr-card" data-testid="client-qr-card" aria-label="QR real del usuario @Model.Dashboard.Client.UserName">
                    @Html.Raw(Model.ClientQrSvg)
                </div>
                <dl class="client-profile-list" data-testid="client-profile-summary">
                    <div>
                        <dt>Usuario</dt>
                        <dd data-testid="client-profile-username">@Model.Dashboard.Client.UserName</dd>
                    </div>
                    <div>
                        <dt>Correo</dt>
                        <dd data-testid="client-profile-email">@Model.Dashboard.Client.Email</dd>
                    </div>
                </dl>
            </div>

            <div class="client-dashboard-metrics">
                <div class="metric">
                    <span>Sellos actuales</span>
                    <strong data-testid="client-dashboard-current-stamps">@Model.Dashboard.TotalCurrentStamps</strong>
                </div>
                <div class="metric">
                    <span>Sellos historicos</span>
                    <strong data-testid="client-dashboard-lifetime-stamps">@Model.Dashboard.TotalLifetimeStamps</strong>
                </div>
                <div class="metric">
                    <span>Google Wallet</span>
                    <strong data-testid="client-dashboard-google-count">@Model.Dashboard.GoogleIssuedCount</strong>
                </div>
                <div class="metric">
                    <span>Apple Wallet</span>
                    <strong data-testid="client-dashboard-apple-count">@Model.Dashboard.AppleTrackedCount</strong>
                </div>
            </div>
        </div>

        @if (Model.Dashboard.Cards.Count > 0)
        {
            <div class="client-card-preview-grid" data-testid="client-dashboard-card-preview">
                @foreach (var card in Model.Dashboard.Cards.Take(3))
                {
                    <article class="client-card-preview">
                        <div>
                            <span class="client-card-kicker">Tarjeta</span>
                            <h3>@card.BusinessName</h3>
                        </div>
                        <div class="client-stamp-track" aria-label="Sellos actuales">
                            @for (var stamp = 1; stamp <= 10; stamp++)
                            {
                                <span class="@(stamp <= Math.Min(card.CurrentStamps, 10) ? "filled" : string.Empty)"></span>
                            }
                        </div>
                        <p>@card.CurrentStamps sellos actuales &middot; @card.LifetimeStamps historicos</p>
                        <a class="btn btn-outline-primary btn-sm"
                           asp-page="/Wallet/Select"
                           asp-route-token="@card.WalletSelectToken"
                           data-testid="client-dashboard-wallet-link">Abrir Wallet</a>
                    </article>
                }
            </div>
        }
    </section>
}
