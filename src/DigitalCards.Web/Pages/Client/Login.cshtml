@page
@model DigitalCards.Web.Pages.Client.LoginModel
@{
    ViewData["Title"] = "Login cliente";
}

<section class="auth-gateway auth-gateway-client client-auth-panel">
    <div class="auth-copy-panel">
        <h1>Tus tarjetas de lealtad siempre contigo.</h1>
        <p>
            Revisa sellos, abre links Wallet y consulta las tarjetas que tienes con tus negocios favoritos.
        </p>
        <a class="auth-home-link" asp-page="/Index">Volver al inicio</a>
    </div>

    <div class="auth-form-card">
        <div class="p-auth-tabs">
            <span class="p-auth-tab p-auth-tab-active">Cliente</span>
            <a class="p-auth-tab" asp-page="/Business/Login">Negocio</a>
        </div>
        <div class="auth-form-heading">
            <div>
                <h2>Acceso cliente</h2>
                <p>Consulta tus tarjetas y sellos digitales.</p>
            </div>
        </div>

        <form method="post" data-testid="client-login-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Input.UserNameOrEmail" class="form-label"></label>
                <input asp-for="Input.UserNameOrEmail"
                       class="form-control form-control-lg"
                       autocomplete="username"
                       autocapitalize="none"
                       spellcheck="false"
                       data-testid="client-login-username" />
                <span asp-validation-for="Input.UserNameOrEmail" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" class="form-control form-control-lg" data-testid="client-login-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <button class="btn btn-primary btn-lg w-100" type="submit" data-testid="client-login-submit">Entrar a mis tarjetas</button>
            <div class="auth-link-row">
                <a class="auth-forgot-link" asp-page="/Client/ForgotPassword" data-testid="client-forgot-password-link">Olvide mi contrasena</a>
                <a class="auth-forgot-link" asp-page="/Register">Crear cuenta</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
