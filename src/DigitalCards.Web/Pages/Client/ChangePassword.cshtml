@page
@model DigitalCards.Web.Pages.Client.ChangePasswordModel
@{
    ViewData["Title"] = "Cambiar contrasena";
}

<section class="form-panel client-auth-panel">
    <p class="eyebrow">Cliente</p>
    <h1>Cambiar contrasena</h1>
    <p class="lead">Actualiza tu acceso al dashboard cliente.</p>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status" data-testid="client-change-password-status">
            @Model.StatusMessage
        </div>
    }

    <form method="post" data-testid="client-change-password-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Input.CurrentPassword" class="form-label"></label>
            <input asp-for="Input.CurrentPassword" class="form-control" data-testid="client-current-password" />
            <span asp-validation-for="Input.CurrentPassword" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.NewPassword" class="form-label"></label>
            <input asp-for="Input.NewPassword" class="form-control" data-testid="client-new-password" />
            <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.ConfirmPassword" class="form-label"></label>
            <input asp-for="Input.ConfirmPassword" class="form-control" data-testid="client-confirm-password" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button class="btn btn-primary" type="submit" data-testid="client-change-password-submit">Actualizar</button>
            <a class="btn btn-outline-secondary" asp-page="/Client/Dashboard">Volver</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
