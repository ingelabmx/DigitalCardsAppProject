@page "{token}"
@model DigitalCards.Web.Pages.Business.ResetPasswordModel
@{
    ViewData["Title"] = "Restablecer contrasena negocio";
}

<div class="p-auth-simple">
    <h1 class="p-page-heading mb-2">Restablecer contrasena</h1>
    <p class="p-page-sub mb-4">Define una nueva contrasena para volver a entrar con tu cuenta de negocio.</p>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status" data-testid="business-reset-password-status">
            @Model.StatusMessage
        </div>
        <a class="btn btn-primary" asp-page="/Business/Login" data-testid="business-reset-login-link">Entrar al negocio</a>
    }
    else
    {
        <div class="p-card">
            <form method="post" data-testid="business-reset-password-form">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Token" />

                <div class="mb-3">
                    <label asp-for="Input.NewPassword" class="form-label"></label>
                    <input asp-for="Input.NewPassword" class="form-control" data-testid="business-reset-new-password" />
                    <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                    <input asp-for="Input.ConfirmPassword" class="form-control" data-testid="business-reset-confirm-password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button class="btn btn-primary" type="submit" data-testid="business-reset-submit">Actualizar contrasena</button>
            </form>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
