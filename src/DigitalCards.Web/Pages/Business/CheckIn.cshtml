@page
@model DigitalCards.Web.Pages.Business.CheckInModel
@{
    ViewData["Title"] = "Modo mostrador";
}

<section class="result-panel business-checkin-panel" data-testid="business-checkin-panel">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Mostrador</p>
            <h1>Check-in cliente</h1>
            <p class="lead">Escanea el QR del cliente o captura username/correo para validar la tarjeta y agregar sello.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-page="/Business/Dashboard" data-testid="business-checkin-back-link">Dashboard</a>
    </div>

    @if (Model.IsPilotBlocked)
    {
        <div class="alert alert-warning" role="status" data-testid="pilot-business-blocked">
            @Model.PilotBlockMessage
        </div>
    }
    else
    {
        <form method="post" asp-page-handler="Lookup" class="business-checkin-search" data-testid="business-card-search-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <label asp-for="Query" class="form-label"></label>
            <div class="input-group input-group-lg">
                <input asp-for="Query" class="form-control" placeholder="Escanea o captura username/correo" data-testid="business-card-search-input" autofocus />
                <button class="btn btn-primary" type="submit" data-testid="business-checkin-lookup-submit">Buscar</button>
            </div>
            <span asp-validation-for="Query" class="text-danger"></span>
        </form>

        <div class="business-checkin-guide" data-testid="business-checkin-guide">
            <span>1. Escanea QR</span>
            <span>2. Confirma tarjeta</span>
            <span>3. Agrega sello</span>
        </div>

        <div class="qr-scanner-panel business-checkin-scanner" data-business-qr-scanner data-testid="business-checkin-qr-scanner">
            <div>
                <strong>Lector QR</strong>
                <span data-qr-status>Listo</span>
            </div>
            <div class="qr-scanner-actions">
                <button class="btn btn-outline-primary btn-sm" type="button" data-qr-start data-testid="business-checkin-qr-start">Escanear</button>
                <button class="btn btn-outline-secondary btn-sm" type="button" data-qr-stop data-testid="business-checkin-qr-stop">Detener</button>
            </div>
            <video class="qr-scanner-video" autoplay muted playsinline data-qr-video aria-label="Vista de camara QR"></video>
        </div>
    }
</section>

@if (!Model.IsPilotBlocked)
{
    <section class="result-panel mt-3" data-testid="business-checkin-results">
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="alert @(Model.SelectedCard is null ? "alert-warning" : "alert-success")" role="status" data-testid="business-checkin-status">
                @Model.StatusMessage
            </div>
        }

        @if (Model.Results.Count > 1)
        {
            <h2>Selecciona tarjeta</h2>
            <div class="list-group">
                @foreach (var card in Model.Results)
                {
                    <div class="list-group-item business-checkin-result" data-testid="business-checkin-result">
                        <div>
                            <strong>@card.Client.UserName</strong>
                            <span>@card.Client.Email</span>
                        </div>
                        <form method="post" asp-page-handler="Stamp" asp-route-cardId="@card.Id">
                            <input type="hidden" asp-for="Query" value="@Model.Query" />
                            <button class="btn btn-primary" type="submit" data-testid="business-checkin-stamp-submit">Agregar sello</button>
                        </form>
                    </div>
                }
            </div>
        }
        else if (Model.SelectedCard is not null)
        {
            <article class="business-checkin-card" data-testid="business-checkin-card">
                <div>
                    <p class="eyebrow">Tarjeta validada</p>
                    <h2>@Model.SelectedCard.Client.UserName</h2>
                    <p>@Model.SelectedCard.Client.FirstName @Model.SelectedCard.Client.LastName &middot; @Model.SelectedCard.Client.Email</p>
                </div>
                <div class="metric-row">
                    <div class="metric">
                        <span>Sellos actuales</span>
                        <strong data-testid="business-checkin-current-stamps">@Model.SelectedCard.CurrentStamps</strong>
                    </div>
                    <div class="metric">
                        <span>Sellos historicos</span>
                        <strong data-testid="business-checkin-lifetime-stamps">@Model.SelectedCard.LifetimeStamps</strong>
                    </div>
                    <div class="metric">
                        <span>Google</span>
                        <strong data-testid="business-checkin-google-status">@(Model.SelectedCard.GoogleIssued ? "Emitida" : "Pendiente")</strong>
                    </div>
                    <div class="metric">
                        <span>Apple</span>
                        <strong data-testid="business-checkin-apple-status">@(Model.SelectedCard.AppleTracked ? "Activa" : "Pendiente")</strong>
                    </div>
                </div>
                <form method="post" asp-page-handler="Stamp" asp-route-cardId="@Model.SelectedCard.Id" class="business-checkin-stamp-form">
                    <input type="hidden" asp-for="Query" value="@Model.Query" />
                    <button class="btn btn-primary btn-lg" type="submit" data-testid="business-checkin-stamp-submit">Agregar sello</button>
                </form>
            </article>
        }
    </section>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/business-cards.js" asp-append-version="true"></script>
}
