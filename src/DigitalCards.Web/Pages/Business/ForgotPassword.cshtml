@page
@model DigitalCards.Web.Pages.Business.ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperar contrasena negocio";
}

<section class="form-panel">
    <h1>Recuperar contrasena negocio</h1>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status" data-testid="business-forgot-password-status">
            @Model.StatusMessage
        </div>
    }

    <form method="post" data-testid="business-forgot-password-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Input.Email" class="form-label"></label>
            <input asp-for="Input.Email" class="form-control" data-testid="business-forgot-email" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <button class="btn btn-primary" type="submit" data-testid="business-forgot-submit">Enviar link</button>
        <a class="btn btn-link" asp-page="/Business/Login">Volver al login</a>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
