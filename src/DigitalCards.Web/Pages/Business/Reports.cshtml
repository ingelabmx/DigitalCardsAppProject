@page
@using System.Globalization
@model DigitalCards.Web.Pages.Business.ReportsModel
@{
    ViewData["Title"] = "Reportes negocio";
    var maxStampPeriod = Model.Reports is { StampPeriods.Count: > 0 }
        ? Math.Max(1, Model.Reports.StampPeriods.Max(period => Math.Max(period.StampCount, period.RedemptionCount)))
        : 1;
    var maxClientPeriod = Model.Reports is { NewClientPeriods.Count: > 0 }
        ? Math.Max(1, Model.Reports.NewClientPeriods.Max(period => period.NewClientCount))
        : 1;
}

<section class="result-panel business-reports" data-testid="business-reports">
    <div class="page-heading">
        <div>
            <h1>Reportes</h1>
            <p class="lead">Resumen operativo de tarjetas, sellos, canjes y clientes del negocio autenticado.</p>
        </div>
    </div>

    @if (Model.IsPilotBlocked)
    {
        <div class="alert alert-warning" role="status" data-testid="pilot-business-blocked">
            @Model.PilotBlockMessage
        </div>
    }
    else if (Model.Reports is null)
    {
        <p class="text-muted">No hay datos disponibles.</p>
    }
    else
    {
        <div class="metric-row business-report-metrics business-report-metrics-four">
            <div class="metric">
                <span>Tarjetas</span>
                <strong data-testid="business-report-card-count">@Model.Reports.CardCount</strong>
                <small>@Model.Reports.CardsCreatedLast30Days en 30 dias</small>
            </div>
            <div class="metric">
                <span>Clientes</span>
                <strong data-testid="business-report-client-count">@Model.Reports.ClientCount</strong>
                <small>@Model.Reports.NewClientPeriods.Sum(period => period.NewClientCount) nuevos en 6 meses</small>
            </div>
            <div class="metric">
                <span>Sellos vs canjes</span>
                <strong>@Model.Reports.StampsLast30Days / @Model.Reports.RedemptionsLast30Days</strong>
                <small>ultimos 30 dias</small>
            </div>
            <div class="metric">
                <span>Tasa de redencion</span>
                <strong>@Model.Reports.RedemptionRate.ToString("0.0")%</strong>
                <small>canjes sobre sellos</small>
            </div>
        </div>

        <div class="business-dashboard-grid">
            <section class="business-dashboard-panel">
                <h2>Sellos por mes</h2>
                @if (Model.Reports.StampPeriods.Count == 0)
                {
                    <p class="text-muted" data-testid="business-report-no-periods">No hay eventos recientes de sellos.</p>
                }
                else
                {
                    <div class="report-line-chart" data-testid="business-report-periods">
                        <svg viewBox="0 0 100 60" preserveAspectRatio="none" role="img" aria-label="Sellos y canjes por mes">
                            <defs>
                                <linearGradient id="grad-primary" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%" stop-color="#0f766e" stop-opacity="0.22" />
                                    <stop offset="100%" stop-color="#0f766e" stop-opacity="0" />
                                </linearGradient>
                                <linearGradient id="grad-accent" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%" stop-color="#d97706" stop-opacity="0.18" />
                                    <stop offset="100%" stop-color="#d97706" stop-opacity="0" />
                                </linearGradient>
                            </defs>
                            <polygon class="report-area report-area-primary"
                                     points="@AreaPoints(Model.Reports.StampPeriods.Select(period => period.StampCount), maxStampPeriod)"
                                     fill="url(#grad-primary)" />
                            <polygon class="report-area report-area-accent"
                                     points="@AreaPoints(Model.Reports.StampPeriods.Select(period => period.RedemptionCount), maxStampPeriod)"
                                     fill="url(#grad-accent)" />
                            <polyline class="report-line report-line-primary"
                                      points="@LinePoints(Model.Reports.StampPeriods.Select(period => period.StampCount), maxStampPeriod)" />
                            <polyline class="report-line report-line-accent"
                                      points="@LinePoints(Model.Reports.StampPeriods.Select(period => period.RedemptionCount), maxStampPeriod)" />
                            @foreach (var point in ChartPoints(Model.Reports.StampPeriods.Select(period => period.StampCount), maxStampPeriod))
                            {
                                <circle class="report-point report-point-primary" cx="@point.X" cy="@point.Y" r="1.8" />
                            }
                            @foreach (var point in ChartPoints(Model.Reports.StampPeriods.Select(period => period.RedemptionCount), maxStampPeriod))
                            {
                                <circle class="report-point report-point-accent" cx="@point.X" cy="@point.Y" r="1.8" />
                            }
                        </svg>
                        <div class="report-line-labels">
                        @foreach (var period in Model.Reports.StampPeriods)
                        {
                            <div data-testid="business-report-period">
                                <strong>@period.Period</strong>
                                <small>@period.StampCount sellos · @period.RedemptionCount canjes</small>
                            </div>
                        }
                        </div>
                        <div class="report-chart-legend">
                            <span><i class="report-legend-primary"></i>Sellos</span>
                            <span><i class="report-legend-accent"></i>Canjes</span>
                        </div>
                    </div>
                }
            </section>

            <section class="business-dashboard-panel">
                <h2>Nuevos clientes por mes</h2>
                @if (Model.Reports.NewClientPeriods.Count == 0)
                {
                    <p class="text-muted">No hay altas recientes.</p>
                }
                else
                {
                    <div class="report-line-chart report-line-chart-compact" data-testid="business-report-new-clients">
                        <svg viewBox="0 0 100 60" preserveAspectRatio="none" role="img" aria-label="Nuevos clientes por mes">
                            <defs>
                                <linearGradient id="grad-secondary" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%" stop-color="#1d4ed8" stop-opacity="0.2" />
                                    <stop offset="100%" stop-color="#1d4ed8" stop-opacity="0" />
                                </linearGradient>
                            </defs>
                            <polygon class="report-area report-area-secondary"
                                     points="@AreaPoints(Model.Reports.NewClientPeriods.Select(period => period.NewClientCount), maxClientPeriod)"
                                     fill="url(#grad-secondary)" />
                            <polyline class="report-line report-line-secondary"
                                      points="@LinePoints(Model.Reports.NewClientPeriods.Select(period => period.NewClientCount), maxClientPeriod)" />
                            @foreach (var point in ChartPoints(Model.Reports.NewClientPeriods.Select(period => period.NewClientCount), maxClientPeriod))
                            {
                                <circle class="report-point report-point-secondary" cx="@point.X" cy="@point.Y" r="1.8" />
                            }
                        </svg>
                        <div class="report-line-labels">
                        @foreach (var period in Model.Reports.NewClientPeriods)
                        {
                            <div data-testid="business-report-new-client-period">
                                <strong>@period.Period</strong>
                                <small>@period.NewClientCount cliente(s)</small>
                            </div>
                        }
                        </div>
                    </div>
                }
            </section>
        </div>

        <div class="business-dashboard-grid">
            <section class="business-dashboard-panel">
                <h2>Top clientes por uso</h2>
                @if (Model.Reports.TopClients.Count == 0)
                {
                    <p class="text-muted">No hay clientes suficientes para generar ranking.</p>
                }
                else
                {
                    <div class="dashboard-card-list" data-testid="business-report-top-clients">
                        @foreach (var client in Model.Reports.TopClients)
                        {
                            <a class="dashboard-card-row"
                               asp-page="/Business/Cards"
                               asp-route-query="@client.UserName"
                               data-testid="business-report-top-client">
                                <div>
                                    <strong>@client.ClientName</strong>
                                    <span>@client.UserName</span>
                                </div>
                                <div>
                                    <strong>@client.LifetimeStamps</strong>
                                    <span>sellos historicos</span>
                                </div>
                                <div>
                                    <strong>@client.RedemptionCount</strong>
                                    <span>canjes</span>
                                </div>
                            </a>
                        }
                    </div>
                }
            </section>

            <section class="business-dashboard-panel">
                <h2>Resumen comercial</h2>
                <div class="dashboard-card-list" data-testid="business-report-summary-cards">
                    <div class="dashboard-card-row compact">
                        <div>
                            <strong>@Model.Reports.NewClientPeriods.Sum(period => period.NewClientCount)</strong>
                            <span>nuevos clientes en 6 meses</span>
                        </div>
                        <div>
                            <strong>@Model.Reports.StampsLast30Days</strong>
                            <span>sellos generados en 30 dias</span>
                        </div>
                    </div>
                    <div class="dashboard-card-row compact">
                        <div>
                            <strong>@Model.Reports.RedemptionsLast30Days</strong>
                            <span>canjes en 30 dias</span>
                        </div>
                        <div>
                            <strong>@Model.Reports.CurrentStampTotal</strong>
                            <span>sellos activos acumulados</span>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <section class="business-dashboard-panel business-report-client-breakdown">
            <h2>Clientes del negocio</h2>
            @if (Model.Reports.RecentClients.Count == 0)
            {
                <p class="text-muted" data-testid="business-report-no-client-breakdown">No hay clientes asociados a este negocio.</p>
            }
            else
            {
                <div class="table-responsive" data-testid="business-report-client-breakdown">
                    <table class="table align-middle legacy-table">
                        <thead>
                            <tr>
                                <th>Cliente</th>
                                <th>Usuario</th>
                                <th>Correo</th>
                                <th>Tarjetas</th>
                                <th>Sellos actuales</th>
                                <th>Sellos historicos</th>
                                <th>Estado</th>
                                <th>Ultima actividad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var client in Model.Reports.RecentClients)
                            {
                                <tr data-testid="business-report-client-breakdown-row">
                                    <td>@client.ClientName</td>
                                    <td>@client.UserName</td>
                                    <td>@client.Email</td>
                                    <td>@client.CardCount</td>
                                    <td>@client.CurrentStamps</td>
                                    <td>@client.LifetimeStamps</td>
                                    <td><span class="status-pill">@client.CardStatus</span></td>
                                    <td>@client.LastActivityAt.ToLocalTime().ToString("g")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }
</section>

@functions {
    private static string LinePoints(IEnumerable<int> values, int maxValue)
    {
        return string.Join(" ", ChartPoints(values, maxValue).Select(point =>
            $"{point.X},{point.Y}"));
    }

    private static string AreaPoints(IEnumerable<int> values, int maxValue)
    {
        var points = ChartPoints(values, maxValue);
        if (points.Count == 0) return string.Empty;
        var line = string.Join(" ", points.Select(p => $"{p.X},{p.Y}"));
        return $"{line} {points[^1].X},58 {points[0].X},58";
    }

    private static IReadOnlyList<ChartPoint> ChartPoints(IEnumerable<int> values, int maxValue)
    {
        var items = values.ToArray();
        if (items.Length == 0)
        {
            return [];
        }

        var divisor = Math.Max(1, items.Length - 1);
        var safeMax = Math.Max(1, maxValue);
        return items
            .Select((value, index) => new ChartPoint(
                X: (index * 100d / divisor).ToString("0.##", CultureInfo.InvariantCulture),
                Y: (56d - (Math.Max(0, value) * 50d / safeMax)).ToString("0.##", CultureInfo.InvariantCulture)))
            .ToArray();
    }

    private sealed record ChartPoint(string X, string Y);
}
