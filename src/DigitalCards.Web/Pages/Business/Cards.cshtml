@page
@using DigitalCards.Application.Models
@model DigitalCards.Web.Pages.Business.CardsModel
@{
    ViewData["Title"] = "Tarjetas de negocio";
}

<section class="result-panel business-cards business-primary-workflow" data-testid="business-primary-workflow">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Operacion</p>
            <h1>Tarjetas de clientes</h1>
            <p class="lead">Busca una tarjeta, reenvia el link Wallet y aplica sellos desde el detalle validado del negocio.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-page="/Business/Dashboard" data-testid="cards-back-link">Dashboard</a>
    </div>

    @if (Model.IsPilotBlocked)
    {
        <div class="alert alert-warning" role="status" data-testid="pilot-business-blocked">
            @Model.PilotBlockMessage
        </div>
    }
    else
    {
        <div class="business-card-toolbar">
            <form method="get" class="search-row business-card-search-row" data-testid="business-card-search-form">
                <label asp-for="Query" class="form-label visually-hidden"></label>
                <input asp-for="Query" class="form-control" placeholder="username, correo o QR" data-testid="business-card-search-input" />
                <button class="btn btn-primary" type="submit" data-testid="business-card-search-submit">Buscar</button>
            </form>

            <div class="qr-scanner-panel" data-business-qr-scanner data-testid="business-qr-scanner">
                <div>
                    <strong>Lector QR</strong>
                    <span data-qr-status>Listo</span>
                </div>
                <div class="qr-scanner-actions">
                    <button class="btn btn-outline-primary btn-sm" type="button" data-qr-start data-testid="business-qr-start">Escanear</button>
                    <button class="btn btn-outline-secondary btn-sm" type="button" data-qr-stop data-testid="business-qr-stop">Detener</button>
                </div>
                <video class="qr-scanner-video" autoplay muted playsinline data-qr-video aria-label="Vista de camara QR"></video>
            </div>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        @if (Model.StatusMessage is not null)
        {
            <div class="alert alert-success" role="status" data-testid="business-card-status">
                @Model.StatusMessage
                @if (Model.ResentEnrollmentUrl is not null)
                {
                    <a href="@Model.ResentEnrollmentUrl" data-testid="resent-enrollment-link">Abrir link</a>
                }
            </div>
        }

        <div class="business-card-grid">
            <div class="business-card-list">
                <h2>Resultados</h2>

                @if (string.IsNullOrWhiteSpace(Model.Query))
                {
                    <div class="dashboard-empty-state compact" data-testid="business-card-empty-search">
                        <p class="eyebrow">Busca una tarjeta</p>
                        <h3>Escanea QR o captura usuario/correo</h3>
                        <p>Cuando selecciones una tarjeta, aqui apareceran acciones para reenviar Wallet y agregar sello.</p>
                    </div>
                }
                else if (Model.Results.Count == 0)
                {
                    <div class="dashboard-empty-state compact" data-testid="business-card-no-results">
                        <p class="eyebrow">Sin resultados</p>
                        <h3>No hay tarjeta asociada</h3>
                        <p>No se encontraron tarjetas para este negocio. Asocia el cliente para enviar su link Wallet.</p>
                        <a class="btn btn-primary btn-sm" asp-page="/Business/Enroll">Asociar cliente</a>
                    </div>
                }
                else
                {
                    <div class="list-group" data-testid="business-card-results">
                        @foreach (var card in Model.Results)
                        {
                            <a class="list-group-item list-group-item-action business-card-result-row"
                               asp-page="/Business/Cards"
                               asp-route-query="@Model.Query"
                               asp-route-cardId="@card.Id"
                               data-testid="business-card-result">
                                <div>
                                    <strong>@FullClientName(card.Client)</strong>
                                    <small>@card.Client.Email</small>
                                </div>
                                <div class="business-card-result-state">
                                    <span>@VisibleStamps(card.CurrentStamps, card.StampGoal) de @NormalizedStampGoal(card.StampGoal) sellos</span>
                                    <span class="@(IsCardReady(card) ? "wallet-status-ok" : "wallet-status-pending")">
                                        @(IsCardReady(card) ? "Tarjeta lista" : "Tarjeta pendiente")
                                    </span>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>

            <div class="business-card-detail" data-testid="business-card-detail">
                @if (Model.Detail is null)
                {
                    <h2>Detalle</h2>
                    <div class="dashboard-empty-state compact business-card-detail-empty-panel" data-testid="business-card-detail-empty">
                        <p class="eyebrow">Selecciona una tarjeta</p>
                        <h3>Opera desde el detalle validado</h3>
                        <p>El detalle muestra sellos, estado Wallet, auditoria y acciones seguras del negocio autenticado.</p>
                    </div>
                }
                else
                {
                    var stampGoal = NormalizedStampGoal(Model.Detail.StampGoal);
                    var visibleStamps = VisibleStamps(Model.Detail.CurrentStamps, stampGoal);
                    var stampsToGoal = Math.Max(0, stampGoal - visibleStamps);

                    <div class="detail-heading">
                        <div>
                            <h2>@Model.Detail.Client.UserName</h2>
                            <p>@Model.Detail.Client.FirstName @Model.Detail.Client.LastName · @Model.Detail.Client.Email</p>
                        </div>
                        <span class="badge text-bg-light">@Model.Detail.BusinessName</span>
                    </div>

                    <div class="business-card-action-strip" data-testid="business-card-action-strip">
                        <div>
                            <span>Estado de tarjeta</span>
                            <strong>
                                @(Model.Detail.IsActive
                                    ? stampsToGoal == 0
                                        ? "Activa · Recompensa lista o nuevo ciclo"
                                        : $"Activa · Faltan {stampsToGoal} sello(s)"
                                    : "Inactiva")
                            </strong>
                        </div>
                        <div class="business-card-action-buttons">
                            <form method="post" asp-page-handler="Resend" asp-route-cardId="@Model.Detail.Id" asp-route-query="@Model.Query">
                                <button class="btn btn-outline-primary" type="submit" data-testid="business-card-resend-submit" disabled="@(!Model.Detail.IsActive)">
                                    Reenviar Wallet
                                </button>
                            </form>
                            <form method="post" asp-page-handler="Stamp" asp-route-cardId="@Model.Detail.Id" asp-route-query="@Model.Query">
                                <button class="btn btn-primary" type="submit" data-testid="business-card-stamp-submit" disabled="@(!Model.Detail.IsActive)">
                                    Agregar sello
                                </button>
                            </form>
                        </div>
                    </div>

                    <div class="business-detail-card-face" data-testid="business-detail-card-face">
                        <div>
                            <span>Tarjeta digital</span>
                            <strong>@Model.Detail.BusinessName</strong>
                            <small>@Model.Detail.Client.UserName</small>
                        </div>
                        <div class="business-stamp-track" aria-label="Sellos actuales">
                            @for (var stamp = 1; stamp <= stampGoal; stamp++)
                            {
                                <span class="@(stamp <= visibleStamps ? "filled" : null)"></span>
                            }
                        </div>
                    </div>

                    <div class="metric-row metric-row-wide">
                        <div class="metric">
                            <span>Sellos actuales</span>
                            <strong data-testid="business-card-current-stamps">@visibleStamps de @stampGoal</strong>
                        </div>
                        <div class="metric">
                            <span>Sellos historicos</span>
                            <strong data-testid="business-card-lifetime-stamps">@Model.Detail.LifetimeStamps</strong>
                        </div>
                        <div class="metric">
                            <span>Tarjeta</span>
                            <strong data-testid="business-card-wallet-status">@(IsCardReady(Model.Detail) ? "Lista" : "Pendiente")</strong>
                        </div>
                        <div class="metric">
                            <span>Ultimo update</span>
                            <strong data-testid="business-card-last-update">@Model.Detail.LastStampedAt.ToLocalTime().ToString("g")</strong>
                        </div>
                    </div>

                    <div class="business-wallet-status-row" data-testid="business-wallet-status-row">
                        <span class="@(IsCardReady(Model.Detail) ? "wallet-status-ok" : "wallet-status-pending")">
                            @(IsCardReady(Model.Detail) ? "Tarjeta lista" : "Tarjeta pendiente")
                        </span>
                    </div>

                    <div class="stamp-ledger" data-testid="stamp-ledger-list">
                        <h3>Auditoria de sellos</h3>
                        @if (Model.Detail.RecentStampEvents.Count == 0)
                        {
                            <p class="text-muted" data-testid="stamp-ledger-empty">Aun no hay eventos registrados para esta tarjeta.</p>
                        }
                        else
                        {
                            <div class="stamp-ledger-items">
                                @foreach (var item in Model.Detail.RecentStampEvents)
                                {
                                    <div class="stamp-ledger-item" data-testid="stamp-ledger-event">
                                        <div>
                                            <strong>@CardStatus(item.GoogleWalletAttempted, item.GoogleWalletSucceeded, item.AppleWalletAttempted, item.AppleWalletSucceeded)</strong>
                                            <span>@item.CreatedAt.ToLocalTime().ToString("g")</span>
                                        </div>
                                        <p>
                                            Sellos actuales @item.NewCheckQTY
                                            &middot; Historicos @item.NewHistoricCheckQTY
                                        </p>
                                        @if (!string.IsNullOrWhiteSpace(item.ErrorSummary))
                                        {
                                            <p class="text-danger">Error: @item.ErrorSummary</p>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="business-management-note" id="business-card-management-panel" data-testid="business-card-management-panel">
                        <strong>Administracion de tarjeta</strong>
                        <p>Desactivar pausa la operacion de esta tarjeta. Eliminar borra permanentemente la relacion del cliente con este negocio, sin borrar su cuenta global.</p>
                        <div class="business-card-action-buttons">
                            @if (Model.Detail.IsActive)
                            {
                                <form method="post" asp-page-handler="Deactivate" asp-route-cardId="@Model.Detail.Id" asp-route-query="@Model.Query">
                                    <button class="btn btn-outline-warning" type="submit" data-testid="business-card-deactivate-submit">
                                        Desactivar cliente
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="Reactivate" asp-route-cardId="@Model.Detail.Id" asp-route-query="@Model.Query">
                                    <button class="btn btn-outline-success" type="submit" data-testid="business-card-reactivate-submit">
                                        Reactivar cliente
                                    </button>
                                </form>
                            }
                        </div>
                        <form method="post" asp-page-handler="Delete" asp-route-cardId="@Model.Detail.Id" asp-route-query="@Model.Query" class="business-card-delete-form danger-action-panel danger-zone-card">
                            <div>
                                <strong>Eliminar permanentemente</strong>
                                <p>Esta accion elimina la tarjeta, sus links Wallet y sus datos asociados para este negocio. Escribe <b>@Model.Detail.Client.UserName</b> para confirmar.</p>
                            </div>
                            <div class="danger-action-controls">
                                <input class="form-control form-control-sm"
                                       name="confirmation"
                                       placeholder="Escribe @Model.Detail.Client.UserName"
                                       data-testid="business-card-delete-confirmation" />
                                <button class="btn btn-outline-danger" type="submit" data-testid="business-card-delete-submit">
                                    Eliminar
                                </button>
                            </div>
                        </form>
                    </div>
                }
            </div>
        </div>
    }
</section>

@functions {
    private static string FullClientName(ClientDto client)
    {
        var fullName = $"{client.FirstName} {client.LastName}".Trim();
        return string.IsNullOrWhiteSpace(fullName) ? client.UserName : fullName;
    }

    private static bool IsCardReady(BusinessCardDto card)
    {
        return card.GoogleIssued || card.AppleTracked;
    }

    private static int NormalizedStampGoal(int stampGoal)
    {
        return Math.Max(1, stampGoal);
    }

    private static int VisibleStamps(int currentStamps, int stampGoal)
    {
        return Math.Min(Math.Max(currentStamps, 0), NormalizedStampGoal(stampGoal));
    }

    private static string CardStatus(
        bool googleAttempted,
        bool googleSucceeded,
        bool appleAttempted,
        bool appleSucceeded)
    {
        if ((googleAttempted && !googleSucceeded) || (appleAttempted && !appleSucceeded))
        {
            return "Con alerta";
        }

        return "Actualizado";
    }
}

@section Scripts {
    <script src="~/js/business-cards.js" asp-append-version="true"></script>
}
