@page
@using DigitalCards.Application.Models
@model DigitalCards.Web.Pages.Business.CardsModel
@{
    ViewData["Title"] = "Tarjetas de negocio";
}

<section class="result-panel business-cards business-primary-workflow" data-testid="business-primary-workflow">
    <div class="page-heading">
        <div>
            <h1>Tarjetas de clientes</h1>
            <p class="lead">Consulta las tarjetas del negocio, abre su detalle y opera sellos, wallet y estado desde un solo panel.</p>
        </div>
    </div>

    @if (Model.IsPilotBlocked)
    {
        <div class="alert alert-warning" role="status" data-testid="pilot-business-blocked">
            @Model.PilotBlockMessage
        </div>
    }
    else
    {
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        @if (Model.StatusMessage is not null)
        {
            <div class="alert alert-success" role="status" data-testid="business-card-status">
                @Model.StatusMessage
                @if (Model.ResentEnrollmentUrl is not null)
                {
                    <a href="@Model.ResentEnrollmentUrl" data-testid="resent-enrollment-link">Abrir link</a>
                }
            </div>
        }

        <div class="admin-filter-card business-card-table-toolbar">
            <form method="get" class="business-table-controls" data-testid="business-card-table-controls">
                <input type="hidden" asp-for="CardId" />
                <div class="business-table-control-group grow">
                    <label asp-for="Query" class="form-label visually-hidden"></label>
                    <input asp-for="Query" class="form-control" placeholder="usuario o correo del cliente" data-testid="business-card-search-input" />
                </div>
                <div>
                    <span class="table-counter-label">Tarjetas del negocio</span>
                    <strong data-testid="business-card-total-count">@Model.TotalCards registro(s)</strong>
                </div>
                <div class="business-table-control-group">
                    <label asp-for="PageSize" class="form-label mb-0">Mostrar</label>
                    <select asp-for="PageSize" class="form-select form-select-sm" onchange="this.form.submit()" data-testid="business-card-page-size">
                        <option value="10">10</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                    </select>
                </div>
                <button class="btn btn-primary" type="submit" data-testid="business-card-search-submit">Buscar</button>
            </form>
        </div>

        @if (Model.PagedCards.Count == 0)
        {
            <div class="dashboard-empty-state compact business-card-detail-empty-panel" data-testid="business-card-no-results">
                <h3>No hay clientes asociados</h3>
                <p>Asocia un cliente para comenzar a operar tarjetas desde este panel.</p>
                <a class="btn btn-primary btn-sm" asp-page="/Business/Enroll">Asociar cliente</a>
            </div>
        }
        else
        {
            <div class="table-responsive business-table-shell" data-testid="business-card-table">
                <table class="table align-middle legacy-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Usuario</th>
                            <th>Sellos</th>
                            <th>Alta</th>
                            <th>Ultima actividad</th>
                            <th>Estado</th>
                            <th class="text-end">Administrar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var card in Model.PagedCards)
                        {
                            <tr data-testid="business-card-row">
                                <td>@card.Client.FirstName @card.Client.LastName</td>
                                <td>@card.Client.UserName</td>
                                <td>@card.VisibleStamps de @card.StampGoal</td>
                                <td>@card.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td>@card.LastStampedAt.ToLocalTime().ToString("g")</td>
                                <td><span class="status-pill">@(card.IsActive ? "Activa" : "Inactiva")</span></td>
                                <td class="text-end">
                                    <a class="btn btn-outline-primary btn-sm"
                                       asp-page="/Business/Cards"
                                       asp-route-cardId="@card.Id"
                                       asp-route-query="@Model.Query"
                                       asp-route-pageNumber="@Model.PageNumber"
                                       asp-route-pageSize="@Model.PageSize"
                                       data-testid="business-card-manage-link">
                                        Administrar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="table-pager" data-testid="business-card-pager">
                <span>Pagina @Model.PageNumber de @Model.TotalPages</span>
                <div class="table-pager-actions">
                    <a class="btn btn-outline-secondary btn-sm @(Model.PageNumber <= 1 ? "disabled" : null)"
                       asp-page="/Business/Cards"
                       asp-route-query="@Model.Query"
                       asp-route-pageNumber="@(Model.PageNumber - 1)"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-cardId="@Model.CardId"
                       data-testid="business-card-page-prev">
                        Anterior
                    </a>
                    <a class="btn btn-outline-secondary btn-sm @(Model.PageNumber >= Model.TotalPages ? "disabled" : null)"
                       asp-page="/Business/Cards"
                       asp-route-query="@Model.Query"
                       asp-route-pageNumber="@(Model.PageNumber + 1)"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-cardId="@Model.CardId"
                       data-testid="business-card-page-next">
                        Siguiente
                    </a>
                </div>
            </div>
        }

        <div class="business-card-grid business-card-direct-grid">
            <div class="business-card-detail business-card-detail-wide" data-testid="business-card-detail">
                @if (Model.Detail is null)
                {
                    <h2>Detalle</h2>
                    <div class="dashboard-empty-state compact business-card-detail-empty-panel" data-testid="business-card-detail-empty">
                        <h3>@(string.IsNullOrWhiteSpace(Model.Query) ? "Selecciona una tarjeta" : "Usuario no encontrado")</h3>
                        <p>@(string.IsNullOrWhiteSpace(Model.Query)
                            ? "El detalle mostrara sellos, estado Wallet y acciones del negocio cuando abras un registro."
                            : "No se encontro una tarjeta para esa busqueda. Ajusta el usuario o correo, o asocia un cliente nuevo.")</p>
                    </div>
                }
                else
                {
                    <div class="detail-heading">
                        <div>
                            <h2>@Model.Detail.Client.UserName</h2>
                            <p>@Model.Detail.Client.FirstName @Model.Detail.Client.LastName · @Model.Detail.Client.Email</p>
                        </div>
                        <span class="badge text-bg-light">@Model.Detail.BusinessName</span>
                    </div>

                    <div class="business-card-action-strip" data-testid="business-card-action-strip">
                        <div>
                            <span>Estado de tarjeta</span>
                            <strong>
                                @(Model.Detail.IsActive
                                    ? Model.Detail.RewardReady
                                        ? "Activa - Recompensa lista"
                                        : $"Activa - Faltan {Model.Detail.StampsRemaining} sello(s)"
                                    : "Inactiva")
                            </strong>
                        </div>
                        <div class="business-card-action-buttons">
                            <form method="post"
                                  asp-page-handler="Resend"
                                  asp-route-cardId="@Model.Detail.Id"
                                  asp-route-query="@Model.Query"
                                  asp-route-pageNumber="@Model.PageNumber"
                                  asp-route-pageSize="@Model.PageSize">
                                <button class="btn btn-outline-primary" type="submit" data-testid="business-card-resend-submit" disabled="@(!Model.Detail.IsActive)">
                                    Reenviar Wallet
                                </button>
                            </form>
                            @if (Model.Detail.RewardReady)
                            {
                                <form method="post"
                                      asp-page-handler="Redeem"
                                      asp-route-cardId="@Model.Detail.Id"
                                      asp-route-query="@Model.Query"
                                      asp-route-pageNumber="@Model.PageNumber"
                                      asp-route-pageSize="@Model.PageSize">
                                    <button class="btn btn-success" type="submit" data-testid="business-card-redeem-submit" disabled="@(!Model.Detail.IsActive)" onclick="return confirm('Confirmar canje de recompensa para esta tarjeta?');">
                                        Canjear recompensa
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form method="post"
                                      asp-page-handler="Stamp"
                                      asp-route-cardId="@Model.Detail.Id"
                                      asp-route-query="@Model.Query"
                                      asp-route-pageNumber="@Model.PageNumber"
                                      asp-route-pageSize="@Model.PageSize">
                                    <button class="btn btn-primary" type="submit" data-testid="business-card-stamp-submit" disabled="@(!Model.Detail.IsActive)">
                                        Agregar sello
                                    </button>
                                </form>
                            }
                        </div>
                    </div>

                    <div class="business-detail-card-face" data-testid="business-detail-card-face">
                        <div>
                            <span>Tarjeta digital</span>
                            <strong>@Model.Detail.BusinessName</strong>
                            <small>@Model.Detail.Client.UserName</small>
                        </div>
                        <div class="business-stamp-track" aria-label="Sellos actuales">
                            @for (var stamp = 1; stamp <= Model.Detail.StampGoal; stamp++)
                            {
                                <span class="@(stamp <= Model.Detail.VisibleStamps ? "filled" : null)"></span>
                            }
                        </div>
                    </div>

                    <div class="metric-row metric-row-wide">
                        <div class="metric">
                            <span>Sellos actuales</span>
                            <strong data-testid="business-card-current-stamps">@Model.Detail.VisibleStamps de @Model.Detail.StampGoal</strong>
                        </div>
                        <div class="metric">
                            <span>Sellos historicos</span>
                            <strong data-testid="business-card-lifetime-stamps">@Model.Detail.LifetimeStamps</strong>
                        </div>
                        <div class="metric">
                            <span>Tarjeta</span>
                            <strong data-testid="business-card-wallet-status">@(IsCardReady(Model.Detail) ? "Lista" : "Pendiente")</strong>
                        </div>
                        <div class="metric">
                            <span>Ultimo update</span>
                            <strong data-testid="business-card-last-update">@Model.Detail.LastStampedAt.ToLocalTime().ToString("g")</strong>
                        </div>
                    </div>

                    <div class="business-wallet-status-row" data-testid="business-wallet-status-row">
                        <span class="@(IsCardReady(Model.Detail) ? "wallet-status-ok" : "wallet-status-pending")">
                            @(IsCardReady(Model.Detail) ? "Tarjeta lista" : "Tarjeta pendiente")
                        </span>
                    </div>

                    <div class="stamp-ledger" data-testid="stamp-ledger-list">
                        <h3>Auditoria de sellos</h3>
                        @if (Model.Detail.RecentStampEvents.Count == 0)
                        {
                            <p class="text-muted" data-testid="stamp-ledger-empty">Aun no hay eventos registrados para esta tarjeta.</p>
                        }
                        else
                        {
                            <div class="stamp-ledger-items">
                                @foreach (var item in Model.Detail.RecentStampEvents)
                                {
                                    <div class="stamp-ledger-item" data-testid="stamp-ledger-event">
                                        <div>
                                            <strong>@CardStatus(item.GoogleWalletAttempted, item.GoogleWalletSucceeded, item.AppleWalletAttempted, item.AppleWalletSucceeded)</strong>
                                            <span>@item.CreatedAt.ToLocalTime().ToString("g")</span>
                                        </div>
                                        <p>Sellos actuales @item.NewCheckQTY · Historicos @item.NewHistoricCheckQTY</p>
                                        @if (!string.IsNullOrWhiteSpace(item.ErrorSummary))
                                        {
                                            <p class="text-danger">Error: @item.ErrorSummary</p>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="stamp-ledger" data-testid="reward-redemption-list">
                        <h3>Recompensas canjeadas</h3>
                        @if (Model.Detail.RecentRewardRedemptions.Count == 0)
                        {
                            <p class="text-muted" data-testid="reward-redemption-empty">Aun no hay recompensas canjeadas para esta tarjeta.</p>
                        }
                        else
                        {
                            <div class="stamp-ledger-items">
                                @foreach (var item in Model.Detail.RecentRewardRedemptions)
                                {
                                    <div class="stamp-ledger-item" data-testid="reward-redemption-event">
                                        <div>
                                            <strong>@(string.IsNullOrWhiteSpace(item.ErrorSummary) ? "Canje registrado" : "Con alerta")</strong>
                                            <span>@item.RedeemedAt.ToLocalTime().ToString("g")</span>
                                        </div>
                                        <p>@item.RedeemedCheckQTY de @item.StampGoal sellos · @item.RewardText</p>
                                        @if (!string.IsNullOrWhiteSpace(item.ErrorSummary))
                                        {
                                            <p class="text-danger">Error: @item.ErrorSummary</p>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="business-management-note" id="business-card-management-panel" data-testid="business-card-management-panel">
                        <strong>Administracion de tarjeta</strong>
                        <p>Desactivar pausa la operacion de esta tarjeta. Eliminar borra permanentemente la relacion del cliente con este negocio, sin borrar su cuenta global.</p>
                        <div class="business-card-action-buttons">
                            @if (Model.Detail.IsActive)
                            {
                                <form method="post"
                                      asp-page-handler="Deactivate"
                                      asp-route-cardId="@Model.Detail.Id"
                                      asp-route-query="@Model.Query"
                                      asp-route-pageNumber="@Model.PageNumber"
                                      asp-route-pageSize="@Model.PageSize">
                                    <button class="btn btn-outline-warning" type="submit" data-testid="business-card-deactivate-submit">
                                        Desactivar cliente
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form method="post"
                                      asp-page-handler="Reactivate"
                                      asp-route-cardId="@Model.Detail.Id"
                                      asp-route-query="@Model.Query"
                                      asp-route-pageNumber="@Model.PageNumber"
                                      asp-route-pageSize="@Model.PageSize">
                                    <button class="btn btn-outline-success" type="submit" data-testid="business-card-reactivate-submit">
                                        Reactivar cliente
                                    </button>
                                </form>
                            }
                        </div>
                        <form method="post"
                  asp-page-handler="Delete"
                  asp-route-cardId="@Model.Detail.Id"
                  asp-route-query="@Model.Query"
                  asp-route-pageNumber="@Model.PageNumber"
                  asp-route-pageSize="@Model.PageSize"
                              class="business-card-delete-form danger-action-panel danger-zone-card">
                            <div>
                                <strong>Eliminar permanentemente</strong>
                                <p>Esta accion elimina la tarjeta, sus links Wallet y sus datos asociados para este negocio. Escribe <b>@Model.Detail.Client.UserName</b> para confirmar.</p>
                            </div>
                            <div class="danger-action-controls">
                                <input class="form-control form-control-sm"
                                       name="confirmation"
                                       placeholder="Escribe @Model.Detail.Client.UserName"
                                       data-testid="business-card-delete-confirmation" />
                                <button class="btn btn-outline-danger" type="submit" data-testid="business-card-delete-submit">
                                    Eliminar
                                </button>
                            </div>
                        </form>
                    </div>
                }
            </div>
        </div>
    }
</section>

@functions {
    private static bool IsCardReady(BusinessCardDto card)
    {
        return card.GoogleIssued || card.AppleTracked;
    }

    private static string CardStatus(
        bool googleAttempted,
        bool googleSucceeded,
        bool appleAttempted,
        bool appleSucceeded)
    {
        if ((googleAttempted && !googleSucceeded) || (appleAttempted && !appleSucceeded))
        {
            return "Con alerta";
        }

        return "Actualizado";
    }
}
