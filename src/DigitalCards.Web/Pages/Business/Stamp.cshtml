@page
@model DigitalCards.Web.Pages.Business.StampModel
@{
    ViewData["Title"] = "Agregar sello";
}

<section class="form-panel business-operation-panel" data-testid="business-stamp-panel">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Checadas</p>
            <h1>Agregar sello</h1>
            <p class="lead">Aplicacion rapida por username o correo; la operacion completa vive en Tarjetas.</p>
        </div>
    </div>

    @if (Model.IsPilotBlocked)
    {
        <div class="alert alert-warning" role="status" data-testid="pilot-business-blocked">
            @Model.PilotBlockMessage
        </div>
    }

    @if (Model.Result is not null)
    {
        <div class="alert alert-success" role="status" data-testid="stamp-success">
            Sello agregado a @Model.Result.ClientUserName.
        </div>
        <div class="metric-row">
            <div class="metric">
                <span>Sellos actuales</span>
                <strong data-testid="current-stamps">@Model.Result.VisibleStamps de @Model.Result.StampGoal</strong>
            </div>
            <div class="metric">
                <span>Sellos historicos</span>
                <strong data-testid="lifetime-stamps">@Model.Result.LifetimeStamps</strong>
            </div>
            <div class="metric">
                <span>Tarjeta</span>
                <strong data-testid="card-status">@(Model.Result.GoogleObjectId is null ? "Pendiente" : "Actualizada")</strong>
            </div>
        </div>
    }

    @if (Model.Redemption is { Succeeded: true })
    {
        <div class="alert @(Model.Redemption.HasWalletWarning ? "alert-warning" : "alert-success")" role="status" data-testid="reward-redemption-success">
            @(Model.Redemption.HasWalletWarning
                ? Model.Redemption.ErrorMessage
                : "Recompensa canjeada. La tarjeta inicio un nuevo ciclo con 0 sellos.")
        </div>
    }

    @if (Model.RewardCandidate is { RewardReady: true })
    {
        <div class="business-form-card" data-testid="stamp-reward-candidate">
            <p class="eyebrow">Recompensa lista</p>
            <h2>@Model.RewardCandidate.Client.FirstName @Model.RewardCandidate.Client.LastName</h2>
            <p>Esta tarjeta ya tiene @Model.RewardCandidate.VisibleStamps de @Model.RewardCandidate.StampGoal sellos. Confirma el canje para iniciar un nuevo ciclo con 0 sellos.</p>
            <form method="post" asp-page-handler="Redeem" asp-route-cardId="@Model.RewardCandidate.Id">
                <button class="btn btn-success" type="submit" data-testid="stamp-redeem-submit" onclick="return confirm('Confirmar canje de recompensa para esta tarjeta?');">
                    Canjear recompensa
                </button>
            </form>
        </div>
    }

    @if (!Model.IsPilotBlocked)
    {
        <form method="post" class="business-form-card" data-testid="stamp-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input asp-for="ScannedCode" type="hidden" data-testid="stamp-scanned-code" />

            <div class="mb-3">
                <label asp-for="Input.UserNameOrEmail" class="form-label"></label>
                <input asp-for="Input.UserNameOrEmail" class="form-control" data-testid="stamp-username" />
                <span asp-validation-for="Input.UserNameOrEmail" class="text-danger"></span>
            </div>

            <div class="stamp-form-actions">
                <button class="btn btn-primary" type="submit" data-testid="stamp-submit">Agregar sello</button>
                <button class="btn btn-outline-primary" type="button" data-qr-start data-testid="stamp-scan-submit">Escanear QR</button>
                <span class="stamp-scan-status" data-qr-status data-testid="stamp-scan-status">Listo</span>
            </div>

            <div class="stamp-scan-preview" data-stamp-scan-preview data-scan-state="ready" data-testid="stamp-scan-preview">
                <span class="stamp-scan-preview-dot" aria-hidden="true"></span>
                <span data-stamp-scan-preview-text>Listo para escanear</span>
            </div>

            <div data-stamp-camera hidden>
                <video data-qr-video playsinline muted></video>
                <canvas data-qr-canvas></canvas>
            </div>
        </form>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/jsQR.js" asp-append-version="true"></script>
    <script src="~/js/business-stamp.js" asp-append-version="true"></script>
}
