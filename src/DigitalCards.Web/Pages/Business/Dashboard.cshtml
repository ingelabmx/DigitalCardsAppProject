@page
@model DigitalCards.Web.Pages.Business.DashboardModel
@{
    ViewData["Title"] = "Dashboard negocio";
}

<div class="p-page-header" data-testid="business-dashboard-shell">
    <h1 class="p-page-heading" data-testid="business-dashboard-title">@Model.BusinessName</h1>
    <p class="p-page-sub">Superficie inicial para enrolar clientes, agregar sellos y validar Wallets.</p>
</div>

@if (Model.IsPilotBlocked)
{
    <div class="alert alert-warning" role="status" data-testid="pilot-business-blocked">
        @Model.PilotBlockMessage
    </div>
}

@if (!Model.IsPilotBlocked && Model.Dashboard is not null)
{
    <div class="p-steps-grid" data-testid="business-flow-steps">
        <div class="p-step">
            <span class="p-step-num">01</span>
            <i class="bi bi-search p-step-icon"></i>
            <span class="p-step-title">Buscar tarjeta</span>
            <span class="p-step-desc">Encuentra al cliente por usuario o email.</span>
        </div>
        <div class="p-step">
            <span class="p-step-num">02</span>
            <i class="bi bi-send p-step-icon"></i>
            <span class="p-step-title">Reenviar Wallet</span>
            <span class="p-step-desc">Actualiza la tarjeta digital del cliente.</span>
        </div>
        <div class="p-step">
            <span class="p-step-num">03</span>
            <i class="bi bi-patch-check p-step-icon"></i>
            <span class="p-step-title">Agregar sello</span>
            <span class="p-step-desc">Registra la visita del cliente.</span>
        </div>
    </div>

    <div class="p-stats-grid">
        <div class="p-stat">
            <div class="p-stat-label">
                <span class="p-stat-icon blue"><i class="bi bi-credit-card-2-front"></i></span>
                Tarjetas recientes
            </div>
            <div class="p-stat-value" data-testid="business-dashboard-card-count">@Model.Dashboard.RecentCardCount</div>
        </div>
        <div class="p-stat">
            <div class="p-stat-label">
                <span class="p-stat-icon amber"><i class="bi bi-star-fill"></i></span>
                Sellos actuales
            </div>
            <div class="p-stat-value" data-testid="business-dashboard-current-stamps">@Model.Dashboard.CurrentStampTotal</div>
        </div>
        <div class="p-stat">
            <div class="p-stat-label">
                <span class="p-stat-icon green"><i class="bi bi-graph-up"></i></span>
                Sellos historicos
            </div>
            <div class="p-stat-value" data-testid="business-dashboard-lifetime-stamps">@Model.Dashboard.LifetimeStampTotal</div>
        </div>
    </div>

    <div class="p-card p-qr-panel mb-4" data-testid="business-public-enrollment-panel">
        <div class="p-qr-panel-header">
            <div>
                <h2 class="p-card-title">QR para clientes</h2>
                <p class="p-card-desc">Genera un link y QR para que clientes se registren directamente.</p>
            </div>
            <form method="post" asp-page-handler="GenerateEnrollmentLink">
                <button class="p-btn p-btn-primary" type="submit" data-testid="business-generate-enrollment-qr">
                    <i class="bi bi-qr-code"></i> Generar link y QR
                </button>
            </form>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.GeneratedEnrollmentUrl) && !string.IsNullOrWhiteSpace(Model.GeneratedEnrollmentQrSvg))
        {
            <div class="business-dashboard-grid mt-4" data-testid="business-enrollment-qr-result">
                <div>
                    <h3 class="p-sub-heading">Link publico</h3>
                    <input class="p-input" value="@Model.GeneratedEnrollmentUrl" readonly data-testid="business-enrollment-public-link" />
                    <div class="d-flex gap-2 mt-2">
                        <button type="button"
                                class="p-btn p-btn-outline p-btn-sm"
                                onclick="copyEnrollmentLink(this)"
                                data-link="@Model.GeneratedEnrollmentUrl">
                            <i class="bi bi-clipboard"></i> Copiar enlace
                        </button>
                        <button type="button"
                                class="p-btn p-btn-outline p-btn-sm"
                                onclick="downloadQRSvg()">
                            <i class="bi bi-download"></i> Descargar QR
                        </button>
                    </div>
                    <p class="p-note mt-2">El link generado no se guarda. Si generas otro QR o link, el anterior queda eliminado.</p>
                </div>
                <div class="text-center" data-testid="business-enrollment-qr">
                    @Html.Raw(Model.GeneratedEnrollmentQrSvg)
                </div>
            </div>
        }
    </div>

    <div class="p-activity-grid" data-testid="business-dashboard-summary">
        <div class="p-card-flush">
            <div class="p-card-header">
                <h2>Tarjetas recientes</h2>
                <a class="p-btn p-btn-ghost p-btn-sm" asp-page="/Business/Cards">Ver todas</a>
            </div>
            @if (Model.Dashboard.RecentCards.Count == 0)
            {
                <div class="p-empty" data-testid="business-dashboard-no-cards">
                    <i class="bi bi-credit-card p-empty-icon"></i>
                    <div class="p-empty-title">Sin tarjetas todavia</div>
                    <p class="p-empty-desc">Cuando agregues una tarjeta, aqui veras sellos y actividad reciente.</p>
                    <a class="p-btn p-btn-primary p-btn-sm p-empty-cta" asp-page="/Business/Enroll">Asociar cliente</a>
                </div>
            }
            else
            {
                <div data-testid="business-dashboard-recent-cards">
                    @foreach (var card in Model.Dashboard.RecentCards)
                    {
                        var clientName = $"{card.Client.FirstName} {card.Client.LastName}".Trim();
                        if (string.IsNullOrWhiteSpace(clientName)) clientName = card.Client.UserName;
                        var stampGoal = Math.Max(1, card.StampGoal);
                        var visibleStamps = Math.Min(card.CurrentStamps, stampGoal);
                        <a class="p-list-row"
                           asp-page="/Business/Cards"
                           asp-route-query="@card.Client.UserName"
                           asp-route-cardId="@card.Id"
                           data-testid="business-dashboard-recent-card">
                            <div>
                                <strong class="p-list-name">@clientName</strong>
                                <span class="p-list-meta">@card.Client.Email</span>
                            </div>
                            <span class="p-badge p-badge-gray">@visibleStamps / @stampGoal sellos</span>
                        </a>
                    }
                </div>
            }
        </div>

        <div class="p-card-flush">
            <div class="p-card-header">
                <h2>Ultimos sellos</h2>
                <a class="p-btn p-btn-ghost p-btn-sm" asp-page="/Business/Cards">Abrir tarjetas</a>
            </div>
            @if (Model.Dashboard.RecentStampEvents.Count == 0)
            {
                <div class="p-empty" data-testid="business-dashboard-no-ledger">
                    <i class="bi bi-patch-check p-empty-icon"></i>
                    <div class="p-empty-title">Sin sellos recientes</div>
                    <p class="p-empty-desc">Los eventos apareceran aqui con el resultado de la tarjeta digital.</p>
                </div>
            }
            else
            {
                <div class="stamp-ledger-items" data-testid="business-dashboard-ledger">
                    @foreach (var item in Model.Dashboard.RecentStampEvents)
                    {
                        var status = CardStatus(item.GoogleWalletAttempted, item.GoogleWalletSucceeded, item.AppleWalletAttempted, item.AppleWalletSucceeded);
                        var statusClass = status == "Con alerta" ? "p-badge p-badge-amber" : "p-badge p-badge-green";
                        <div class="p-ledger-item" data-testid="business-dashboard-ledger-event">
                            <div class="p-ledger-row">
                                <div>
                                    <strong class="p-list-name">@item.ClientName</strong>
                                    <span class="p-list-meta"><time class="local-time" data-utc="@item.CreatedAt.ToUniversalTime().ToString("o")" data-format="datetime">@item.CreatedAt.ToLocalTime().ToString("g")</time></span>
                                </div>
                                <span class="p-badge p-badge-gray">@item.NewCheckQTY sellos</span>
                            </div>
                            <div class="p-ledger-status">
                                <span class="@statusClass">@status</span>
                                @if (!string.IsNullOrWhiteSpace(item.ErrorSummary))
                                {
                                    <span class="p-badge p-badge-red"><i class="bi bi-exclamation-circle"></i> @item.ErrorSummary</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<script>
function downloadQRSvg() {
    var svg = document.querySelector('[data-testid="business-enrollment-qr"] svg');
    if (!svg) return;
    var svgData = new XMLSerializer().serializeToString(svg);
    var svgBlob = new Blob([svgData], { type: 'image/svg+xml;charset=utf-8' });
    var url = URL.createObjectURL(svgBlob);
    var img = new Image();
    img.onload = function () {
        var scale = 3;
        var canvas = document.createElement('canvas');
        canvas.width = img.naturalWidth * scale;
        canvas.height = img.naturalHeight * scale;
        var ctx = canvas.getContext('2d');
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
        URL.revokeObjectURL(url);
        var a = document.createElement('a');
        a.href = canvas.toDataURL('image/png');
        a.download = 'puntelio-qr.png';
        a.click();
    };
    img.src = url;
}
function copyEnrollmentLink(btn) {
    const link = btn.getAttribute('data-link');
    navigator.clipboard.writeText(link).then(function() {
        const original = btn.innerHTML;
        btn.innerHTML = '<i class="bi bi-check2"></i> Copiado';
        btn.disabled = true;
        setTimeout(function() {
            btn.innerHTML = original;
            btn.disabled = false;
        }, 2000);
    }).catch(function() {
        const input = document.createElement('input');
        input.value = link;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
        const original = btn.innerHTML;
        btn.innerHTML = '<i class="bi bi-check2"></i> Copiado';
        btn.disabled = true;
        setTimeout(function() {
            btn.innerHTML = original;
            btn.disabled = false;
        }, 2000);
    });
}
</script>

@functions {
    private static string CardStatus(
        bool googleAttempted,
        bool googleSucceeded,
        bool appleAttempted,
        bool appleSucceeded)
    {
        var hasGoogleAlert = googleAttempted && !googleSucceeded;
        var hasAppleAlert = appleAttempted && !appleSucceeded;
        if (hasGoogleAlert || hasAppleAlert) return "Con alerta";
        return "Actualizado";
    }
}
