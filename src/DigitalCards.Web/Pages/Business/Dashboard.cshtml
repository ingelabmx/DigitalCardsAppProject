@page
@model DigitalCards.Web.Pages.Business.DashboardModel
@{
    ViewData["Title"] = "Dashboard negocio";
}

<section class="app-surface business-dashboard-shell" data-testid="business-dashboard-shell">
    <div class="business-hero-grid">
        <div>
            <p class="eyebrow">Negocio</p>
            <h1 data-testid="business-dashboard-title">@Model.BusinessName</h1>
            <p class="lead">Superficie inicial para enrolar clientes, agregar sellos y validar Wallets.</p>
        </div>
        <div class="business-flow-card" data-testid="business-flow-steps">
            <span>Flujo diario</span>
            <ol>
                <li>Buscar tarjeta</li>
                <li>Reenviar Wallet</li>
                <li>Agregar sello</li>
            </ol>
        </div>
    </div>

    @if (Model.IsPilotBlocked)
    {
        <div class="alert alert-warning" role="status" data-testid="pilot-business-blocked">
            @Model.PilotBlockMessage
        </div>

        <div class="action-grid business-action-grid">
            <a class="action-card" asp-page="/Business/Logout" data-testid="logout-link">
                <span>Salir</span>
                <small>Cierra la sesion del negocio.</small>
            </a>
        </div>
    }
    else
    {
        <div class="action-grid">
            <a class="action-card" asp-page="/Business/Cards" data-testid="cards-link">
                <span>Tarjetas y sellos</span>
                <small>Busca clientes, reenvia Wallet y agrega sellos.</small>
            </a>
            <a class="action-card" asp-page="/Business/Enroll" data-testid="enroll-link">
                <span>Asociar cliente</span>
                <small>Genera correo con link de Wallet.</small>
            </a>
            <a class="action-card" asp-page="/Business/Branding" data-testid="business-branding-link">
                <span>Branding Wallet</span>
                <small>Edita logo, colores y nombre publico del programa.</small>
            </a>
            <a class="action-card" asp-page="/Business/Reports" data-testid="business-reports-link">
                <span>Reportes</span>
                <small>Consulta tarjetas, sellos, Wallets y alertas recientes.</small>
            </a>
            @if (Model.ShowDevOutboxLink)
            {
                <a class="action-card" asp-page="/Dev/Outbox" data-testid="dashboard-outbox-link">
                    <span>Ver outbox</span>
                    <small>Simulacion de correos enviados.</small>
                </a>
            }
            <a class="action-card" asp-page="/Business/Logout" data-testid="logout-link">
                <span>Salir</span>
                <small>Cierra la sesion del negocio.</small>
            </a>
        </div>
    }
</section>

@if (!Model.IsPilotBlocked && Model.Dashboard is not null)
{
    <section class="result-panel" data-testid="business-public-enrollment-panel">
        <div class="page-heading">
            <div>
                <p class="eyebrow">Registro publico</p>
                <h2>QR para clientes</h2>
                <p class="text-muted">Genera un link y QR para que clientes se registren directamente en este negocio.</p>
            </div>
            <form method="post" asp-page-handler="GenerateEnrollmentLink">
                <button class="btn btn-outline-primary" type="submit" data-testid="business-generate-enrollment-qr">
                    Generar link y QR
                </button>
            </form>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.GeneratedEnrollmentUrl) && !string.IsNullOrWhiteSpace(Model.GeneratedEnrollmentQrSvg))
        {
            <div class="business-dashboard-grid" data-testid="business-enrollment-qr-result">
                <div class="business-dashboard-panel">
                    <h2>Link publico</h2>
                    <input class="form-control" value="@Model.GeneratedEnrollmentUrl" readonly data-testid="business-enrollment-public-link" />
                    <p class="text-muted mt-2">El token plano no se guarda. Si generas otro QR, el anterior queda revocado.</p>
                </div>
                <div class="business-dashboard-panel text-center" data-testid="business-enrollment-qr">
                    @Html.Raw(Model.GeneratedEnrollmentQrSvg)
                </div>
            </div>
        }
    </section>

    <section class="result-panel business-dashboard-summary" data-testid="business-dashboard-summary">
        <div class="page-heading">
            <div>
                <p class="eyebrow">Resumen operativo</p>
                <h2>Actividad reciente</h2>
                <p class="text-muted">Datos recientes del negocio autenticado. No se muestran tokens ni credenciales.</p>
            </div>
            <a class="btn btn-outline-primary" asp-page="/Business/Cards" data-testid="business-dashboard-open-cards">Abrir tarjetas</a>
        </div>

        <div class="metric-row">
            <div class="metric">
                <span>Tarjetas recientes</span>
                <strong data-testid="business-dashboard-card-count">@Model.Dashboard.RecentCardCount</strong>
            </div>
            <div class="metric">
                <span>Sellos actuales</span>
                <strong data-testid="business-dashboard-current-stamps">@Model.Dashboard.CurrentStampTotal</strong>
            </div>
            <div class="metric">
                <span>Sellos historicos</span>
                <strong data-testid="business-dashboard-lifetime-stamps">@Model.Dashboard.LifetimeStampTotal</strong>
            </div>
            <div class="metric">
                <span>Google Wallet</span>
                <strong data-testid="business-dashboard-google-count">@Model.Dashboard.GoogleIssuedCount</strong>
            </div>
            <div class="metric">
                <span>Apple Wallet</span>
                <strong data-testid="business-dashboard-apple-count">@Model.Dashboard.AppleTrackedCount</strong>
            </div>
            <div class="metric">
                <span>Alertas Wallet</span>
                <strong data-testid="business-dashboard-wallet-issues">@Model.Dashboard.WalletIssueCount</strong>
            </div>
        </div>

        <div class="business-dashboard-grid">
            <section class="business-dashboard-panel">
                <h2>Tarjetas recientes</h2>
                @if (Model.Dashboard.RecentCards.Count == 0)
                {
                    <p class="text-muted" data-testid="business-dashboard-no-cards">Aun no hay tarjetas asociadas.</p>
                }
                else
                {
                    <div class="dashboard-card-list" data-testid="business-dashboard-recent-cards">
                        @foreach (var card in Model.Dashboard.RecentCards)
                        {
                            <a class="dashboard-card-row"
                               asp-page="/Business/Cards"
                               asp-route-query="@card.Client.UserName"
                               asp-route-cardId="@card.Id"
                               data-testid="business-dashboard-recent-card">
                                <div>
                                    <strong>@card.Client.UserName</strong>
                                    <span>@card.Client.Email</span>
                                </div>
                                <div>
                                    <strong>@card.CurrentStamps</strong>
                                    <span>sellos</span>
                                </div>
                            </a>
                        }
                    </div>
                }
            </section>

            <section class="business-dashboard-panel">
                <h2>Ultimos sellos</h2>
                @if (Model.Dashboard.RecentStampEvents.Count == 0)
                {
                    <p class="text-muted" data-testid="business-dashboard-no-ledger">Aun no hay eventos de sellos.</p>
                }
                else
                {
                    <div class="stamp-ledger-items" data-testid="business-dashboard-ledger">
                        @foreach (var item in Model.Dashboard.RecentStampEvents)
                        {
                            <div class="stamp-ledger-item" data-testid="business-dashboard-ledger-event">
                                <div>
                                    <strong>@item.ClientUserName</strong>
                                    <span>@item.CreatedAt.ToLocalTime().ToString("g")</span>
                                </div>
                                <p>@item.Source &middot; Sellos: @item.PreviousCheckQTY -> @item.NewCheckQTY</p>
                                <p>
                                    Google: @WalletStatus(item.GoogleWalletAttempted, item.GoogleWalletSucceeded)
                                    &middot; Apple: @WalletStatus(item.AppleWalletAttempted, item.AppleWalletSucceeded)
                                </p>
                                @if (!string.IsNullOrWhiteSpace(item.ErrorSummary))
                                {
                                    <p class="text-danger">Error: @item.ErrorSummary</p>
                                }
                            </div>
                        }
                    </div>
                }
            </section>
        </div>
    </section>
}

@functions {
    private static string WalletStatus(bool attempted, bool succeeded)
    {
        if (!attempted)
        {
            return "No aplica";
        }

        return succeeded ? "OK" : "Fallo";
    }
}
