@page
@model DigitalCards.Web.Pages.Business.BrandingModel
@{
    ViewData["Title"] = "Branding negocio";
}

<div class="p-page-header">
    <h1 class="p-page-heading">Branding Wallet</h1>
    @if (Model.Settings is not null)
    {
        <p class="p-page-sub" data-testid="business-branding-heading">@Model.Settings.BusinessName</p>
    }
</div>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success" role="status" data-testid="business-branding-status">
        @Model.StatusMessage
    </div>
}

@if (Model.IsPilotBlocked)
{
    <div class="alert alert-warning" role="status" data-testid="pilot-business-blocked">
        @Model.PilotBlockMessage
    </div>
}
else if (Model.Settings is not null)
{
    <div class="p-branding-grid">
        <form method="post"
              enctype="multipart/form-data"
              data-testid="business-branding-form">
            <div class="p-card mb-4">
                <h2 class="p-section-title">Perfil publico</h2>
                <p class="p-page-sub mb-4">Estos datos aparecen en correos, landing Wallet, tarjeta digital y dashboard cliente.</p>

                <div class="mb-3">
                    <label asp-for="Input.PublicName" class="form-label">Nombre del negocio</label>
                    <input asp-for="Input.PublicName" class="form-control" maxlength="80" data-testid="business-branding-public-name" data-branding-text="name" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ProgramName" class="form-label">Programa</label>
                    <input asp-for="Input.ProgramName" class="form-control" maxlength="80" data-testid="business-branding-program-name" data-branding-text="program" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ProgramDescription" class="form-label">Recompensa</label>
                    <input asp-for="Input.ProgramDescription" class="form-control" maxlength="280" data-testid="business-branding-description" data-branding-text="desc" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.StampGoal" class="form-label">Numero de sellos</label>
                    <input asp-for="Input.StampGoal" class="form-control" type="number" min="1" max="1000" data-testid="business-branding-stamp-goal" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Logo actual</label>
                    @{
                        var hasLogo = !Model.CurrentLogoUnavailable && !string.IsNullOrWhiteSpace(Model.Settings.Branding.LogoPath);
                    }
                    <div class="branding-logo-preview"
                         data-testid="business-branding-logo-preview"
                         data-branding-logo-preview-container
                         hidden="@(!hasLogo)">
                        <img src="@(hasLogo ? VersionedLogoPath(Model.Settings.Branding.LogoPath, Model.Settings.Branding.UpdatedAt) : string.Empty)"
                             alt="Logo actual"
                             data-branding-logo-preview-image
                             hidden="@(!hasLogo)" />
                    </div>
                    @if (Model.CurrentLogoUnavailable)
                    {
                        <div class="alert alert-warning py-2 mb-2" role="status" data-testid="business-branding-logo-missing" data-branding-logo-placeholder>
                            El logo actual no esta disponible; sube un PNG nuevo.
                        </div>
                    }
                    else if (!hasLogo)
                    {
                        <p class="p-page-sub mb-2" data-testid="business-branding-logo-empty" data-branding-logo-placeholder>Sin logo personalizado.</p>
                    }
                    <label asp-for="Input.LogoUpload" class="form-label">Subir logo PNG</label>
                    <input asp-for="Input.LogoUpload" class="form-control" type="file" accept=".png,image/png" data-testid="business-branding-logo-upload" data-branding-logo-upload />
                    <small class="p-page-sub">Solo PNG. Maximo 2 MB. Si no es cuadrado, Puntelio lo centra en un lienzo transparente para Wallet.</small>
                </div>

                <div class="p-branding-colors mb-3">
                    <div>
                        <label asp-for="Input.PrimaryColor" class="form-label">Color primario</label>
                        <div class="p-color-picker-wrap">
                            <button type="button" class="p-color-swatch" style="background:@Model.Input.PrimaryColor" data-swatch-for="Input_PrimaryColor"></button>
                            <input type="color" id="picker_primary" class="p-color-native" value="@Model.Input.PrimaryColor" data-picker-for="Input_PrimaryColor" />
                            <input type="text" class="form-control p-color-hex" maxlength="7" placeholder="#000000" value="@Model.Input.PrimaryColor" data-branding-color-input="primary" data-hex-for="Input_PrimaryColor" data-testid="business-branding-primary" />
                            <input type="hidden" asp-for="Input.PrimaryColor" />
                        </div>
                    </div>
                    <div>
                        <label asp-for="Input.SecondaryColor" class="form-label">Color secundario 1</label>
                        <div class="p-color-picker-wrap">
                            <button type="button" class="p-color-swatch" style="background:@Model.Input.SecondaryColor" data-swatch-for="Input_SecondaryColor"></button>
                            <input type="color" id="picker_secondary" class="p-color-native" value="@Model.Input.SecondaryColor" data-picker-for="Input_SecondaryColor" />
                            <input type="text" class="form-control p-color-hex" maxlength="7" placeholder="#000000" value="@Model.Input.SecondaryColor" data-branding-color-input="secondary" data-hex-for="Input_SecondaryColor" data-testid="business-branding-secondary" />
                            <input type="hidden" asp-for="Input.SecondaryColor" />
                        </div>
                    </div>
                    <div>
                        <label asp-for="Input.CustomFieldColor" class="form-label">Color secundario 2</label>
                        <div class="p-color-picker-wrap">
                            <button type="button" class="p-color-swatch" style="background:@Model.Input.CustomFieldColor" data-swatch-for="Input_CustomFieldColor"></button>
                            <input type="color" id="picker_custom" class="p-color-native" value="@Model.Input.CustomFieldColor" data-picker-for="Input_CustomFieldColor" />
                            <input type="text" class="form-control p-color-hex" maxlength="7" placeholder="#000000" value="@Model.Input.CustomFieldColor" data-branding-color-input="custom" data-hex-for="Input_CustomFieldColor" data-testid="business-branding-custom-field-color" />
                            <input type="hidden" asp-for="Input.CustomFieldColor" />
                        </div>
                    </div>
                </div>

                <div class="p-branding-preview"
                     id="brandingPreview"
                     style="--brand-primary:@Model.Input.PrimaryColor;--brand-secondary:@Model.Input.SecondaryColor;--brand-custom:@Model.Input.CustomFieldColor;"
                     data-testid="business-branding-preview">
                    <span data-branding-preview="program">@Model.Input.ProgramName</span>
                    <strong data-branding-preview="name">@Model.Input.PublicName</strong>
                    <small data-branding-preview="desc">@Model.Input.ProgramDescription</small>
                </div>

                <div class="p-action-buttons mt-4">
                    <button class="btn btn-primary" type="submit" data-testid="business-branding-submit">Guardar</button>
                    <button class="btn btn-outline-primary"
                            type="submit"
                            asp-page-handler="SaveAndRefresh"
                            data-testid="business-branding-save-refresh-submit">
                        Guardar y actualizar
                    </button>
                </div>
            </div>
        </form>

        <div>
            <div class="p-card" data-testid="business-wallet-branding-refresh-form">
                <form method="post" asp-page-handler="RefreshWallets">
                    <h2 class="p-section-title">Actualizar Tarjetas</h2>
                    <p class="p-page-sub mb-3">Aplica el branding actual a todas las tarjetas digitales ya emitidas de este negocio. No modifica sellos ni datos del cliente.</p>

                    @if (Model.RefreshResult is not null)
                    {
                        <div class="p-wallet-refresh mb-3" data-testid="business-wallet-branding-refresh-result">
                            <span>Tarjetas Wallet: <strong>@Model.RefreshResult.CardsWithTrackedWallets</strong></span>
                            <span>Actualizaciones: <strong>@(Model.RefreshResult.GoogleWalletSucceeded + Model.RefreshResult.AppleWalletSucceeded) / @(Model.RefreshResult.GoogleWalletAttempted + Model.RefreshResult.AppleWalletAttempted)</strong></span>
                        </div>
                    }

                    <button class="btn btn-outline-primary" type="submit" data-testid="business-wallet-branding-refresh-submit">Actualizar</button>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
(function () {
    var preview = document.getElementById('brandingPreview');
    if (!preview) return;

    function normalizeHex(val) {
        val = (val || '').trim();
        if (val.charAt(0) === '#') val = val.slice(1);
        val = val.replace(/[^0-9a-fA-F]/g, '');
        if (val.length > 6) val = val.slice(0, 6);
        while (val.length < 6) val += '0';
        return val.length === 0 ? '' : '#' + val;
    }

    function updateColors() {
        var primary   = document.querySelector('[data-branding-color-input="primary"]');
        var secondary = document.querySelector('[data-branding-color-input="secondary"]');
        var custom    = document.querySelector('[data-branding-color-input="custom"]');
        if (primary   && primary.value)   preview.style.setProperty('--brand-primary',   primary.value);
        if (secondary && secondary.value) preview.style.setProperty('--brand-secondary', secondary.value);
        if (custom    && custom.value)    preview.style.setProperty('--brand-custom',     custom.value);
    }

    function updateText(key, value) {
        var el = preview.querySelector('[data-branding-preview="' + key + '"]');
        if (el) el.textContent = value;
    }

    // Sync hidden input + picker + swatch to a new value
    function applyColor(hiddenId, val) {
        var hidden = document.getElementById(hiddenId);
        var picker = document.querySelector('[data-picker-for="' + hiddenId + '"]');
        var swatch = document.querySelector('[data-swatch-for="' + hiddenId + '"]');
        if (hidden) hidden.value = val;
        if (picker && /^#[0-9A-Fa-f]{6}$/.test(val)) picker.value = val;
        if (swatch) swatch.style.background = val;
    }

    // Native color picker → hex text + hidden + swatch + preview
    document.querySelectorAll('[data-picker-for]').forEach(function (picker) {
        var hiddenId = picker.getAttribute('data-picker-for');
        var hexEl = document.querySelector('[data-hex-for="' + hiddenId + '"]');
        picker.addEventListener('input', function () {
            if (hexEl) hexEl.value = this.value;
            applyColor(hiddenId, this.value);
            updateColors();
        });
    });

    // Hex text input → picker + hidden + swatch + preview
    document.querySelectorAll('[data-branding-color-input]').forEach(function (input) {
        var hiddenId = input.getAttribute('data-hex-for');
        input.addEventListener('input', function () {
            if (hiddenId && /^#[0-9A-Fa-f]{6}$/.test(this.value)) {
                applyColor(hiddenId, this.value);
            }
            updateColors();
        });
        input.addEventListener('blur', function () {
            var normalized = normalizeHex(this.value);
            if (normalized) {
                this.value = normalized;
                if (hiddenId) applyColor(hiddenId, normalized);
                updateColors();
            }
        });
    });

    // Swatch button → click native picker
    document.querySelectorAll('[data-swatch-for]').forEach(function (swatch) {
        var hiddenId = swatch.getAttribute('data-swatch-for');
        swatch.addEventListener('click', function () {
            var picker = document.querySelector('[data-picker-for="' + hiddenId + '"]');
            if (picker) picker.click();
        });
    });

    // Text fields → preview
    document.querySelectorAll('[data-branding-text]').forEach(function (input) {
        var key = input.getAttribute('data-branding-text');
        input.addEventListener('input', function () {
            updateText(key, this.value);
        });
    });
})();
</script>
}

@functions {
    private static string VersionedLogoPath(string logoPath, DateTimeOffset? updatedAt)
    {
        if (string.IsNullOrWhiteSpace(logoPath))
        {
            return string.Empty;
        }

        var version = updatedAt?.ToUnixTimeSeconds() ?? DateTimeOffset.UtcNow.ToUnixTimeSeconds();
        var separator = logoPath.Contains('?', StringComparison.Ordinal) ? "&" : "?";
        return $"{logoPath}{separator}v={version}";
    }
}
