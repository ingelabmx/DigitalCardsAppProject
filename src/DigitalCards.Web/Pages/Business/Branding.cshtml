@page
@model DigitalCards.Web.Pages.Business.BrandingModel
@{
    ViewData["Title"] = "Branding negocio";
}

<div class="p-page-header">
    <span class="p-eyebrow">Negocio</span>
    <h1 class="p-page-heading">Branding Wallet</h1>
    @if (Model.Settings is not null)
    {
        <p class="p-page-sub" data-testid="business-branding-heading">@Model.Settings.BusinessName</p>
    }
</div>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success" role="status" data-testid="business-branding-status">
        @Model.StatusMessage
    </div>
}

@if (Model.IsPilotBlocked)
{
    <div class="alert alert-warning" role="status" data-testid="pilot-business-blocked">
        @Model.PilotBlockMessage
    </div>
}
else if (Model.Settings is not null)
{
    <div class="p-branding-grid">
        <form method="post"
              enctype="multipart/form-data"
              data-testid="business-branding-form">
            <div class="p-card mb-4">
                <h2 class="p-section-title">Perfil publico</h2>
                <p class="p-page-sub mb-4">Estos datos aparecen en correos, landing Wallet, tarjeta digital y dashboard cliente.</p>

                <div class="mb-3">
                    <label asp-for="Input.PublicName" class="form-label">Nombre del negocio</label>
                    <input asp-for="Input.PublicName" class="form-control" maxlength="80" data-testid="business-branding-public-name" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ProgramName" class="form-label">Programa</label>
                    <input asp-for="Input.ProgramName" class="form-control" maxlength="80" data-testid="business-branding-program-name" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ProgramDescription" class="form-label">Recompensa</label>
                    <input asp-for="Input.ProgramDescription" class="form-control" maxlength="280" data-testid="business-branding-description" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.StampGoal" class="form-label">Numero de sellos</label>
                    <input asp-for="Input.StampGoal" class="form-control" type="number" min="1" max="1000" data-testid="business-branding-stamp-goal" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Logo actual</label>
                    @{
                        var hasLogo = !Model.CurrentLogoUnavailable && !string.IsNullOrWhiteSpace(Model.Settings.Branding.LogoPath);
                    }
                    <div class="branding-logo-preview"
                         data-testid="business-branding-logo-preview"
                         data-branding-logo-preview-container
                         hidden="@(!hasLogo)">
                        <img src="@(hasLogo ? VersionedLogoPath(Model.Settings.Branding.LogoPath, Model.Settings.Branding.UpdatedAt) : string.Empty)"
                             alt="Logo actual"
                             data-branding-logo-preview-image
                             hidden="@(!hasLogo)" />
                    </div>
                    @if (Model.CurrentLogoUnavailable)
                    {
                        <div class="alert alert-warning py-2 mb-2" role="status" data-testid="business-branding-logo-missing" data-branding-logo-placeholder>
                            El logo actual no esta disponible; sube un PNG nuevo.
                        </div>
                    }
                    else if (!hasLogo)
                    {
                        <p class="p-page-sub mb-2" data-testid="business-branding-logo-empty" data-branding-logo-placeholder>Sin logo personalizado.</p>
                    }
                    <label asp-for="Input.LogoUpload" class="form-label">Subir logo PNG</label>
                    <input asp-for="Input.LogoUpload" class="form-control" type="file" accept=".png,image/png" data-testid="business-branding-logo-upload" data-branding-logo-upload />
                    <small class="p-page-sub">Solo PNG. Maximo 2 MB. Si no es cuadrado, Puntelio lo centra en un lienzo transparente para Wallet.</small>
                </div>

                <div class="p-branding-colors mb-3">
                    <div>
                        <label asp-for="Input.PrimaryColor" class="form-label">Color primario</label>
                        <input asp-for="Input.PrimaryColor" class="form-control" maxlength="7" data-testid="business-branding-primary" data-branding-color-input="primary" />
                    </div>
                    <div>
                        <label asp-for="Input.SecondaryColor" class="form-label">Color secundario 1</label>
                        <input asp-for="Input.SecondaryColor" class="form-control" maxlength="7" data-testid="business-branding-secondary" data-branding-color-input="secondary" />
                    </div>
                    <div>
                        <label asp-for="Input.CustomFieldColor" class="form-label">Color secundario 2</label>
                        <input asp-for="Input.CustomFieldColor" class="form-control" maxlength="7" data-testid="business-branding-custom-field-color" data-branding-color-input="custom" />
                    </div>
                </div>

                <div class="p-action-buttons">
                    <button class="btn btn-primary" type="submit" data-testid="business-branding-submit">Guardar</button>
                    <button class="btn btn-outline-primary"
                            type="submit"
                            asp-page-handler="SaveAndRefresh"
                            data-testid="business-branding-save-refresh-submit">
                        Guardar y actualizar
                    </button>
                </div>
            </div>
        </form>

        <div>
            <div class="p-branding-preview"
                 style="--brand-primary:@Model.Input.PrimaryColor;--brand-secondary:@Model.Input.SecondaryColor;--brand-custom:@Model.Input.CustomFieldColor;"
                 data-testid="business-branding-preview">
                <span>@Model.Input.ProgramName</span>
                <strong>@Model.Input.PublicName</strong>
                <small>@Model.Input.ProgramDescription</small>
            </div>

            <div class="p-card mt-4" data-testid="business-wallet-branding-refresh-form">
                <form method="post" asp-page-handler="RefreshWallets">
                    <h2 class="p-section-title">Actualizar Tarjetas</h2>
                    <p class="p-page-sub mb-3">Aplica el branding actual a todas las tarjetas digitales ya emitidas de este negocio. No modifica sellos ni datos del cliente.</p>

                    @if (Model.RefreshResult is not null)
                    {
                        <div class="p-wallet-refresh mb-3" data-testid="business-wallet-branding-refresh-result">
                            <span>Tarjetas Wallet: <strong>@Model.RefreshResult.CardsWithTrackedWallets</strong></span>
                            <span>Actualizaciones: <strong>@(Model.RefreshResult.GoogleWalletSucceeded + Model.RefreshResult.AppleWalletSucceeded) / @(Model.RefreshResult.GoogleWalletAttempted + Model.RefreshResult.AppleWalletAttempted)</strong></span>
                        </div>
                    }

                    <button class="btn btn-outline-primary" type="submit" data-testid="business-wallet-branding-refresh-submit">Actualizar</button>
                </form>
            </div>
        </div>
    </div>
}

@functions {
    private static string VersionedLogoPath(string logoPath, DateTimeOffset? updatedAt)
    {
        if (string.IsNullOrWhiteSpace(logoPath))
        {
            return string.Empty;
        }

        var version = updatedAt?.ToUnixTimeSeconds() ?? DateTimeOffset.UtcNow.ToUnixTimeSeconds();
        var separator = logoPath.Contains('?', StringComparison.Ordinal) ? "&" : "?";
        return $"{logoPath}{separator}v={version}";
    }
}
