@page
@model DigitalCards.Web.Pages.Business.BrandingModel
@{
    ViewData["Title"] = "Branding negocio";
}

<section class="result-panel">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Negocio</p>
            <h1>Branding Wallet</h1>
            @if (Model.Settings is not null)
            {
                <p class="lead" data-testid="business-branding-heading">@Model.Settings.BusinessName</p>
            }
        </div>
        <a class="btn btn-outline-secondary" asp-page="/Business/Dashboard" data-testid="business-branding-back-link">Dashboard</a>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status" data-testid="business-branding-status">
            @Model.StatusMessage
        </div>
    }

    @if (Model.IsPilotBlocked)
    {
        <div class="alert alert-warning" role="status" data-testid="pilot-business-blocked">
            @Model.PilotBlockMessage
        </div>
    }
    else if (Model.Settings is not null)
    {
        <div class="business-profile-grid">
            <form method="post"
                  enctype="multipart/form-data"
                  class="business-profile-panel business-branding-panel"
                  data-testid="business-branding-form">
                <h2>Perfil publico</h2>
                <p class="text-muted">Estos datos aparecen en correos, landing Wallet, tarjeta digital y dashboard cliente.</p>

                <div class="mb-3">
                    <label asp-for="Input.PublicName" class="form-label">Nombre publico</label>
                    <input asp-for="Input.PublicName" class="form-control" maxlength="80" data-testid="business-branding-public-name" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ProgramName" class="form-label">Programa</label>
                    <input asp-for="Input.ProgramName" class="form-control" maxlength="80" data-testid="business-branding-program-name" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ProgramDescription" class="form-label">Recompensa</label>
                    <input asp-for="Input.ProgramDescription" class="form-control" maxlength="280" data-testid="business-branding-description" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Logo actual</label>
                    @if (Model.CurrentLogoUnavailable)
                    {
                        <div class="alert alert-warning py-2 mb-2" role="status" data-testid="business-branding-logo-missing">
                            El logo actual no esta disponible; sube un PNG nuevo.
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(Model.Settings.Branding.LogoPath))
                    {
                        <div class="branding-logo-preview" data-testid="business-branding-logo-preview">
                            <img src="@Model.Settings.Branding.LogoPath" alt="Logo actual" />
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-2" data-testid="business-branding-logo-empty">Sin logo personalizado.</p>
                    }
                    <label asp-for="Input.LogoUpload" class="form-label">Subir logo PNG</label>
                    <input asp-for="Input.LogoUpload" class="form-control" type="file" accept=".png,image/png" data-testid="business-branding-logo-upload" />
                    <small class="form-text text-muted">Solo PNG. Maximo 2 MB. Si no es cuadrado, Puntelio lo centra en un lienzo transparente para Wallet.</small>
                </div>

                <div class="branding-color-row">
                    <div class="mb-3">
                        <label asp-for="Input.PrimaryColor" class="form-label">Color primario</label>
                        <input asp-for="Input.PrimaryColor" class="form-control" maxlength="7" data-testid="business-branding-primary" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.SecondaryColor" class="form-label">Color secundario</label>
                        <input asp-for="Input.SecondaryColor" class="form-control" maxlength="7" data-testid="business-branding-secondary" />
                    </div>
                </div>

                <div class="branding-preview"
                     style="--brand-primary:@Model.Input.PrimaryColor;--brand-secondary:@Model.Input.SecondaryColor;"
                     data-testid="business-branding-preview">
                    <span>@Model.Input.ProgramName</span>
                    <strong>@Model.Input.PublicName</strong>
                </div>

                <div class="form-actions">
                    <button class="btn btn-primary" type="submit" data-testid="business-branding-submit">Guardar</button>
                    <button class="btn btn-outline-primary"
                            type="submit"
                            asp-page-handler="SaveAndRefresh"
                            data-testid="business-branding-save-refresh-submit">
                        Guardar y actualizar
                    </button>
                </div>
            </form>

            <form method="post"
                  asp-page-handler="RefreshWallets"
                  class="business-profile-panel"
                  data-testid="business-wallet-branding-refresh-form">
                <h2>Actualizar Tarjetas</h2>
                <p class="text-muted">Aplica el branding actual a todas las tarjetas digitales ya emitidas de este negocio. No modifica sellos ni datos del cliente.</p>

                @if (Model.RefreshResult is not null)
                {
                    <div class="wallet-refresh-summary" data-testid="business-wallet-branding-refresh-result">
                        <span>Tarjetas Wallet: @Model.RefreshResult.CardsWithTrackedWallets</span>
                        <span>Actualizaciones: @(Model.RefreshResult.GoogleWalletSucceeded + Model.RefreshResult.AppleWalletSucceeded) / @(Model.RefreshResult.GoogleWalletAttempted + Model.RefreshResult.AppleWalletAttempted)</span>
                    </div>
                }

                <button class="btn btn-outline-primary" type="submit" data-testid="business-wallet-branding-refresh-submit">Actualizar</button>
            </form>
        </div>
    }
</section>
