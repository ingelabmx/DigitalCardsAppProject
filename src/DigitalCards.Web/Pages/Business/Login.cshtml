@page
@model DigitalCards.Web.Pages.Business.LoginModel
@{
    ViewData["Title"] = "Login negocio";
}

<section class="auth-gateway auth-gateway-business">
    <div class="auth-copy-panel">
        <h1>Opera tarjetas y sellos desde tu mostrador.</h1>
        <p>
            Busca clientes, asocia tarjetas, reenvia links Wallet y confirma updates despues de cada sello.
        </p>
        <a class="auth-home-link" asp-page="/Index">Volver al inicio</a>
    </div>

    <div class="auth-form-card">
        <div class="p-auth-tabs">
            <a class="p-auth-tab" asp-page="/Client/Login">Cliente</a>
            <span class="p-auth-tab p-auth-tab-active">Negocio</span>
        </div>
        <div class="auth-form-heading">
            <div>
                <h2>Acceso negocio</h2>
                <p>Acceso para negocios habilitados en Puntelio.</p>
            </div>
        </div>

        <form method="post" data-testid="business-login-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control form-control-lg" data-testid="business-email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" class="form-control form-control-lg" data-testid="business-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <button class="btn btn-primary btn-lg w-100" type="submit" data-testid="business-login-submit">Entrar al negocio</button>
            <a class="auth-forgot-link" asp-page="/Business/ForgotPassword" data-testid="business-forgot-password-link">Olvide mi contrasena</a>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
