@page
@model DigitalCards.Web.Pages.Business.LoginModel
@{
    ViewData["Title"] = "Login negocio";
}

<section class="form-panel">
    <h1>Login negocio</h1>
    <p class="text-muted">Cuenta local de prueba: demo@digitalcards.test / business123.</p>

    <form method="post" data-testid="business-login-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Input.Email" class="form-label"></label>
            <input asp-for="Input.Email" class="form-control" data-testid="business-email" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Password" class="form-label"></label>
            <input asp-for="Input.Password" class="form-control" data-testid="business-password" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <button class="btn btn-primary" type="submit" data-testid="business-login-submit">Entrar</button>
        <a class="btn btn-link" asp-page="/Business/ForgotPassword" data-testid="business-forgot-password-link">Olvide mi contrasena</a>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
