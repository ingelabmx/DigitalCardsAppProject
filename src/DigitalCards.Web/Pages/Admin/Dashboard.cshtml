@page
@model DigitalCards.Web.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Dashboard admin";
}

<div class="p-page-header">
    <h1 class="p-page-heading" data-testid="admin-dashboard-title">@Model.AdminName</h1>
    <p class="p-page-sub">Administra negocios, clientes, soporte y operacion de app.puntelio.com.</p>
</div>

<div class="p-steps-grid mb-4" data-testid="admin-dashboard-command-strip">
    <div class="p-step">
        <span class="p-step-num">01</span>
        <a class="p-step-link" asp-page="/Admin/Businesses">
            <strong class="p-step-title">Negocios</strong>
            <span class="p-step-desc">Alta, estado y perfil.</span>
        </a>
    </div>
    <div class="p-step">
        <span class="p-step-num">02</span>
        <a class="p-step-link" asp-page="/Admin/Support">
            <strong class="p-step-title">Soporte</strong>
            <span class="p-step-desc">Diagnostico y eventos operativos.</span>
        </a>
    </div>
    <div class="p-step">
        <span class="p-step-num">03</span>
        <a class="p-step-link" asp-page="/Admin/Clients">
            <strong class="p-step-title">Clientes</strong>
            <span class="p-step-desc">Consulta y limpieza de pruebas.</span>
        </a>
    </div>
</div>

<div class="p-card" data-testid="admin-dashboard-next-steps">
    <span class="p-eyebrow">Siguiente paso</span>
    <h2 class="p-page-heading" style="font-size:20px">Prepara un negocio para operar en Puntelio</h2>
    <p class="p-page-sub">Si todavia no hay negocios activos, crea uno o activa un negocio existente. Despues valida branding, soporte y smoke real desde esta misma consola.</p>
    <div class="d-flex gap-2 mt-3">
        <a class="btn btn-primary" asp-page="/Admin/Businesses">Administrar negocios</a>
        <a class="btn btn-outline-secondary" asp-page="/Admin/Support">Revisar soporte</a>
    </div>
</div>
