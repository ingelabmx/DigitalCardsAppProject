@page
@model DigitalCards.Web.Pages.Admin.ClientsModel
@{
    ViewData["Title"] = "Clientes";
}

<div class="p-card">
    <div class="p-page-header mb-4">
        <div>
            <h1 class="p-page-heading">Clientes</h1>
            <p class="p-page-sub">Consulta clientes, sus tarjetas por negocio y opera la limpieza de pruebas desde un solo panel.</p>
        </div>
    </div>

    <div class="danger-action-panel danger-zone-card admin-client-cleanup-note" data-testid="admin-client-cleanup-note">
        <div>
            <strong>Clientes y limpieza de pruebas</strong>
            <p>Busca el cliente, abre su detalle y elimina su cuenta global, tarjetas, links Wallet y datos relacionados. Esta herramienta no borra negocios.</p>
        </div>
    </div>

    <div class="admin-filter-card">
        <form method="get" class="business-table-controls" data-testid="admin-client-search-form">
            <div class="business-table-control-group grow">
                <label asp-for="Query" class="form-label visually-hidden"></label>
                <input asp-for="Query" class="form-control" placeholder="usuario, correo, nombre o apellido" data-testid="admin-client-search-input" />
            </div>
            <div class="business-table-control-group">
                <label asp-for="PageSize" class="form-label mb-0">Mostrar</label>
                <select asp-for="PageSize" class="form-select form-select-sm" onchange="this.form.submit()" data-testid="admin-client-page-size">
                    <option value="10">10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                </select>
            </div>
            <button class="btn btn-primary" type="submit" data-testid="admin-client-search-submit">Buscar</button>
        </form>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @if (Model.StatusMessage is not null)
    {
        <div class="alert alert-success" role="status" data-testid="admin-client-status">
            @Model.StatusMessage
        </div>
    }

    @if (Model.PagedClients.Count == 0)
    {
        <p class="text-muted" data-testid="admin-client-no-results">No se encontraron clientes.</p>
    }
    else
    {
        <div class="table-responsive business-table-shell" data-testid="admin-client-table">
            <table class="table align-middle p-table mb-0">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Usuario</th>
                        <th>Correo</th>
                        <th>Negocios ligados</th>
                        <th>Tarjetas</th>
                        <th>Sellos</th>
                        <th>Ultima actividad</th>
                        <th class="text-end">Administrar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var client in Model.PagedClients)
                    {
                        <tr data-testid="admin-client-row">
                            <td>@client.ClientName</td>
                            <td>@client.UserName</td>
                            <td>@client.ClientEmail</td>
                            <td>@string.Join(", ", client.LinkedBusinessNames)</td>
                            <td>@client.CardCount</td>
                            <td>@client.CurrentStamps / @client.LifetimeStamps</td>
                            <td>@(client.LastActivityAt?.ToLocalTime().ToString("g") ?? "Sin actividad")</td>
                            <td class="text-end">
                                <a class="btn btn-outline-primary btn-sm"
                                   asp-page="/Admin/Clients"
                                   asp-route-clientId="@client.ClientId"
                                   asp-route-query="@Model.Query"
                                   asp-route-pageNumber="@Model.PageNumber"
                                   asp-route-pageSize="@Model.PageSize"
                                   data-testid="admin-client-manage-link">
                                    Administrar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="table-pager" data-testid="admin-client-pager">
            <span>Pagina @Model.PageNumber de @Model.TotalPages</span>
            <div class="table-pager-actions">
                <a class="btn btn-outline-secondary btn-sm @(Model.PageNumber <= 1 ? "disabled" : null)"
                   asp-page="/Admin/Clients"
                   asp-route-query="@Model.Query"
                   asp-route-clientId="@Model.ClientId"
                   asp-route-pageNumber="@(Model.PageNumber - 1)"
                   asp-route-pageSize="@Model.PageSize">
                    Anterior
                </a>
                <a class="btn btn-outline-secondary btn-sm @(Model.PageNumber >= Model.TotalPages ? "disabled" : null)"
                   asp-page="/Admin/Clients"
                   asp-route-query="@Model.Query"
                   asp-route-clientId="@Model.ClientId"
                   asp-route-pageNumber="@(Model.PageNumber + 1)"
                   asp-route-pageSize="@Model.PageSize">
                    Siguiente
                </a>
            </div>
        </div>
    }

    @if (Model.SelectedClient is not null)
    {
        <section class="business-dashboard-panel admin-client-detail-panel" data-testid="admin-client-detail-panel">
            <div class="detail-heading">
                <div>
                    <h2>@Model.SelectedClient.ClientName</h2>
                    <p>@Model.SelectedClient.ClientEmail · @Model.SelectedClient.UserName</p>
                </div>
                <span class="p-badge p-badge-gray">@(Model.SelectedClient.CardCount) tarjeta(s)</span>
            </div>

            @if (Model.SelectedClient.Cards.Count == 0)
            {
                <p class="text-muted" data-testid="admin-client-no-cards">Este cliente no tiene tarjetas asociadas.</p>
            }
            else
            {
                <div class="table-responsive" data-testid="admin-client-card-list">
                    <table class="table align-middle p-table mb-0">
                        <thead>
                            <tr>
                                <th>Negocio</th>
                                <th>Sellos</th>
                                <th>Historico</th>
                                <th>Estado</th>
                                <th>Ultima actividad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var card in Model.SelectedClient.Cards)
                            {
                                <tr data-testid="admin-client-card-row">
                                    <td>
                                        <a asp-page="/Admin/BusinessProfile" asp-route-businessId="@card.BusinessId">@card.BusinessName</a>
                                    </td>
                                    <td>@card.CurrentStamps</td>
                                    <td>@card.LifetimeStamps</td>
                                    <td><span class="status-pill">@card.CardStatus</span></td>
                                    <td>@card.LastActivityAt.ToLocalTime().ToString("g")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <form method="post"
                  asp-page-handler="Delete"
                  asp-route-clientId="@Model.SelectedClient.ClientId"
                  asp-route-query="@Model.Query"
                  asp-route-pageNumber="@Model.PageNumber"
                  asp-route-pageSize="@Model.PageSize"
                  class="danger-action-panel danger-zone-card admin-client-delete-form"
                  data-testid="admin-client-delete-form">
                <div>
                    <strong>Eliminar permanentemente</strong>
                    <p>Eliminar cliente borra cuenta global, tarjetas, links Wallet y datos relacionados; no borra negocios.</p>
                </div>
                <div class="danger-action-controls">
                    <input class="form-control form-control-sm"
                           name="confirmation"
                           placeholder="Escribe @Model.SelectedClient.UserName"
                           data-testid="admin-client-delete-confirmation" />
                    <button class="btn btn-outline-danger btn-sm" type="submit" data-testid="admin-client-delete-submit">
                        Eliminar cliente
                    </button>
                </div>
            </form>
        </section>
    }
</div>
