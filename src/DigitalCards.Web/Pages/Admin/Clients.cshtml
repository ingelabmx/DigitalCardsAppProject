@page
@model DigitalCards.Web.Pages.Admin.ClientsModel
@{
    ViewData["Title"] = "Clientes";
}

<section class="result-panel">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Admin</p>
            <h1>Clientes</h1>
            <p class="lead">Consulta clientes y deja que cada negocio administre sus asociaciones desde Tarjetas.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-page="/Admin/Dashboard" data-testid="admin-clients-back-link">Dashboard</a>
    </div>

    <div class="alert alert-info" role="status" data-testid="admin-client-allowlist-retired">
        La activacion operativa se controla por negocio. Usa esta vista para consultar clientes y limpiar cuentas de prueba de forma permanente.
    </div>

    <div class="danger-action-panel danger-zone-card admin-client-cleanup-note" data-testid="admin-client-cleanup-note">
        <div>
            <strong>Limpieza de clientes de prueba</strong>
            <p>Busca el cliente, confirma con su usuario o correo y elimina su cuenta global, tarjetas, links Wallet y datos relacionados. Esta accion no borra negocios.</p>
        </div>
    </div>

    <form method="get" class="search-row" data-testid="admin-client-search-form">
        <label asp-for="Query" class="form-label visually-hidden"></label>
        <input asp-for="Query" class="form-control" placeholder="usuario, correo, nombre o apellido" data-testid="admin-client-search-input" />
        <button class="btn btn-primary" type="submit" data-testid="admin-client-search-submit">Buscar</button>
    </form>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @if (Model.StatusMessage is not null)
    {
        <div class="alert alert-success" role="status" data-testid="admin-client-status">
            @Model.StatusMessage
        </div>
    }

    @if (Model.Clients.Count == 0)
    {
        <p class="text-muted" data-testid="admin-client-no-results">No se encontraron clientes.</p>
    }
    else
    {
        <div class="pilot-business-list legacy-admin-list" data-testid="admin-client-list">
            @foreach (var client in Model.Clients)
            {
                <article class="pilot-business-item legacy-admin-row" data-testid="admin-client-row">
                    <div>
                        <h2>@client.UserName</h2>
                        <p>@client.ClientEmail</p>
                        <small>@client.ClientName</small>
                    </div>
                    <div>
                        <span class="badge text-bg-info" data-testid="admin-client-pilot-status">
                            Operable por negocio habilitado
                        </span>
                        @if (client.UpdatedAt is not null)
                        {
                            <small>Registro operativo actualizado @client.UpdatedAt.Value.ToLocalTime().ToString("g")</small>
                        }
                    </div>
                    <p class="text-muted mb-0">Para permitir operacion, activa el negocio desde <a asp-page="/Admin/Businesses">Negocios</a>.</p>
                    <form method="post"
                          asp-page-handler="Delete"
                          asp-route-clientId="@client.ClientId"
                          class="danger-action-panel danger-zone-card admin-client-delete-form"
                          data-testid="admin-client-delete-form">
                        <div>
                            <strong>Eliminar permanentemente</strong>
                            <p>Eliminar cliente borra cuenta global, tarjetas, links Wallet y datos relacionados; no borra negocios.</p>
                        </div>
                        <div class="danger-action-controls">
                            <input class="form-control form-control-sm"
                                   name="confirmation"
                                   placeholder="Escribe @client.UserName"
                                   data-testid="admin-client-delete-confirmation" />
                            <button class="btn btn-outline-danger btn-sm" type="submit" data-testid="admin-client-delete-submit">
                                Eliminar cliente
                            </button>
                        </div>
                    </form>
                </article>
            }
        </div>
    }
</section>
