@page
@model DigitalCards.Web.Pages.Admin.ClientsModel
@{
    ViewData["Title"] = "Clientes";
}

<section class="result-panel">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Admin</p>
            <h1>Clientes</h1>
            <p class="lead">Consulta clientes, tarjetas asociadas, sellos y estado operativo sin exponer datos sensibles.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-page="/Admin/Dashboard" data-testid="admin-clients-back-link">Dashboard</a>
    </div>

    <div class="danger-action-panel danger-zone-card admin-client-cleanup-note" data-testid="admin-client-cleanup-note">
        <div>
            <strong>Clientes y limpieza de pruebas</strong>
            <p>Busca el cliente, confirma con su usuario o correo y elimina su cuenta global, tarjetas, links Wallet y datos relacionados. Esta herramienta sirve para limpiar clientes de prueba y no borra negocios.</p>
        </div>
    </div>

    <form method="get" class="search-row" data-testid="admin-client-search-form">
        <label asp-for="Query" class="form-label visually-hidden"></label>
        <input asp-for="Query" class="form-control" placeholder="usuario, correo, nombre o apellido" data-testid="admin-client-search-input" />
        <button class="btn btn-primary" type="submit" data-testid="admin-client-search-submit">Buscar</button>
    </form>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @if (Model.StatusMessage is not null)
    {
        <div class="alert alert-success" role="status" data-testid="admin-client-status">
            @Model.StatusMessage
        </div>
    }

    @if (Model.Clients.Count == 0)
    {
        <p class="text-muted" data-testid="admin-client-no-results">No se encontraron clientes.</p>
    }
    else
    {
        <div class="pilot-business-list legacy-admin-list admin-client-console-list" data-testid="admin-client-list">
            @foreach (var client in Model.Clients)
            {
                <article class="pilot-business-item legacy-admin-row" data-testid="admin-client-row">
                    <div class="admin-client-console-header">
                        <div>
                            <h2>@client.ClientName</h2>
                            <p>@client.ClientEmail</p>
                            <small>@client.UserName</small>
                        </div>
                        <div class="admin-client-console-stats">
                            <span><strong>@client.CardCount</strong> tarjeta(s)</span>
                            <span><strong>@client.CurrentStamps</strong> sellos actuales</span>
                            <span><strong>@client.LifetimeStamps</strong> sellos historicos</span>
                            <span><strong>@(client.LastActivityAt?.ToLocalTime().ToString("g") ?? "Sin actividad")</strong> ultima actividad</span>
                        </div>
                    </div>

                    @if (client.Cards.Count == 0)
                    {
                        <p class="text-muted mb-0" data-testid="admin-client-no-cards">Este cliente no tiene tarjetas asociadas.</p>
                    }
                    else
                    {
                        <div class="table-responsive" data-testid="admin-client-card-list">
                            <table class="table align-middle legacy-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Negocio</th>
                                        <th>Sellos</th>
                                        <th>Historico</th>
                                        <th>Estado</th>
                                        <th>Ultima actividad</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var card in client.Cards)
                                    {
                                        <tr data-testid="admin-client-card-row">
                                            <td>
                                                <a asp-page="/Admin/BusinessProfile" asp-route-businessId="@card.BusinessId">@card.BusinessName</a>
                                            </td>
                                            <td>@card.CurrentStamps</td>
                                            <td>@card.LifetimeStamps</td>
                                            <td><span class="status-pill">@card.CardStatus</span></td>
                                            <td>@card.LastActivityAt.ToLocalTime().ToString("g")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <form method="post"
                          asp-page-handler="Delete"
                          asp-route-clientId="@client.ClientId"
                          class="danger-action-panel danger-zone-card admin-client-delete-form"
                          data-testid="admin-client-delete-form">
                        <div>
                            <strong>Eliminar permanentemente</strong>
                            <p>Eliminar cliente borra cuenta global, tarjetas, links Wallet y datos relacionados; no borra negocios.</p>
                        </div>
                        <div class="danger-action-controls">
                            <input class="form-control form-control-sm"
                                   name="confirmation"
                                   placeholder="Escribe @client.UserName"
                                   data-testid="admin-client-delete-confirmation" />
                            <button class="btn btn-outline-danger btn-sm" type="submit" data-testid="admin-client-delete-submit">
                                Eliminar cliente
                            </button>
                        </div>
                    </form>
                </article>
            }
        </div>
    }
</section>
