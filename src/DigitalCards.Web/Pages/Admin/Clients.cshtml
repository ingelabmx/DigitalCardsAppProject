@page
@model DigitalCards.Web.Pages.Admin.ClientsModel
@{
    ViewData["Title"] = "Clientes";
}

<section class="result-panel">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Admin</p>
            <h1>Clientes</h1>
            <p class="lead">El acceso moderno ya no se controla por allowlist de cliente. Habilita el negocio piloto y deja que el negocio asocie clientes desde su flujo.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-page="/Admin/Dashboard" data-testid="admin-clients-back-link">Dashboard</a>
    </div>

    <div class="alert alert-info" role="status" data-testid="admin-client-allowlist-retired">
        La allowlist de clientes quedo retirada del flujo operativo. Esta vista queda solo como consulta segura de clientes legacy.
    </div>

    <form method="get" class="search-row" data-testid="admin-client-search-form">
        <label asp-for="Query" class="form-label visually-hidden"></label>
        <input asp-for="Query" class="form-control" placeholder="usuario, correo, nombre o apellido" data-testid="admin-client-search-input" />
        <button class="btn btn-primary" type="submit" data-testid="admin-client-search-submit">Buscar</button>
    </form>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @if (Model.StatusMessage is not null)
    {
        <div class="alert alert-success" role="status" data-testid="admin-client-status">
            @Model.StatusMessage
        </div>
    }

    @if (Model.Clients.Count == 0)
    {
        <p class="text-muted" data-testid="admin-client-no-results">No se encontraron clientes.</p>
    }
    else
    {
        <div class="pilot-business-list legacy-admin-list" data-testid="admin-client-list">
            @foreach (var client in Model.Clients)
            {
                <article class="pilot-business-item legacy-admin-row" data-testid="admin-client-row">
                    <div>
                        <h2>@client.UserName</h2>
                        <p>@client.ClientEmail</p>
                        <small>@client.ClientName</small>
                    </div>
                    <div>
                        <span class="badge text-bg-info" data-testid="admin-client-pilot-status">
                            Operable por negocio habilitado
                        </span>
                        @if (client.UpdatedAt is not null)
                        {
                            <small>Registro piloto historico actualizado @client.UpdatedAt.Value.ToLocalTime().ToString("g")</small>
                        }
                    </div>
                    <p class="text-muted mb-0">Para permitir operacion moderna, habilita el negocio desde <a asp-page="/Admin/Businesses">Negocios</a>.</p>
                </article>
            }
        </div>
    }
</section>
