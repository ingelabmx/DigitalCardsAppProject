@page
@model DigitalCards.Web.Pages.Admin.ClientsModel
@{
    ViewData["Title"] = "Clientes piloto";
}

<section class="result-panel">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Admin</p>
            <h1>Clientes piloto</h1>
            <p class="lead">Habilita o deshabilita clientes existentes para operar el flujo moderno.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-page="/Admin/Dashboard" data-testid="admin-clients-back-link">Dashboard</a>
    </div>

    <form method="get" class="search-row" data-testid="admin-client-search-form">
        <label asp-for="Query" class="form-label visually-hidden"></label>
        <input asp-for="Query" class="form-control" placeholder="usuario, correo, nombre o apellido" data-testid="admin-client-search-input" />
        <button class="btn btn-primary" type="submit" data-testid="admin-client-search-submit">Buscar</button>
    </form>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @if (Model.StatusMessage is not null)
    {
        <div class="alert alert-success" role="status" data-testid="admin-client-status">
            @Model.StatusMessage
        </div>
    }

    @if (Model.Clients.Count == 0)
    {
        <p class="text-muted" data-testid="admin-client-no-results">No se encontraron clientes.</p>
    }
    else
    {
        <div class="pilot-business-list legacy-admin-list" data-testid="admin-client-list">
            @foreach (var client in Model.Clients)
            {
                <article class="pilot-business-item legacy-admin-row" data-testid="admin-client-row">
                    <div>
                        <h2>@client.UserName</h2>
                        <p>@client.ClientEmail</p>
                        <small>@client.ClientName</small>
                    </div>
                    <div>
                        <span class="badge @(client.IsEnabled ? "text-bg-success" : "text-bg-secondary")" data-testid="admin-client-pilot-status">
                            @(client.IsEnabled ? "Piloto habilitado" : "Piloto deshabilitado")
                        </span>
                        @if (client.UpdatedAt is not null)
                        {
                            <small>Actualizado @client.UpdatedAt.Value.ToLocalTime().ToString("g")</small>
                        }
                    </div>
                    <form method="post" asp-page-handler="Enable" asp-route-query="@Model.Query" class="pilot-business-form">
                        <input type="hidden" name="clientId" value="@client.ClientId" />
                        <label class="form-label" for="enable-client-notes-@client.ClientId">Notas</label>
                        <textarea id="enable-client-notes-@client.ClientId" name="notes" class="form-control" rows="2" data-testid="admin-client-notes">@client.Notes</textarea>
                        <button class="btn btn-primary" type="submit" data-testid="admin-enable-client-pilot">Habilitar piloto</button>
                    </form>
                    <form method="post" asp-page-handler="Disable" asp-route-query="@Model.Query" class="pilot-business-inline-form">
                        <input type="hidden" name="clientId" value="@client.ClientId" />
                        <input type="hidden" name="notes" value="@client.Notes" />
                        <button class="btn btn-outline-danger" type="submit" data-testid="admin-disable-client-pilot">Deshabilitar piloto</button>
                    </form>
                </article>
            }
        </div>
    }
</section>
