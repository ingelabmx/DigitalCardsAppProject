@page
@model DigitalCards.Web.Pages.Admin.BusinessesModel
@{
    ViewData["Title"] = "Negocios";
}

<section class="result-panel admin-list-panel" data-testid="admin-businesses-panel">
    <div class="page-heading">
        <div>
            <h1>Negocios</h1>
            <p class="lead">Consulta negocios activos e inactivos y abre su administracion desde una tabla compacta.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-primary" asp-page="/Admin/CreateBusiness" data-testid="admin-businesses-create-link">Crear negocio</a>
            <a class="btn btn-outline-secondary" asp-page="/Admin/Dashboard" data-testid="admin-businesses-back-link">Dashboard</a>
        </div>
    </div>

    <div class="admin-filter-card">
        <form method="get" class="business-table-controls" data-testid="admin-business-search-form">
            <div class="business-table-control-group grow">
                <label asp-for="Query" class="form-label visually-hidden"></label>
                <input asp-for="Query" class="form-control" placeholder="nombre o correo del negocio" data-testid="admin-business-search-input" />
            </div>
            <div class="business-table-control-group">
                <label asp-for="PageSize" class="form-label mb-0">Mostrar</label>
                <select asp-for="PageSize" class="form-select form-select-sm" onchange="this.form.submit()" data-testid="admin-business-page-size">
                    <option value="10">10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                </select>
            </div>
            <button class="btn btn-primary" type="submit" data-testid="admin-business-search-submit">Buscar</button>
        </form>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @if (Model.StatusMessage is not null)
    {
        <div class="alert alert-success" role="status" data-testid="admin-business-status">
            @Model.StatusMessage
        </div>
    }

    @if (Model.PagedBusinesses.Count == 0)
    {
        <div class="dashboard-empty-state compact" data-testid="admin-business-no-results">
            <h3>No se encontraron negocios</h3>
            <p>Prueba con otro nombre o correo, o crea un negocio nuevo desde el panel admin.</p>
            <a class="btn btn-primary btn-sm" asp-page="/Admin/CreateBusiness">Crear negocio</a>
        </div>
    }
    else
    {
        <div class="table-responsive business-table-shell" data-testid="admin-business-table">
            <table class="table align-middle legacy-table mb-0">
                <thead>
                    <tr>
                        <th>Negocio</th>
                        <th>Correo</th>
                        <th>Clientes</th>
                        <th>Sellos</th>
                        <th>Estado</th>
                        <th>Actualizado</th>
                        <th class="text-end">Administrar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var business in Model.PagedBusinesses)
                    {
                        <tr data-testid="admin-business-row">
                            <td>@business.BusinessName</td>
                            <td>@business.BusinessEmail</td>
                            <td>@business.ClientCount</td>
                            <td>@business.CurrentStampTotal</td>
                            <td>
                                <span class="badge @(business.IsEnabled ? "text-bg-success" : "text-bg-secondary")" data-testid="admin-business-activation-status">
                                    @ActivationLabel(business.IsEnabled)
                                </span>
                            </td>
                            <td>@(business.UpdatedAt?.ToLocalTime().ToString("g") ?? "Sin cambios")</td>
                            <td class="text-end">
                                <a class="btn btn-outline-primary btn-sm"
                                   asp-page="/Admin/BusinessProfile"
                                   asp-route-businessId="@business.BusinessId"
                                   data-testid="admin-manage-business">
                                    Administrar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="table-pager" data-testid="admin-business-pager">
            <span>Pagina @Model.PageNumber de @Model.TotalPages</span>
            <div class="table-pager-actions">
                <a class="btn btn-outline-secondary btn-sm @(Model.PageNumber <= 1 ? "disabled" : null)"
                   asp-page="/Admin/Businesses"
                   asp-route-query="@Model.Query"
                   asp-route-pageNumber="@(Model.PageNumber - 1)"
                   asp-route-pageSize="@Model.PageSize">
                    Anterior
                </a>
                <a class="btn btn-outline-secondary btn-sm @(Model.PageNumber >= Model.TotalPages ? "disabled" : null)"
                   asp-page="/Admin/Businesses"
                   asp-route-query="@Model.Query"
                   asp-route-pageNumber="@(Model.PageNumber + 1)"
                   asp-route-pageSize="@Model.PageSize">
                    Siguiente
                </a>
            </div>
        </div>
    }
</section>

@functions {
    private static string ActivationLabel(bool isEnabled)
    {
        return isEnabled ? "Activo" : "Inactivo";
    }
}
