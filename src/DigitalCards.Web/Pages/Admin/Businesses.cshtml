@page
@model DigitalCards.Web.Pages.Admin.BusinessesModel
@{
    ViewData["Title"] = "Negocios";
}

<div class="p-card" data-testid="admin-businesses-panel">
    <div class="p-page-header mb-4">
        <div>
            <h1 class="p-page-heading">Negocios</h1>
            <p class="p-page-sub">Consulta negocios activos e inactivos y abre su administracion desde una tabla compacta.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-primary" asp-page="/Admin/CreateBusiness" data-testid="admin-businesses-create-link">Crear negocio</a>
        </div>
    </div>

    <div class="admin-filter-card">
        <form method="get" class="business-table-controls" data-testid="admin-business-search-form">
            <div class="business-table-control-group grow">
                <label asp-for="Query" class="form-label visually-hidden"></label>
                <input asp-for="Query" class="form-control" placeholder="nombre o correo del negocio" data-testid="admin-business-search-input" />
            </div>
            <div class="business-table-control-group">
                <label asp-for="PageSize" class="form-label mb-0">Mostrar</label>
                <select asp-for="PageSize" class="form-select form-select-sm" onchange="this.form.submit()" data-testid="admin-business-page-size">
                    <option value="10">10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                </select>
            </div>
            <button class="btn btn-primary" type="submit" data-testid="admin-business-search-submit">Buscar</button>
        </form>
        <div class="d-flex gap-2 flex-wrap mt-2" data-testid="admin-business-sub-filter">
            @{
                var filters = new[] {
                    (Key: (string?)null,     Label: "Todos"),
                    (Key: "active",          Label: "Activos"),
                    (Key: "past_due",        Label: "Atrasados"),
                    (Key: "none",            Label: "Sin plan"),
                };
            }
            @foreach (var f in filters)
            {
                var isActive = Model.SubscriptionFilter == f.Key;
                <a class="p-btn p-btn-sm @(isActive ? "p-btn-primary" : "p-btn-outline")"
                   asp-page="/Admin/Businesses"
                   asp-route-query="@Model.Query"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-subscriptionFilter="@f.Key">
                    @f.Label
                </a>
            }
        </div>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @if (Model.StatusMessage is not null)
    {
        <div class="alert alert-success" role="status" data-testid="admin-business-status">
            @Model.StatusMessage
        </div>
    }

    @if (Model.PagedBusinesses.Count == 0)
    {
        <div class="p-empty" data-testid="admin-business-no-results">
            <h3>No se encontraron negocios</h3>
            <p>Prueba con otro nombre o correo, o crea un negocio nuevo desde el panel admin.</p>
            <a class="btn btn-primary btn-sm" asp-page="/Admin/CreateBusiness">Crear negocio</a>
        </div>
    }
    else
    {
        <div class="table-responsive business-table-shell" data-testid="admin-business-table">
            <table class="table align-middle p-table mb-0">
                <thead>
                    <tr>
                        <th>Negocio</th>
                        <th>Correo</th>
                        <th>Clientes</th>
                        <th>Sellos</th>
                        <th>Estado</th>
                        <th>Plan</th>
                        <th>Suscripcion</th>
                        <th>Actualizado</th>
                        <th class="text-end">Administrar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var business in Model.PagedBusinesses)
                    {
                        <tr data-testid="admin-business-row">
                            <td>@business.BusinessName</td>
                            <td>@business.BusinessEmail</td>
                            <td>@business.ClientCount</td>
                            <td>@business.CurrentStampTotal</td>
                            <td>
                                <span class="p-badge @(business.IsEnabled ? "p-badge-green" : "p-badge-gray")" data-testid="admin-business-activation-status">
                                    @ActivationLabel(business.IsEnabled)
                                </span>
                            </td>
                            <td>
                                <span class="p-badge @PlanBadgeClass(business.StripePlanKey)">
                                    @PlanLabel(business.StripePlanKey)
                                </span>
                            </td>
                            <td>
                                <span class="p-badge @SubBadgeClass(business.SubscriptionStatus, business.GraceEndsAt)">
                                    @SubLabel(business.SubscriptionStatus, business.GraceEndsAt)
                                </span>
                            </td>
                            <td>@(business.UpdatedAt?.ToLocalTime().ToString("g") ?? "Sin cambios")</td>
                            <td class="text-end">
                                <a class="btn btn-outline-primary btn-sm"
                                   asp-page="/Admin/BusinessProfile"
                                   asp-route-businessId="@business.BusinessId"
                                   data-testid="admin-manage-business">
                                    Administrar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="table-pager" data-testid="admin-business-pager">
            <span>Pagina @Model.PageNumber de @Model.TotalPages</span>
            <div class="table-pager-actions">
                <a class="btn btn-outline-secondary btn-sm @(Model.PageNumber <= 1 ? "disabled" : null)"
                   asp-page="/Admin/Businesses"
                   asp-route-query="@Model.Query"
                   asp-route-pageNumber="@(Model.PageNumber - 1)"
                   asp-route-pageSize="@Model.PageSize">
                    Anterior
                </a>
                <a class="btn btn-outline-secondary btn-sm @(Model.PageNumber >= Model.TotalPages ? "disabled" : null)"
                   asp-page="/Admin/Businesses"
                   asp-route-query="@Model.Query"
                   asp-route-pageNumber="@(Model.PageNumber + 1)"
                   asp-route-pageSize="@Model.PageSize">
                    Siguiente
                </a>
            </div>
        </div>
    }
</div>

@if (Model.AbandonedSignups.Count > 0)
{
    <div class="p-card mt-4" data-testid="admin-abandoned-signups-panel">
        <div class="p-page-header mb-3">
            <div>
                <h2 class="p-page-heading" style="font-size:1.25rem;">Registros pendientes de pago</h2>
                <p class="p-page-sub">Negocios creados que no completaron el pago en Stripe.</p>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table align-middle p-table mb-0" data-testid="admin-abandoned-table">
                <thead>
                    <tr>
                        <th>Negocio</th>
                        <th>Correo</th>
                        <th>Plan</th>
                        <th>Fecha registro</th>
                        <th class="text-end">Accion</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var signup in Model.AbandonedSignups)
                    {
                        <tr data-testid="admin-abandoned-row">
                            <td>@signup.BusinessName</td>
                            <td>@signup.BusinessEmail</td>
                            <td>@(signup.PlanKey ?? "—")</td>
                            <td>@signup.CreatedAt.ToLocalTime().ToString("g")</td>
                            <td class="text-end">
                                <form method="post" asp-page-handler="ResendPaymentLink" style="display:inline;">
                                    <input type="hidden" name="businessId" value="@signup.BusinessId" />
                                    <button class="btn btn-outline-primary btn-sm" type="submit" data-testid="admin-abandoned-resend">
                                        Reenviar link de pago
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@functions {
    private static string ActivationLabel(bool isEnabled) => isEnabled ? "Activo" : "Inactivo";

    private static string PlanBadgeClass(string? planKey) => planKey switch
    {
        null       => "p-badge-gray",
        "Manual"   => "p-badge-gray",
        "Basic"    => "p-badge-blue",
        "Pro"      => "p-badge-black",
        "Business" => "p-badge-black",
        _          => "p-badge-blue"
    };

    private static string PlanLabel(string? planKey) => planKey switch
    {
        null       => "Sin plan",
        "Manual"   => "Manual",
        "Basic"    => "Basico",
        "Pro"      => "Pro",
        "Business" => "Empresarial",
        _          => planKey
    };

    private static string SubBadgeClass(string? status, DateTimeOffset? graceEndsAt) => status switch
    {
        "active"   => "p-badge-green",
        "manual"   => "p-badge-black",
        "past_due" => graceEndsAt.HasValue && graceEndsAt.Value < DateTimeOffset.UtcNow ? "p-badge-red" : "p-badge-amber",
        "canceled" => "p-badge-red",
        _          => "p-badge-gray"
    };

    private static string SubLabel(string? status, DateTimeOffset? graceEndsAt)
    {
        return status switch
        {
            "active"   => "Activa",
            "manual"   => "Manual",
            "past_due" => graceEndsAt.HasValue
                ? $"Atrasado (gracia hasta {graceEndsAt.Value.ToLocalTime():d})"
                : "Atrasado",
            "canceled" => "Cancelada",
            _          => "Sin suscripcion"
        };
    }
}
