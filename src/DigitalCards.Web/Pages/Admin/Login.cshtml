@page
@model DigitalCards.Web.Pages.Admin.LoginModel
@{
    ViewData["Title"] = "Login admin";
}

<section class="auth-gateway auth-gateway-admin">
    <div class="auth-copy-panel">
        <p class="eyebrow">Administracion</p>
        <h1>Centro de control Puntelio</h1>
        <p>
            Gestiona negocios, soporte, auditoria y cutover desde el panel moderno.
        </p>
        <a class="auth-home-link" asp-page="/Index">Volver al inicio</a>
    </div>

    <div class="auth-form-card">
        <div class="auth-form-heading">
            <span class="auth-role-mark">AD</span>
            <div>
                <h2>Entrar como admin</h2>
                <p>Usa tu cuenta administrativa autorizada.</p>
            </div>
        </div>

        <form method="post" data-testid="admin-login-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Input.UserNameOrEmail" class="form-label"></label>
                <input asp-for="Input.UserNameOrEmail" class="form-control form-control-lg" data-testid="admin-username" />
                <span asp-validation-for="Input.UserNameOrEmail" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" class="form-control form-control-lg" data-testid="admin-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <button class="btn btn-primary btn-lg w-100" type="submit" data-testid="admin-login-submit">Entrar al panel</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
