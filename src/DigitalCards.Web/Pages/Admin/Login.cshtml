@page
@model DigitalCards.Web.Pages.Admin.LoginModel
@{
    ViewData["Title"] = "Login admin";
}

<section class="form-panel">
    <h1>Login admin</h1>
    <p class="text-muted">Acceso para administrar el piloto moderno de negocios.</p>

    <form method="post" data-testid="admin-login-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Input.UserNameOrEmail" class="form-label"></label>
            <input asp-for="Input.UserNameOrEmail" class="form-control" data-testid="admin-username" />
            <span asp-validation-for="Input.UserNameOrEmail" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Password" class="form-label"></label>
            <input asp-for="Input.Password" class="form-control" data-testid="admin-password" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <button class="btn btn-primary" type="submit" data-testid="admin-login-submit">Entrar</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
