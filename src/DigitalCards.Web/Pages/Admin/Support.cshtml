@page
@model DigitalCards.Web.Pages.Admin.SupportModel
@{
    ViewData["Title"] = "Soporte admin";
}

<section class="result-panel">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Admin</p>
            <h1>Soporte</h1>
            <p class="lead">Diagnostico seguro por cliente, negocio o tarjeta. No muestra tokens, passwords, hashes ni credenciales.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-page="/Admin/Dashboard" data-testid="admin-support-back-link">Dashboard</a>
    </div>

    <form method="get" class="support-filter-panel" data-testid="admin-support-search-form">
        <div class="search-row">
            <label asp-for="Query" class="form-label visually-hidden"></label>
            <input asp-for="Query" class="form-control" placeholder="usuario, correo, negocio, CardID o URL Wallet" data-testid="admin-support-search-input" />
            <button class="btn btn-primary" type="submit" data-testid="admin-support-search-submit">Buscar</button>
        </div>
        <div class="support-filter-grid" data-testid="admin-support-filters">
            <div>
                <label asp-for="BusinessFilter" class="form-label">Negocio</label>
                <input asp-for="BusinessFilter" class="form-control" placeholder="nombre o email" data-testid="admin-support-business-filter" />
            </div>
            <div>
                <label asp-for="ClientFilter" class="form-label">Cliente</label>
                <input asp-for="ClientFilter" class="form-control" placeholder="username o email" data-testid="admin-support-client-filter" />
            </div>
            <div>
                <label asp-for="From" class="form-label">Desde</label>
                <input asp-for="From" class="form-control" type="date" data-testid="admin-support-from-filter" />
            </div>
            <div>
                <label asp-for="To" class="form-label">Hasta</label>
                <input asp-for="To" class="form-control" type="date" data-testid="admin-support-to-filter" />
            </div>
        </div>
        <div class="form-check">
            <input asp-for="WalletIssuesOnly" class="form-check-input" data-testid="admin-support-wallet-issues-filter" />
            <label asp-for="WalletIssuesOnly" class="form-check-label">Mostrar solo tarjetas con alertas Wallet recientes</label>
        </div>
    </form>

    <div class="support-sync-status" data-testid="admin-support-sync-status">
        <strong>LegacyWalletSync:</strong>
        @(Model.LegacyWalletSync.Enabled ? "Activo" : "Apagado")
        <span>Intervalo @Model.LegacyWalletSync.PollIntervalSeconds s</span>
        <span>Lookback @Model.LegacyWalletSync.LookbackMinutes min</span>
        <span>Batch @Model.LegacyWalletSync.BatchSize</span>
        <span data-testid="admin-support-sync-last-run">
            Ultimo run:
            @(Model.LegacyWalletSyncState.LastCompletedAt?.ToLocalTime().ToString("g") ?? "no ejecutado")
        </span>
        @if (Model.LegacyWalletSyncState.LastResult is not null)
        {
            <span data-testid="admin-support-sync-last-result">
                Procesados @Model.LegacyWalletSyncState.LastResult.Synced /
                candidatos @Model.LegacyWalletSyncState.LastResult.Candidates /
                fallos @Model.LegacyWalletSyncState.LastResult.Failed
            </span>
        }
        @if (Model.LegacyWalletSyncState.LastErrorSummary is not null)
        {
            <span class="text-danger" data-testid="admin-support-sync-last-error">
                Ultimo error seguro: @Model.LegacyWalletSyncState.LastErrorSummary
            </span>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status" data-testid="admin-support-status-message">
            @Model.StatusMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-warning" role="alert" data-testid="admin-support-error-message">
            @Model.ErrorMessage
        </div>
    }

    @if (Model.Result is not null)
    {
        <section class="support-results" data-testid="admin-support-results">
            <div class="metric-row">
                <div class="metric">
                    <span>Clientes</span>
                    <strong data-testid="admin-support-client-count">@Model.Result.Clients.Count</strong>
                </div>
                <div class="metric">
                    <span>Negocios</span>
                    <strong data-testid="admin-support-business-count">@Model.Result.Businesses.Count</strong>
                </div>
                <div class="metric">
                    <span>Tarjetas</span>
                    <strong data-testid="admin-support-card-count">@Model.Result.Cards.Count</strong>
                </div>
            </div>

            <div class="form-actions">
                <a class="btn btn-outline-primary"
                   asp-page-handler="Export"
                   asp-route-Query="@Model.Query"
                   asp-route-BusinessFilter="@Model.BusinessFilter"
                   asp-route-ClientFilter="@Model.ClientFilter"
                   asp-route-WalletIssuesOnly="@Model.WalletIssuesOnly"
                   asp-route-From="@Model.From"
                   asp-route-To="@Model.To"
                   data-testid="admin-support-export-json">Exportar diagnostico JSON</a>
                <a class="btn btn-outline-secondary"
                   asp-page-handler="ExportCsv"
                   asp-route-Query="@Model.Query"
                   asp-route-BusinessFilter="@Model.BusinessFilter"
                   asp-route-ClientFilter="@Model.ClientFilter"
                   asp-route-WalletIssuesOnly="@Model.WalletIssuesOnly"
                   asp-route-From="@Model.From"
                   asp-route-To="@Model.To"
                   data-testid="admin-support-export-csv">Exportar CSV</a>
            </div>

            @if (Model.Result.Clients.Count > 0)
            {
                <section class="business-dashboard-panel">
                    <h2>Clientes encontrados</h2>
                    <div class="dashboard-card-list" data-testid="admin-support-clients">
                        @foreach (var client in Model.Result.Clients)
                        {
                            <div class="dashboard-card-row" data-testid="admin-support-client-row">
                                <div>
                                    <strong>@client.UserName</strong>
                                    <span>@client.ClientEmail</span>
                                </div>
                                <div>
                                    <strong>@client.CardCount</strong>
                                    <span>tarjetas</span>
                                </div>
                            </div>
                        }
                    </div>
                </section>
            }

            @if (Model.Result.Businesses.Count > 0)
            {
                <section class="business-dashboard-panel">
                    <h2>Negocios encontrados</h2>
                    <div class="dashboard-card-list" data-testid="admin-support-businesses">
                        @foreach (var business in Model.Result.Businesses)
                        {
                            <div class="dashboard-card-row" data-testid="admin-support-business-row">
                                <div>
                                    <strong>@business.BusinessName</strong>
                                    <span>@business.BusinessEmail</span>
                                </div>
                                <div>
                                    <strong>@business.RecentCardCount</strong>
                                    <span>@ActivationLabel(business.ActivationStatus) &middot; @(business.IsPilotEnabled ? "piloto activo" : "piloto apagado")</span>
                                </div>
                                @if (business.ActivationStatus == DigitalCards.Domain.BusinessActivationStatus.LegacyRetired)
                                {
                                    <div class="support-safe-errors" data-testid="admin-support-legacy-retired">
                                        Legacy retirado: confirmar bloqueo manual de Web Forms para este negocio.
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </section>
            }

            @if (Model.Result.Cards.Count == 0)
            {
                <p class="text-muted" data-testid="admin-support-no-cards">No se encontraron tarjetas relacionadas.</p>
            }
            else
            {
                <section class="business-dashboard-panel">
                    <h2>Tarjetas</h2>
                    <div class="support-card-list" data-testid="admin-support-cards">
                        @foreach (var card in Model.Result.Cards)
                        {
                            <article class="support-card" data-testid="admin-support-card">
                                <div class="page-heading">
                                    <div>
                                        <p class="eyebrow">Tarjeta @SupportModel.Suffix(card.CardId)</p>
                                        <h3>@card.Client.UserName &middot; @card.Business.BusinessName</h3>
                                        <p class="text-muted">@card.Client.ClientEmail &middot; @card.Business.BusinessEmail</p>
                                    </div>
                                    <span class="badge text-bg-light">@card.CurrentStamps actuales / @card.LifetimeStamps historicos</span>
                                </div>

                                <div class="metric-row">
                                    <div class="metric">
                                        <span>Google Wallet</span>
                                        <strong data-testid="admin-support-google-state">@(card.GoogleIssued ? "Emitida" : "Pendiente")</strong>
                                        @if (!string.IsNullOrWhiteSpace(card.GoogleObjectSuffix))
                                        {
                                            <small>obj ...@card.GoogleObjectSuffix</small>
                                        }
                                    </div>
                                    <div class="metric">
                                        <span>Apple Wallet</span>
                                        <strong data-testid="admin-support-apple-state">@(card.AppleTracked ? "Instalada" : "Pendiente")</strong>
                                        <small>@card.AppleRegisteredDeviceCount dispositivo(s)</small>
                                    </div>
                                    <div class="metric">
                                        <span>Ultimo sello</span>
                                        <strong>@card.LastStampedAt.ToLocalTime().ToString("g")</strong>
                                    </div>
                                    <div class="metric">
                                        <span>Alertas Wallet</span>
                                        <strong data-testid="admin-support-wallet-issues">@card.WalletIssueCount</strong>
                                    </div>
                                </div>

                                @if (card.AppleTracked)
                                {
                                    <p class="text-muted" data-testid="admin-support-apple-detail">
                                        Apple serial ...@card.AppleSerialSuffix &middot;
                                        update tag @card.AppleUpdateTag &middot;
                                        actualizado @card.AppleUpdatedAt?.ToLocalTime().ToString("g")
                                    </p>
                                }

                                <div class="support-operational-state" data-testid="admin-support-operational-state">
                                    <span>Activacion negocio: @ActivationLabel(card.Business.ActivationStatus)</span>
                                    <span>LegacySync: @(card.LegacySyncEventCount > 0 ? $"{card.LegacySyncEventCount} evento(s)" : "sin eventos recientes")</span>
                                    @if (card.LastLegacySyncAt is not null)
                                    {
                                        <span>Ultimo legacy @card.LastLegacySyncAt?.ToLocalTime().ToString("g")</span>
                                    }
                                    <span>Errores seguros: @card.RecentSafeErrors.Count</span>
                                </div>

                                <form method="post"
                                      asp-page-handler="RetryWalletUpdate"
                                      class="form-actions"
                                      data-testid="admin-support-retry-wallet-form">
                                    <input type="hidden" name="RetryCardId" value="@card.CardId" />
                                    <input type="hidden" name="Query" value="@Model.Query" />
                                    <input type="hidden" name="BusinessFilter" value="@Model.BusinessFilter" />
                                    <input type="hidden" name="ClientFilter" value="@Model.ClientFilter" />
                                    <input type="hidden" name="WalletIssuesOnly" value="@Model.WalletIssuesOnly" />
                                    <input type="hidden" name="From" value='@Model.From?.ToString("o")' />
                                    <input type="hidden" name="To" value='@Model.To?.ToString("o")' />
                                    <button type="submit"
                                            class="btn btn-outline-primary btn-sm"
                                            data-testid="admin-support-retry-wallet">
                                        Reintentar update Wallet
                                    </button>
                                </form>

                                @if (card.RecentSafeErrors.Count > 0)
                                {
                                    <div class="support-safe-errors" data-testid="admin-support-safe-errors">
                                        <h4>Errores recientes seguros</h4>
                                        @foreach (var error in card.RecentSafeErrors)
                                        {
                                            <p>@error</p>
                                        }
                                    </div>
                                }

                                <h4>Eventos recientes</h4>
                                @if (card.RecentStampEvents.Count == 0)
                                {
                                    <p class="text-muted" data-testid="admin-support-no-ledger">Sin eventos de StampLedger.</p>
                                }
                                else
                                {
                                    <div class="stamp-ledger-items" data-testid="admin-support-ledger">
                                        @foreach (var item in card.RecentStampEvents)
                                        {
                                            <div class="stamp-ledger-item" data-testid="admin-support-ledger-event">
                                                <div>
                                                    <strong>@item.Source</strong>
                                                    <span>@item.CreatedAt.ToLocalTime().ToString("g")</span>
                                                </div>
                                                <p>Sellos: @item.PreviousCheckQTY -> @item.NewCheckQTY &middot; Historicos: @item.PreviousHistoricCheckQTY -> @item.NewHistoricCheckQTY</p>
                                                <p>Google: @WalletStatus(item.GoogleWalletAttempted, item.GoogleWalletSucceeded) &middot; Apple: @WalletStatus(item.AppleWalletAttempted, item.AppleWalletSucceeded)</p>
                                                @if (!string.IsNullOrWhiteSpace(item.ErrorSummary))
                                                {
                                                    <p class="text-danger">Error: @item.ErrorSummary</p>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </article>
                        }
                    </div>
                </section>
            }
        </section>
    }
</section>

@functions {
    private static string WalletStatus(bool attempted, bool succeeded)
    {
        if (!attempted)
        {
            return "No aplica";
        }

        return succeeded ? "OK" : "Fallo";
    }

    private static string ActivationLabel(DigitalCards.Domain.BusinessActivationStatus status)
    {
        return status switch
        {
            DigitalCards.Domain.BusinessActivationStatus.PilotModern => "Piloto moderno",
            DigitalCards.Domain.BusinessActivationStatus.ModernPrimary => "Moderno principal",
            DigitalCards.Domain.BusinessActivationStatus.LegacyRetired => "Legacy retirado",
            DigitalCards.Domain.BusinessActivationStatus.Inactive => "Inactivo",
            _ => "Legacy only"
        };
    }
}
