@page "{businessId:guid}"
@model DigitalCards.Web.Pages.Admin.BusinessProfileModel
@using DigitalCards.Domain
@{
    ViewData["Title"] = "Administrar negocio";
}

<section class="result-panel">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Admin</p>
            <h1>Administrar negocio</h1>
            @if (Model.Profile is not null)
            {
                <p class="lead" data-testid="admin-business-profile-heading">@Model.Profile.BusinessName</p>
            }
        </div>
        <a class="btn btn-outline-secondary" asp-page="/Admin/Businesses" data-testid="admin-business-profile-back-link">Negocios</a>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status" data-testid="admin-business-profile-status">
            @Model.StatusMessage
        </div>
    }

    @if (Model.Profile is not null)
    {
        <section class="business-profile-panel mb-4" data-testid="admin-business-public-enrollment">
            <h2>Registro publico del negocio</h2>
            <p class="text-muted">Genera un link para que clientes se registren directamente en este programa. El link no se guarda en ninguna base de datos.</p>
            @if (!string.IsNullOrWhiteSpace(Model.GeneratedEnrollmentUrl))
            {
                <div class="alert alert-info" role="status" data-testid="admin-business-public-enrollment-url">
                    <strong>Link generado:</strong>
                    <a href="@Model.GeneratedEnrollmentUrl">@Model.GeneratedEnrollmentUrl</a>
                </div>
            }
            <form method="post"
                  asp-page-handler="GenerateEnrollmentLink"
                  asp-route-businessId="@Model.Profile.BusinessId">
                <button class="btn btn-outline-primary" type="submit" data-testid="admin-business-generate-enrollment-link">
                    Generar nuevo link publico
                </button>
            </form>
        </section>

        @if (Model.OperationalView is not null)
        {
            var operations = Model.OperationalView;
            <section class="business-profile-panel mb-4" data-testid="admin-business-operational-panel">
                <div class="page-heading">
                    <div>
                        <p class="eyebrow">Administrar</p>
                        <h2>Estado operativo</h2>
                        <p class="text-muted mb-0">Senales utiles para confirmar que el negocio esta listo para operar en Puntelio.</p>
                    </div>
                    <a class="btn btn-outline-primary"
                       asp-page="/Admin/Support"
                       asp-route-BusinessFilter="@Model.Profile.BusinessName"
                       data-testid="admin-business-profile-support-link">
                        Soporte
                    </a>
                </div>

                <div class="metric-row">
                    <div class="metric">
                        <span>Estado</span>
                        <strong data-testid="admin-business-profile-active-state">@(Model.Profile.IsPilotEnabled ? "Activo" : "Inactivo")</strong>
                    </div>
                    <div class="metric">
                        <span>Tarjetas</span>
                        <strong>@(operations.Report?.CardCount ?? 0)</strong>
                    </div>
                    <div class="metric">
                        <span>Clientes</span>
                        <strong>@(operations.Report?.ClientCount ?? 0)</strong>
                    </div>
                    <div class="metric">
                        <span>Alertas</span>
                        <strong>@(operations.Report?.WalletIssueCount ?? 0)</strong>
                    </div>
                </div>

                <div class="cutover-signal-grid" data-testid="admin-business-profile-readiness">
                    <div>
                        <h3>Listo</h3>
                        @foreach (var signal in operations.ReadySignals)
                        {
                            <span class="badge text-bg-success">@signal</span>
                        }
                    </div>
                    <div>
                        <h3>Pendiente</h3>
                        @foreach (var signal in operations.MissingSignals)
                        {
                            <span class="badge text-bg-warning">@signal</span>
                        }
                    </div>
                </div>

                <div class="cutover-smoke-evidence" data-testid="admin-business-profile-smoke-evidence">
                    <h3>Ultimo smoke real</h3>
                    @if (operations.LatestSmoke is null)
                    {
                        <p class="text-muted">Sin evidencia registrada para este negocio.</p>
                    }
                    else
                    {
                        var smoke = operations.LatestSmoke;
                        <p>
                            <strong>@(smoke.IsComplete ? "Completo" : "Con pendientes")</strong>
                            registrado por @smoke.AdminUserName el @smoke.CreatedAt.ToLocalTime().ToString("g")
                        </p>
                        <div class="d-flex gap-2 flex-wrap">
                            <span class="badge @(smoke.HealthOk ? "text-bg-success" : "text-bg-warning")">Health</span>
                            <span class="badge @(smoke.ReadyOk ? "text-bg-success" : "text-bg-warning")">Ready</span>
                            <span class="badge @(smoke.EmailOk ? "text-bg-success" : "text-bg-warning")">Correo</span>
                            <span class="badge @(smoke.AppleWalletOk ? "text-bg-success" : "text-bg-warning")">Wallet movil</span>
                            <span class="badge @(smoke.GoogleWalletOk ? "text-bg-success" : "text-bg-warning")">Wallet guardada</span>
                            <span class="badge @(smoke.ModernStampOk ? "text-bg-success" : "text-bg-warning")">Sello</span>
                            <span class="badge @(smoke.SupportReviewed ? "text-bg-success" : "text-bg-warning")">Soporte</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(smoke.Notes))
                        {
                            <p class="text-muted">@smoke.Notes</p>
                        }
                    }
                </div>

            </section>
        }

        <div class="business-profile-grid">
            <form method="post"
                  asp-page-handler="Save"
                  asp-route-businessId="@Model.Profile.BusinessId"
                  class="business-profile-panel"
                  data-testid="admin-business-profile-form">
                <h2>Datos del negocio</h2>

                <div class="mb-3">
                    <label asp-for="Input.BusinessName" class="form-label">Nombre</label>
                    <input asp-for="Input.BusinessName" class="form-control" maxlength="30" data-testid="admin-business-profile-name" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.BusinessEmail" class="form-label">Correo</label>
                    <input asp-for="Input.BusinessEmail" class="form-control" maxlength="30" data-testid="admin-business-profile-email" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.BusinessLogo" class="form-label">Logo</label>
                    <input asp-for="Input.BusinessLogo" class="form-control" maxlength="100" data-testid="admin-business-profile-logo" />
                    <small class="form-text text-muted">Ruta publica del logo o URL corta.</small>
                </div>

                <input asp-for="Input.IsPilotEnabled" type="hidden" />

                <div class="mb-3">
                    <label asp-for="Input.ActivationStatus" class="form-label">Estado de activacion</label>
                    <select asp-for="Input.ActivationStatus" class="form-select" data-testid="admin-business-activation-status">
                        <option value="@((int)BusinessActivationStatus.ModernPrimary)">Activo</option>
                        <option value="@((int)BusinessActivationStatus.Inactive)">Inactivo</option>
                    </select>
                    <small class="form-text text-muted">Inactivo bloquea el acceso del negocio.</small>
                </div>

                <button class="btn btn-primary" type="submit" data-testid="admin-business-profile-save">Guardar cambios</button>
            </form>

            <form method="post"
                  asp-page-handler="ResetPassword"
                  asp-route-businessId="@Model.Profile.BusinessId"
                  class="business-profile-panel"
                  data-testid="admin-business-password-form">
                <h2>Reset de contrasena</h2>
                <p class="text-muted">Actualiza la credencial de acceso del negocio.</p>

                <div class="mb-3">
                    <label asp-for="PasswordInput.NewPassword" class="form-label">Nueva contrasena</label>
                    <input asp-for="PasswordInput.NewPassword" class="form-control" type="password" autocomplete="new-password" data-testid="admin-business-password-new" />
                </div>

                <div class="mb-3">
                    <label asp-for="PasswordInput.ConfirmPassword" class="form-label">Confirmar contrasena</label>
                    <input asp-for="PasswordInput.ConfirmPassword" class="form-control" type="password" autocomplete="new-password" data-testid="admin-business-password-confirm" />
                </div>

                <button class="btn btn-outline-danger" type="submit" data-testid="admin-business-password-submit">Actualizar contrasena</button>
            </form>

            <form method="post"
                  asp-page-handler="DeleteBusiness"
                  asp-route-businessId="@Model.Profile.BusinessId"
                  class="business-profile-panel border-danger danger-zone-card"
                  data-testid="admin-business-delete-form">
                <h2>Eliminar negocio permanentemente</h2>
                <p class="text-muted">
                    Elimina el negocio, sus tarjetas/asociaciones de clientes y datos Wallet relacionados. Las cuentas globales de clientes no se borran.
                </p>
                <label class="form-label" for="business-delete-confirmation">Escribe exactamente: @Model.Profile.BusinessName</label>
                <input id="business-delete-confirmation"
                       name="confirmation"
                       class="form-control"
                       autocomplete="off"
                       data-testid="admin-business-delete-confirmation" />
                <button class="btn btn-danger mt-3" type="submit" data-testid="admin-business-delete-submit">
                    Eliminar permanentemente
                </button>
            </form>

            <form method="post"
                  asp-page-handler="SendInvite"
                  asp-route-businessId="@Model.Profile.BusinessId"
                  class="business-profile-panel"
                  data-testid="admin-business-invite-form">
                <h2>Invitacion de acceso</h2>
                <p class="text-muted">Envia un correo al negocio con un link seguro para configurar su contrasena. No se muestra ni se envia password plano.</p>

                <div class="business-profile-meta">
                    <span>Destino</span>
                    <strong data-testid="admin-business-invite-email">@Model.Profile.BusinessEmail</strong>
                </div>

                <button class="btn btn-outline-primary" type="submit" data-testid="admin-business-send-invite">Enviar invitacion</button>
            </form>

            <form method="post"
                  asp-page-handler="Branding"
                  asp-route-businessId="@Model.Profile.BusinessId"
                  enctype="multipart/form-data"
                  class="business-profile-panel business-branding-panel"
                  data-testid="admin-business-branding-form">
                <h2>Perfil publico</h2>
                <p class="text-muted">Estos datos aparecen en correos, landing Wallet, tarjeta digital y dashboard cliente.</p>

                <div class="mb-3">
                    <label asp-for="BrandingInput.PublicName" class="form-label">Nombre del negocio</label>
                    <input asp-for="BrandingInput.PublicName" class="form-control" maxlength="80" data-testid="admin-business-branding-public-name" />
                </div>

                <div class="mb-3">
                    <label asp-for="BrandingInput.ProgramName" class="form-label">Programa</label>
                    <input asp-for="BrandingInput.ProgramName" class="form-control" maxlength="80" data-testid="admin-business-branding-program-name" />
                </div>

                <div class="mb-3">
                    <label asp-for="BrandingInput.ProgramDescription" class="form-label">Recompensa</label>
                    <textarea asp-for="BrandingInput.ProgramDescription" class="form-control" rows="3" maxlength="280" data-testid="admin-business-branding-description"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="BrandingInput.StampGoal" class="form-label">Numero de sellos</label>
                    <input asp-for="BrandingInput.StampGoal" class="form-control" type="number" min="1" max="1000" data-testid="admin-business-branding-stamp-goal" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Logo actual</label>
                    @{
                        var hasBrandingLogo = !Model.BrandingLogoUnavailable && !string.IsNullOrWhiteSpace(Model.Profile.Branding.LogoPath);
                    }
                    <div class="branding-logo-preview"
                         data-testid="admin-business-branding-logo-preview"
                         data-branding-logo-preview-container
                         hidden="@(!hasBrandingLogo)">
                        <img src="@(hasBrandingLogo ? VersionedLogoPath(Model.Profile.Branding.LogoPath, Model.Profile.Branding.UpdatedAt) : string.Empty)"
                             alt="Logo actual"
                             data-branding-logo-preview-image
                             hidden="@(!hasBrandingLogo)" />
                    </div>
                    @if (Model.BrandingLogoUnavailable)
                    {
                        <div class="alert alert-warning py-2 mb-2" role="status" data-testid="admin-business-branding-logo-missing" data-branding-logo-placeholder>
                            El logo actual no esta disponible; sube un PNG nuevo.
                        </div>
                    }
                    else if (!hasBrandingLogo)
                    {
                        <p class="text-muted mb-2" data-testid="admin-business-branding-logo-empty" data-branding-logo-placeholder>Sin logo personalizado.</p>
                    }
                    <label asp-for="BrandingInput.LogoUpload" class="form-label">Subir logo PNG</label>
                    <input asp-for="BrandingInput.LogoUpload" class="form-control" type="file" accept=".png,image/png" data-testid="admin-business-branding-logo-upload" data-branding-logo-upload />
                    <small class="form-text text-muted">Solo PNG. Maximo 2 MB. Si no es cuadrado, Puntelio lo centra en un lienzo transparente para Wallet.</small>
                </div>

                <div class="branding-color-row">
                    <div class="mb-3">
                        <label asp-for="BrandingInput.PrimaryColor" class="form-label">Color primario</label>
                        <input asp-for="BrandingInput.PrimaryColor" class="form-control" maxlength="7" data-testid="admin-business-branding-primary" data-branding-color-input="primary" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="BrandingInput.SecondaryColor" class="form-label">Color secundario 1</label>
                        <input asp-for="BrandingInput.SecondaryColor" class="form-control" maxlength="7" data-testid="admin-business-branding-secondary" data-branding-color-input="secondary" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="BrandingInput.CustomFieldColor" class="form-label">Color secundario 2</label>
                        <input asp-for="BrandingInput.CustomFieldColor" class="form-control" maxlength="7" data-testid="admin-business-branding-custom-field-color" data-branding-color-input="custom" />
                    </div>
                </div>

                <div class="branding-preview"
                     style="--brand-primary:@Model.BrandingInput.PrimaryColor;--brand-secondary:@Model.BrandingInput.SecondaryColor;--brand-custom:@Model.BrandingInput.CustomFieldColor;"
                     data-testid="admin-business-branding-preview">
                    <span>@Model.BrandingInput.ProgramName</span>
                    <strong>@Model.BrandingInput.PublicName</strong>
                    <small>@Model.BrandingInput.ProgramDescription</small>
                </div>

                <div class="form-actions">
                    <button class="btn btn-primary" type="submit" data-testid="admin-business-branding-submit">Guardar</button>
                    <button class="btn btn-outline-primary"
                            type="submit"
                            asp-page-handler="SaveAndRefresh"
                            data-testid="admin-business-branding-save-refresh-submit">
                        Guardar y actualizar
                    </button>
                </div>
            </form>

            <form method="post"
                  asp-page-handler="RefreshWalletBranding"
                  asp-route-businessId="@Model.Profile.BusinessId"
                  class="business-profile-panel"
                  data-testid="admin-business-wallet-branding-refresh-form">
                <h2>Actualizar Tarjetas</h2>
                <p class="text-muted">Aplica el branding actual a todas las tarjetas digitales ya emitidas de este negocio. No modifica sellos ni datos del cliente.</p>

                @if (Model.RefreshResult is not null)
                {
                    <div class="wallet-refresh-summary" data-testid="admin-business-wallet-branding-refresh-result">
                        <span>Tarjetas Wallet: @Model.RefreshResult.CardsWithTrackedWallets</span>
                        <span>Actualizaciones: @(Model.RefreshResult.GoogleWalletSucceeded + Model.RefreshResult.AppleWalletSucceeded) / @(Model.RefreshResult.GoogleWalletAttempted + Model.RefreshResult.AppleWalletAttempted)</span>
                    </div>
                }

                <button class="btn btn-outline-primary" type="submit" data-testid="admin-business-wallet-branding-refresh-submit">Actualizar</button>
            </form>
        </div>

        @if (Model.OperationalView is not null)
        {
            var operations = Model.OperationalView;
            <section class="business-profile-panel mt-4" data-testid="admin-business-profile-smoke-section">
                <form method="post"
                      asp-page-handler="Smoke"
                      asp-route-businessId="@Model.Profile.BusinessId"
                      class="cutover-smoke-form"
                      data-testid="admin-business-profile-smoke-form">
                    <h3>Registrar smoke de activacion</h3>
                    <div class="cutover-smoke-checks">
                        <label class="form-check">
                            <input asp-for="SmokeInput.HealthOk" class="form-check-input" checked="@(operations.LatestSmoke?.HealthOk == true)" />
                            <span class="form-check-label">/health OK</span>
                        </label>
                        <label class="form-check">
                            <input asp-for="SmokeInput.ReadyOk" class="form-check-input" checked="@(operations.LatestSmoke?.ReadyOk == true)" />
                            <span class="form-check-label">/health/ready OK</span>
                        </label>
                        <label class="form-check">
                            <input asp-for="SmokeInput.EmailOk" class="form-check-input" checked="@(operations.LatestSmoke?.EmailOk == true)" />
                            <span class="form-check-label">Correo real validado</span>
                        </label>
                        <label class="form-check">
                            <input asp-for="SmokeInput.WalletMobileOk" class="form-check-input" checked="@(operations.LatestSmoke?.AppleWalletOk == true)" />
                            <span class="form-check-label">Wallet movil actualizada</span>
                        </label>
                        <label class="form-check">
                            <input asp-for="SmokeInput.WalletSavedOk" class="form-check-input" checked="@(operations.LatestSmoke?.GoogleWalletOk == true)" />
                            <span class="form-check-label">Wallet guardada actualizada</span>
                        </label>
                        <label class="form-check">
                            <input asp-for="SmokeInput.ModernStampOk" class="form-check-input" checked="@(operations.LatestSmoke?.ModernStampOk == true)" />
                            <span class="form-check-label">Sello probado</span>
                        </label>
                        <label class="form-check">
                            <input asp-for="SmokeInput.SupportReviewed" class="form-check-input" checked="@(operations.LatestSmoke?.SupportReviewed == true)" />
                            <span class="form-check-label">Soporte revisado</span>
                        </label>
                    </div>
                    <label asp-for="SmokeInput.Notes" class="form-label">Notas de evidencia</label>
                    <textarea asp-for="SmokeInput.Notes" class="form-control" rows="2" data-testid="admin-business-profile-smoke-notes"></textarea>
                    <button class="btn btn-outline-primary mt-2"
                            type="submit"
                            data-testid="admin-business-profile-smoke-save"
                            onclick="return confirm('Confirma que esta evidencia no incluye secretos ni datos sensibles.');">
                        Guardar evidencia
                    </button>
                </form>
            </section>
        }
    }
</section>

@functions {
    private static string VersionedLogoPath(string logoPath, DateTimeOffset? updatedAt)
    {
        if (string.IsNullOrWhiteSpace(logoPath))
        {
            return string.Empty;
        }

        var version = updatedAt?.ToUnixTimeSeconds() ?? DateTimeOffset.UtcNow.ToUnixTimeSeconds();
        var separator = logoPath.Contains('?', StringComparison.Ordinal) ? "&" : "?";
        return $"{logoPath}{separator}v={version}";
    }
}
